{
  "name": "website-with-admin",
  "version": "3.3.2",
  "description": "网站前端和后台管理系统 - 针对2核2G服务器优化",
  "main": "server/app.js",
  "scripts": {
    "start": "node --expose-gc --max-old-space-size=768 server/app.js",
    "dev": "node --expose-gc --max-old-space-size=768 server/app.js",
    "pm2": "pm2 start ecosystem.config.js",
    "pm2:restart": "pm2 restart ecosystem.config.js",
    "pm2:stop": "pm2 stop ecosystem.config.js",
    "pm2:logs": "pm2 logs website-admin",
    "pm2:monit": "pm2 monit",
    "start:prod": "npm run pm2",
    "health": "curl http://localhost:3000/health",
    "lint": "eslint . --ext .js,.mjs",
    "lint:fix": "eslint . --ext .js,.mjs --fix",
    "lint:frontend": "eslint public/js/ -c .eslintrc-frontend.json --ext .js",
    "lint:frontend:fix": "eslint public/js/ -c .eslintrc-frontend.json --ext .js --fix",
    "lint:server": "eslint server/ scripts/ --ext .js,.mjs",
    "lint:server:fix": "eslint server/ scripts/ --ext .js,.mjs --fix",
    "security:scan": "node scripts/security-scan.js",
    "security:audit": "npm audit",
    "security:audit:fix": "npm audit fix",
    "security:check": "node -e \"const config = require('./security-config.json'); console.log('安全配置验证通过:', Object.keys(config).length, '个配置项');\"",
    "security:full": "npm run security:audit && npm run security:scan",
    "cleanup": "node scripts/code-cleanup.js",
    "cleanup:dry-run": "node scripts/code-cleanup.js --dry-run",
    "cleanup:interactive": "node scripts/code-cleanup.js --interactive",
    "cleanup:fix": "node scripts/code-cleanup.js --fix",
    "cleanup:report": "node scripts/code-cleanup.js --report",
    "cleanup:full": "node scripts/code-cleanup.js --fix --report",
    "cleanup:verbose": "node scripts/code-cleanup.js --verbose --report",
    "review": "node scripts/code-review.js",
    "review:quick": "node scripts/code-review.js --level=quick",
    "review:standard": "node scripts/code-review.js --level=standard",
    "review:full": "node scripts/code-review.js --level=full",
    "review:ci": "node scripts/code-review.js --level=full --ci",
    "review:json": "node scripts/code-review.js --format=json",
    "review:markdown": "node scripts/code-review.js --format=markdown",
    "review:html": "node scripts/code-review.js --format=html",
    "review:text": "node scripts/code-review.js --format=text",
    "review:verbose": "node scripts/code-review.js --verbose"
  },
  "dependencies": {
    "adm-zip": "^0.5.17",
    "bcryptjs": "^2.4.3",
    "cookie-parser": "^1.4.7",
    "ejs": "^3.1.9",
    "express": "^4.18.2",
    "express-ejs-layouts": "^2.5.1",
    "express-session": "^1.17.3",
    "iconv-lite": "^0.6.3",
    "jsonwebtoken": "^9.0.2",
    "marked": "^12.0.0",
    "multer": "^1.4.5-lts.1",
    "node-cron": "^4.4.1",
    "nodemailer": "^8.0.6",
    "quill": "^2.0.0",
    "sql.js": "^1.9.0",
    "svg-captcha": "^1.4.0"
  },
  "optionalDependencies": {
    "better-sqlite3": "^8.4.0"
  },
  "devDependencies": {
    "eslint": "^8.56.0",
    "eslint-plugin-node": "^11.1.0",
    "eslint-plugin-promise": "^6.1.1",
    "eslint-plugin-security": "^2.1.0",
    "nodemon": "^3.0.2"
  },
  "engines": {
    "node": ">=14.0.0"
  }
}
