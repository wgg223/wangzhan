<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= modeTitle %> - <%= siteName %></title>
  <meta name="csrf-token" content="<%= csrfToken %>">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <link rel="stylesheet" href="/css/auth.css">
</head>
<body class="auth-page <%= source %>-theme">
  <div class="auth-container">
    <div class="auth-header">
      <h1><%= siteName %></h1>
      <p><%= modeSubtitle %></p>
    </div>
    
    <% if (error) { %>
      <div class="auth-alert auth-alert-error">
        <i class="fas fa-exclamation-circle"></i>
        <span><%= error %></span>
      </div>
    <% } %>
    <% if (success) { %>
      <div class="auth-alert auth-alert-success">
        <i class="fas fa-check-circle"></i>
        <span><%= success %></span>
      </div>
    <% } %>

    <!-- 登录表单 -->
    <% if (mode === 'login') { %>
      <form action="/auth/<%= source %>/login" method="POST" class="auth-form" id="loginForm">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        <div class="form-group">
          <label for="username">用户名</label>
          <input type="text" id="username" name="username" class="auth-input" placeholder="请输入用户名" required value="<%= typeof username !== 'undefined' ? username : '' %>">
        </div>
        
        <div class="form-group">
          <label for="password">密码</label>
          <div class="password-field">
            <input type="password" id="password" name="password" class="auth-input" placeholder="请输入密码" required>
            <button type="button" class="toggle-password" onclick="togglePassword('password')">
              <i class="fas fa-eye"></i>
            </button>
          </div>
        </div>
        
        <label class="remember-me">
          <input type="checkbox" name="remember" id="remember"> 记住密码
        </label>
        
        <button type="submit" class="auth-btn auth-btn-primary">
          <i class="fas fa-sign-in-alt"></i> 登录
        </button>
      </form>
      
      <div class="auth-links">
        <p>还没有账号？<a href="/auth/<%= source %>/register">立即注册</a></p>
        <p><a href="/auth/<%= source %>/forgot-password">忘记密码？</a></p>
        <% if (source === 'image-share') { %>
          <p><a href="/image-share">返回图片分享</a></p>
        <% } else { %>
          <p><a href="/">返回首页</a></p>
        <% } %>
      </div>

    <!-- 注册表单 - 信息填写步骤 -->
    <% } else if (mode === 'register' && step !== 'verify') { %>
      <form action="/auth/<%= source %>/register" method="POST" class="auth-form" id="registerForm">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        <div class="form-group">
          <label for="username">用户名 <span class="required">*</span></label>
          <input type="text" id="username" name="username" class="auth-input" placeholder="3-20个字符" required minlength="3" maxlength="20" value="<%= typeof username !== 'undefined' ? username : '' %>">
        </div>

        <% if (source === 'image-share') { %>
          <div class="form-group">
            <label for="nickname">昵称</label>
            <input type="text" id="nickname" name="nickname" class="auth-input" placeholder="选填">
          </div>
        <% } %>
        
        <div class="form-group">
          <label for="email">邮箱 <span class="required">*</span></label>
          <input type="text" id="email" name="email" class="auth-input" placeholder="请输入邮箱地址（格式如：username@domain.com）" required value="<%= typeof email !== 'undefined' ? email : '' %>" oninput="validateEmailFormat(this)">
          <small id="emailHelp" class="form-text" style="color:#999;font-size:12px;display:block;margin-top:4px;">邮箱格式：用户名@域名（如：username@example.com）</small>
        </div>
        
        <div class="form-group">
          <label for="password">密码 <span class="required">*</span></label>
          <div class="password-field">
            <input type="password" id="password" name="password" class="auth-input" placeholder="至少6个字符" required minlength="6">
            <button type="button" class="toggle-password" onclick="togglePassword('password')">
              <i class="fas fa-eye"></i>
            </button>
          </div>
        </div>
        
        <div class="form-group">
          <label for="confirm_password">确认密码 <span class="required">*</span></label>
          <div class="password-field">
            <input type="password" id="confirm_password" name="confirm_password" class="auth-input" placeholder="请再次输入密码" required minlength="6">
            <button type="button" class="toggle-password" onclick="togglePassword('confirm_password')">
              <i class="fas fa-eye"></i>
            </button>
          </div>
          <div id="passwordStrength" style="display: none; margin-top: 8px;">
            <div style="height: 4px; background: #e5e7eb; border-radius: 2px; overflow: hidden;">
              <div id="strengthBar" style="height: 100%; width: 0%; transition: all 0.3s; border-radius: 2px;"></div>
            </div>
            <small id="strengthText" style="font-size: 11px; margin-top: 4px; display: block;"></small>
          </div>
          <small id="passwordMatch" style="font-size: 11px; margin-top: 4px; display: block;"></small>
        </div>
        
        <!-- 图形验证码 -->
        <div class="form-group captcha-group">
          <label for="registerCaptcha">图形验证码 <span class="required">*</span></label>
          <div class="captcha-container">
            <div class="captcha-image-wrapper" id="registerCaptchaWrapper" onclick="refreshRegisterCaptcha()">
              <%- captchaSvg %>
            </div>
            <button type="button" class="captcha-refresh" onclick="refreshRegisterCaptcha()" title="刷新验证码">
              <i class="fas fa-sync-alt"></i>
            </button>
          </div>
          <input type="text" id="registerCaptcha" name="captcha" class="auth-input" 
                 placeholder="请输入计算结果" required maxlength="10" autocomplete="off">
        </div>

        <% if (source === 'frontend') { %>
          <!-- 用户协议 - 仅主站点 -->
          <div class="form-group agreement-group">
            <label class="auth-checkbox-label">
              <input type="checkbox" id="agreeCheck" name="agree" value="1" required>
              <span>我已阅读并同意
                <a href="javascript:void(0)" onclick="showAuthModal('terms')">《用户协议》</a>
                和
                <a href="javascript:void(0)" onclick="showAuthModal('privacy')">《隐私政策》</a>
              </span>
            </label>
          </div>
        <% } %>
        
        <button type="submit" class="auth-btn auth-btn-primary" id="registerBtn">
          <i class="fas fa-user-plus"></i> 注册
        </button>
      </form>
      
      <div class="auth-links">
        <p>已有账号？<a href="/auth/<%= source %>/login">立即登录</a></p>
        <% if (source === 'image-share') { %>
          <p><a href="/image-share">返回图片分享</a></p>
        <% } else { %>
          <p><a href="/">返回首页</a></p>
        <% } %>
      </div>

    <!-- 注册表单 - 验证码步骤 -->
    <% } else if (mode === 'register' && step === 'verify') { %>
      <form action="/auth/<%= source %>/register" method="POST" class="auth-form" id="verifyForm">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        <input type="hidden" name="step" value="verify">
        <div class="form-group">
          <label>邮箱地址</label>
          <input type="text" class="auth-input" value="<%= email %>" disabled style="background:#f5f5f5;">
          <input type="hidden" name="email" value="<%= email %>">
        </div>
        
        <div class="form-group">
          <label for="code">验证码 <span class="required">*</span></label>
          <input type="text" id="code" name="code" class="auth-input auth-input-code" placeholder="请输入验证码" required maxlength="8" pattern="[0-9a-fA-F]{8}" autocomplete="off" style="text-align:center;font-size:24px;letter-spacing:4px;">
        </div>
        
        <div class="form-group">
          <button type="button" class="auth-btn" id="resendCodeBtn" style="background:#f0f0f0;color:#666;font-size:13px;" onclick="resendVerifyCode()">
            <i class="fas fa-redo"></i> <span id="resendText">重新发送验证码</span>
          </button>
        </div>
        
        <button type="submit" class="auth-btn auth-btn-primary" id="verifyBtn">
          <i class="fas fa-check-circle"></i> 验证并注册
        </button>
      </form>
      
      <div class="auth-links">
        <p><a href="/auth/<%= source %>/register">返回上一步</a></p>
        <p>已有账号？<a href="/auth/<%= source %>/login">立即登录</a></p>
        <% if (source === 'frontend') { %>
          <p><a href="/">返回首页</a></p>
        <% } %>
      </div>

    <!-- 忘记密码 - 邮箱步骤 -->
    <% } else if (mode === 'forgot-password' && step === 'email') { %>
      <form action="/auth/<%= source %>/forgot-password/send-code" method="POST" class="auth-form" id="forgotPasswordForm">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        <div class="form-group">
          <label for="email">邮箱地址</label>
          <input type="email" id="email" name="email" class="auth-input" value="<%= email %>" placeholder="请输入注册邮箱" required>
        </div>

        <!-- 图形验证码 -->
        <div class="form-group captcha-group">
          <label for="forgotCaptcha">图形验证码 <span class="required">*</span></label>
          <div class="captcha-container">
            <div class="captcha-image-wrapper" id="forgotCaptchaWrapper" onclick="refreshForgotCaptcha()">
              <%- typeof captchaSvg !== 'undefined' && captchaSvg ? captchaSvg : '' %>
            </div>
            <button type="button" class="captcha-refresh" onclick="refreshForgotCaptcha()" title="刷新验证码">
              <i class="fas fa-sync-alt"></i>
            </button>
          </div>
          <input type="text" id="forgotCaptcha" name="captcha" class="auth-input" 
                 placeholder="请输入计算结果" required maxlength="10" autocomplete="off">
        </div>

        <button type="submit" class="auth-btn auth-btn-primary">
          <i class="fas fa-paper-plane"></i> 发送验证码
        </button>
      </form>
      
      <div class="auth-links">
        <p><a href="/auth/<%= source %>/login">返回登录</a></p>
      </div>

    <!-- 忘记密码 - 验证码步骤 -->
    <% } else if (mode === 'forgot-password' && step === 'verify') { %>
      <form action="/auth/<%= source %>/forgot-password/reset" method="POST" class="auth-form">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        <input type="hidden" name="email" value="<%= email %>">
        
        <div class="form-group">
          <label for="code">验证码</label>
          <input type="text" id="code" name="code" class="auth-input auth-input-code" placeholder="请输入验证码" required maxlength="8" pattern="[0-9a-fA-F]{8}">
        </div>

        <div class="form-group">
          <label for="new_password">新密码</label>
          <div class="password-field">
            <input type="password" id="new_password" name="new_password" class="auth-input" placeholder="请输入新密码（至少6位）" required minlength="6">
            <button type="button" class="toggle-password" onclick="togglePassword('new_password')">
              <i class="fas fa-eye"></i>
            </button>
          </div>
        </div>

        <div class="form-group">
          <label for="confirm_password">确认新密码</label>
          <div class="password-field">
            <input type="password" id="confirm_password" name="confirm_password" class="auth-input" placeholder="请再次输入新密码" required minlength="6">
            <button type="button" class="toggle-password" onclick="togglePassword('confirm_password')">
              <i class="fas fa-eye"></i>
            </button>
          </div>
        </div>

        <button type="submit" class="auth-btn auth-btn-primary">
          <i class="fas fa-key"></i> 重置密码
        </button>
      </form>
      
      <div class="auth-links">
        <p><a href="/auth/<%= source %>/forgot-password">重新发送验证码</a></p>
        <p><a href="/auth/<%= source %>/login">返回登录</a></p>
      </div>

    <!-- 修改密码 -->
    <% } else if (mode === 'change-password') { %>
      <form action="/auth/<%= source %>/change-password" method="POST" class="auth-form">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        <% if (user) { %>
          <div class="form-group">
            <label>当前用户</label>
            <input type="text" value="<%= user.username %>" disabled class="auth-input">
          </div>
        <% } else { %>
          <div class="form-group">
            <label for="username">用户名</label>
            <input type="text" id="username" name="username" class="auth-input" placeholder="请输入用户名" required>
          </div>
        <% } %>

        <div class="form-group">
          <label for="current_password">当前密码</label>
          <div class="password-field">
            <input type="password" id="current_password" name="current_password" class="auth-input" placeholder="请输入当前密码" required>
            <button type="button" class="toggle-password" onclick="togglePassword('current_password')">
              <i class="fas fa-eye"></i>
            </button>
          </div>
        </div>

        <div class="form-group">
          <label for="new_password">新密码</label>
          <div class="password-field">
            <input type="password" id="new_password" name="new_password" class="auth-input" placeholder="请输入新密码（至少6位）" required minlength="6">
            <button type="button" class="toggle-password" onclick="togglePassword('new_password')">
              <i class="fas fa-eye"></i>
            </button>
          </div>
        </div>

        <div class="form-group">
          <label for="confirm_password">确认新密码</label>
          <div class="password-field">
            <input type="password" id="confirm_password" name="confirm_password" class="auth-input" placeholder="请再次输入新密码" required minlength="6">
            <button type="button" class="toggle-password" onclick="togglePassword('confirm_password')">
              <i class="fas fa-eye"></i>
            </button>
          </div>
        </div>

        <button type="submit" class="auth-btn auth-btn-primary">
          <i class="fas fa-key"></i> 修改密码
        </button>
      </form>
      
      <div class="auth-links">
        <p><a href="/">返回首页</a></p>
      </div>

    <!-- 修改用户名 -->
    <% } else if (mode === 'change-username') { %>
      <form action="/auth/<%= source %>/change-username" method="POST" class="auth-form">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        <div class="form-group">
          <label>当前用户名</label>
          <input type="text" value="<%= user ? user.username : '' %>" disabled class="auth-input">
        </div>

        <div class="form-group">
          <label for="new_username">新用户名</label>
          <input type="text" id="new_username" name="new_username" class="auth-input" placeholder="3-20个字符，支持中文、字母、数字和下划线" required minlength="3" maxlength="20" value="<%= typeof username !== 'undefined' ? username : '' %>">
        </div>

        <div class="form-group">
          <label for="password">当前密码（验证身份）</label>
          <div class="password-field">
            <input type="password" id="password" name="password" class="auth-input" placeholder="请输入当前密码以验证身份" required>
            <button type="button" class="toggle-password" onclick="togglePassword('password')">
              <i class="fas fa-eye"></i>
            </button>
          </div>
        </div>

        <button type="submit" class="auth-btn auth-btn-primary">
          <i class="fas fa-user-edit"></i> 修改用户名
        </button>
      </form>
      
      <div class="auth-links">
        <p><a href="/">返回首页</a></p>
      </div>

    <!-- 强制修改密码 -->
    <% } else if (mode === 'force-change-password') { %>
      <div class="auth-alert auth-alert-warning">
        <i class="fas fa-exclamation-triangle"></i>
        <span>您的密码已被管理员重置，请设置一个新密码后继续使用。</span>
      </div>

      <form action="/auth/<%= source %>/force-change-password" method="POST" class="auth-form">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        <div class="form-group">
          <label>当前用户</label>
          <input type="text" value="<%= user.username %>" disabled class="auth-input">
        </div>

        <div class="form-group">
          <label for="new_password">新密码</label>
          <div class="password-field">
            <input type="password" id="new_password" name="new_password" class="auth-input" placeholder="请输入新密码（至少6位）" required minlength="6">
            <button type="button" class="toggle-password" onclick="togglePassword('new_password')">
              <i class="fas fa-eye"></i>
            </button>
          </div>
        </div>

        <div class="form-group">
          <label for="confirm_password">确认新密码</label>
          <div class="password-field">
            <input type="password" id="confirm_password" name="confirm_password" class="auth-input" placeholder="请再次输入新密码" required minlength="6">
            <button type="button" class="toggle-password" onclick="togglePassword('confirm_password')">
              <i class="fas fa-eye"></i>
            </button>
          </div>
        </div>

        <button type="submit" class="auth-btn auth-btn-primary">
          <i class="fas fa-check-circle"></i> 确认修改
        </button>
      </form>
    <% } %>
  </div>

  <!-- 用户协议弹窗 - 仅前端站点 -->
  <% if (source === 'frontend' && mode === 'register') { %>
    <div class="auth-modal-overlay" id="termsModal">
      <div class="auth-modal-content">
        <div class="auth-modal-header">
          <h2>用户协议</h2>
          <button class="auth-modal-close" onclick="closeAuthModal('terms')">&times;</button>
        </div>
        <div class="auth-modal-body">
          <%- userAgreement || '<p>暂无用户协议内容</p>' %>
        </div>
        <div class="auth-modal-footer">
          <button class="auth-btn auth-btn-primary" style="width:auto; padding: 10px 24px;" onclick="agreeAndCloseAuth('terms')">我已阅读并同意</button>
          <button class="auth-btn" style="width:auto; padding: 10px 24px; background:#f0f0f0; color:#666;" onclick="closeAuthModal('terms')">关闭</button>
        </div>
      </div>
    </div>

    <div class="auth-modal-overlay" id="privacyModal">
      <div class="auth-modal-content">
        <div class="auth-modal-header">
          <h2>隐私政策</h2>
          <button class="auth-modal-close" onclick="closeAuthModal('privacy')">&times;</button>
        </div>
        <div class="auth-modal-body">
          <%- privacyPolicy || '<p>暂无隐私政策内容</p>' %>
        </div>
        <div class="auth-modal-footer">
          <button class="auth-btn auth-btn-primary" style="width:auto; padding: 10px 24px;" onclick="agreeAndCloseAuth('privacy')">我已阅读并同意</button>
          <button class="auth-btn" style="width:auto; padding: 10px 24px; background:#f0f0f0; color:#666;" onclick="closeAuthModal('privacy')">关闭</button>
        </div>
      </div>
    </div>
  <% } %>

  <script>
    // 邮箱格式验证函数（基础格式校验：用户名@域名）
    function validateEmailFormat(input) {
      var email = input.value.trim();
      var helpEl = document.getElementById('emailHelp');
      if (!helpEl) return;
      if (email.length === 0) {
        input.style.borderColor = '';
        helpEl.style.color = '#999';
        helpEl.textContent = '邮箱格式：用户名@域名（如：username@example.com）';
        return;
      }
      // 标准邮箱格式校验（与后端一致）
      var emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
      if (emailRegex.test(email)) {
        input.style.borderColor = '#28a745';
        helpEl.style.color = '#28a745';
        helpEl.textContent = '✓ 邮箱格式正确';
      } else {
        input.style.borderColor = '#dc3545';
        helpEl.style.color = '#dc3545';
        var errMsg = '';
        if (!email.includes('@')) {
          errMsg = '邮箱缺少 @ 符号（如 username@example.com）';
        } else if (!email.includes('.')) {
          errMsg = '邮箱域名不完整，缺少 .xxx 后缀';
        } else {
          errMsg = '邮箱格式不正确，请检查输入';
        }
        helpEl.textContent = '✗ ' + errMsg;
      }
    }

    // 密码显示/隐藏功能
    function togglePassword(inputId) {
      var input = document.getElementById(inputId);
      if (!input) return;
      var icon = input.parentElement.querySelector('.toggle-password i');
      if (input.type === 'password') {
        input.type = 'text';
        icon.classList.remove('fa-eye');
        icon.classList.add('fa-eye-slash');
      } else {
        input.type = 'password';
        icon.classList.remove('fa-eye-slash');
        icon.classList.add('fa-eye');
      }
    }

    // 图形验证码刷新功能 - 通过 JSON 接口获取新的验证码内容并直接替换
    function refreshCaptchaCommon(imgWrapperId) {
      var imgWrapper = document.getElementById(imgWrapperId);
      if (!imgWrapper) return;
      fetch('/auth/captcha')
        .then(function(response) { return response.text(); })
        .then(function(svgData) {
          imgWrapper.innerHTML = svgData;
        })
        .catch(function() {
          location.reload();
        });
    }

    function refreshRegisterCaptcha() {
      refreshCaptchaCommon('registerCaptchaWrapper');
    }

    function refreshForgotCaptcha() {
      refreshCaptchaCommon('forgotCaptchaWrapper');
    }

    <% if (mode === 'login') { %>
    // 记住密码功能
    function saveCredentials(username, password) {
      try {
        localStorage.setItem('auth_remember_<%= source %>', JSON.stringify({
          username: btoa(unescape(encodeURIComponent(username))),
          password: btoa(unescape(encodeURIComponent(password)))
        }));
      } catch(e) {}
    }

    function loadCredentials() {
      try {
        var data = localStorage.getItem('auth_remember_<%= source %>');
        if (data) {
          var parsed = JSON.parse(data);
          return {
            username: decodeURIComponent(escape(atob(parsed.username))),
            password: decodeURIComponent(escape(atob(parsed.password)))
          };
        }
      } catch(e) {}
      return null;
    }

    function clearCredentials() {
      localStorage.removeItem('auth_remember_<%= source %>');
    }

    // 页面加载时自动填充
    (function() {
      var creds = loadCredentials();
      if (creds) {
        var usernameInput = document.getElementById('username');
        var passwordInput = document.getElementById('password');
        var rememberCheck = document.getElementById('remember');
        if (usernameInput && creds.username) usernameInput.value = creds.username;
        if (passwordInput && creds.password) passwordInput.value = creds.password;
        if (rememberCheck) rememberCheck.checked = true;
      }
    })();

    // 表单提交处理
    var loginForm = document.getElementById('loginForm');
    if (loginForm) {
      loginForm.addEventListener('submit', function(e) {
        var rememberCheck = document.getElementById('remember');
        var usernameInput = document.getElementById('username');
        var passwordInput = document.getElementById('password');
        if (rememberCheck && rememberCheck.checked) {
          saveCredentials(usernameInput.value, passwordInput.value);
        } else {
          clearCredentials();
        }
      });
    }
    <% } %>

    <% if (source === 'frontend' && mode === 'register') { %>
    // 弹窗控制
    function showAuthModal(type) {
      document.getElementById(type + 'Modal').classList.add('active');
      document.body.style.overflow = 'hidden';
    }

    function closeAuthModal(type) {
      document.getElementById(type + 'Modal').classList.remove('active');
      document.body.style.overflow = '';
    }

    function agreeAndCloseAuth(type) {
      document.getElementById('agreeCheck').checked = true;
      closeAuthModal(type);
    }

    // 点击遮罩层关闭弹窗
    document.addEventListener('click', function(e) {
      if (e.target.classList.contains('auth-modal-overlay')) {
        e.target.classList.remove('active');
        document.body.style.overflow = '';
      }
    });

    // 表单提交验证复选框和邮箱格式
    var registerForm = document.getElementById('registerForm');
    if (registerForm) {
      registerForm.addEventListener('submit', function(e) {
        var agreeCheck = document.getElementById('agreeCheck');
        if (agreeCheck && !agreeCheck.checked) {
          e.preventDefault();
          agreeCheck.focus();
          var label = agreeCheck.closest('.auth-checkbox-label');
          if (label) {
            label.style.color = 'var(--auth-error)';
            setTimeout(function() { label.style.color = ''; }, 2000);
          }
          return false;
        }
        // 提交时再次验证邮箱格式
        var emailInput = document.getElementById('email');
        if (emailInput) {
          var email = emailInput.value.trim();
          var emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
          if (!emailRegex.test(email)) {
            e.preventDefault();
            validateEmailFormat(emailInput);
            emailInput.focus();
            return false;
          }
        }
      });
    }

    // 抖动动画
    var shakeStyle = document.createElement('style');
    shakeStyle.textContent = '@keyframes shake { 0%, 100% { transform: translateX(0); } 25% { transform: translateX(-6px); } 50% { transform: translateX(6px); } 75% { transform: translateX(-3px); } }';
    document.head.appendChild(shakeStyle);

    // 密码强度检测
    var passwordInput = document.getElementById('password');
    var confirmInput = document.getElementById('confirm_password');
    if (passwordInput && confirmInput) {
      passwordInput.addEventListener('input', checkPasswordStrength);
      confirmInput.addEventListener('input', checkPasswordMatch);
    }

    function checkPasswordStrength() {
      var pwd = document.getElementById('password').value;
      var strengthEl = document.getElementById('passwordStrength');
      var bar = document.getElementById('strengthBar');
      var text = document.getElementById('strengthText');
      
      if (!pwd) { strengthEl.style.display = 'none'; return; }
      strengthEl.style.display = 'block';
      
      var score = 0;
      if (pwd.length >= 6) score++;
      if (pwd.length >= 10) score++;
      if (/[A-Z]/.test(pwd) && /[a-z]/.test(pwd)) score++;
      if (/[0-9]/.test(pwd)) score++;
      if (/[^A-Za-z0-9]/.test(pwd)) score++;
      
      var levels = [
        { width: '20%', color: '#ef4444', text: '弱', textColor: '#ef4444' },
        { width: '40%', color: '#f97316', text: '一般', textColor: '#f97316' },
        { width: '60%', color: '#eab308', text: '中等', textColor: '#eab308' },
        { width: '80%', color: '#22c55e', text: '强', textColor: '#22c55e' },
        { width: '100%', color: '#16a34a', text: '非常强', textColor: '#16a34a' }
      ];
      
      var level = levels[Math.min(score, 4)];
      bar.style.width = level.width;
      bar.style.background = level.color;
      text.textContent = '密码强度: ' + level.text;
      text.style.color = level.textColor;
    }

    function checkPasswordMatch() {
      var pwd = document.getElementById('password').value;
      var confirm = document.getElementById('confirm_password').value;
      var matchEl = document.getElementById('passwordMatch');
      
      if (!confirm) { matchEl.textContent = ''; return; }
      
      if (pwd === confirm) {
        matchEl.textContent = '✓ 密码匹配';
        matchEl.style.color = '#16a34a';
      } else {
        matchEl.textContent = '✗ 密码不匹配';
        matchEl.style.color = '#ef4444';
      }
    }
    <% } %>

    <% if (mode === 'register' && step === 'verify') { %>
    // 获取CSRF token
    function getCsrfToken() {
      var meta = document.querySelector('meta[name="csrf-token"]');
      return meta ? meta.getAttribute('content') : '';
    }
    
    // 验证码步骤 - 重新发送验证码
    function resendVerifyCode() {
      var btn = document.getElementById('resendCodeBtn');
      var text = document.getElementById('resendText');
      if (btn.disabled) return;
      
      btn.disabled = true;
      text.textContent = '发送中...';
      
      // 使用fetch API发送重新发送请求
      fetch('/auth/<%= source %>/register/resend-code', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/x-www-form-urlencoded',
          'X-CSRF-Token': getCsrfToken()
        }
      })
      .then(function(response) {
        return response.text();
      })
      .then(function(html) {
        // 刷新页面内容显示新消息
        document.open();
        document.write(html);
        document.close();
      })
      .catch(function() {
        text.textContent = '发送失败，请重试';
        btn.disabled = false;
        setTimeout(function() {
          text.textContent = '重新发送验证码';
        }, 2000);
      });
    }
    
    // 自动聚焦验证码输入框
    document.addEventListener('DOMContentLoaded', function() {
      var codeInput = document.getElementById('code');
      if (codeInput) {
        codeInput.focus();
      }
    });
    <% } %>
  </script>
</body>
</html>