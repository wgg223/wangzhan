<div class="container">
  <article class="page-content">
    <h1><%= page.title %></h1>
    <div class="page-body" style="color: <%= page.font_color || '#333333' %>;">
      <%- page.content || '<p>暂无内容</p>' %>
    </div>
    <div class="page-footer">
      <a href="/home" class="btn">返回首页</a>
    </div>
  </article>
</div>

<style>
.page-content {
  max-width: 900px;
  margin: 0 auto;
}
.page-body {
  line-height: 1.8;
  font-size: 16px;
  margin-top: 20px;
}
.page-body p {
  margin-bottom: 15px;
}
.page-body img {
  max-width: 100%;
  border-radius: 5px;
  margin: 10px 0;
}
.page-body table {
  width: 100%;
  border-collapse: collapse;
  margin: 15px 0;
}
.page-body th, .page-body td {
  border: 1px solid #ddd;
  padding: 10px;
  text-align: left;
}
.page-body th {
  background: #f5f5f5;
}
.page-body blockquote {
  border-left: 4px solid #007bff;
  padding: 10px 20px;
  margin: 15px 0;
  background: #f8f9fa;
  border-radius: 0 5px 5px 0;
}
.page-body pre {
  background: #f5f5f5;
  padding: 15px;
  border-radius: 5px;
  overflow-x: auto;
  margin: 15px 0;
}
.page-body code {
  background: #f5f5f5;
  padding: 2px 6px;
  border-radius: 3px;
  font-size: 14px;
}
.page-footer {
  margin-top: 30px;
  padding-top: 20px;
  border-top: 1px solid #eee;
}
</style>