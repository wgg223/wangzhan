<div class="container">
  <div class="page-header">
    <h1><%= article ? '编辑文章' : '新建文章' %></h1>
    <a href="/articles" class="btn">返回文章列表</a>
  </div>
  
  <% if (typeof error !== 'undefined' && error) { %>
    <div class="alert alert-error"><%= error %></div>
  <% } %>
  
  <form action="/articles/save" method="POST" class="article-form">
    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
    <% if (article) { %>
      <input type="hidden" name="id" value="<%= article.id %>">
    <% } %>
    
    <div class="form-row">
      <div class="form-group">
        <label for="title">文章标题 *</label>
        <input type="text" id="title" name="title" value="<%= article ? article.title : '' %>" required placeholder="请输入文章标题">
      </div>
    </div>
    
    <div class="form-row three-col">
      <div class="form-group">
        <label for="category">分类</label>
        <input type="text" id="category" name="category" value="<%= article ? article.category : '' %>" placeholder="例如：技术、生活、新闻">
      </div>
      
      <div class="form-group">
        <label for="location">发表位置</label>
        <select id="location" name="location">
          <option value="home" <%= !article || article.location === 'home' ? 'selected' : '' %>>首页展示</option>
          <option value="category" <%= article && article.location === 'category' ? 'selected' : '' %>>分类页展示</option>
          <option value="both" <%= article && article.location === 'both' ? 'selected' : '' %>>首页+分类页</option>
        </select>
      </div>
      
      <div class="form-group">
        <label for="status">状态</label>
        <select id="status" name="status">
          <option value="published" <%= !article || article.status === 'published' ? 'selected' : '' %>>发布</option>
          <option value="draft" <%= article && article.status === 'draft' ? 'selected' : '' %>>保存草稿</option>
        </select>
      </div>
    </div>
    
    <div class="form-group">
      <label for="cover_image">封面图片</label>
      <div class="input-with-button">
        <input type="text" id="cover_image" name="cover_image" value="<%= article ? article.cover_image : '' %>" placeholder="输入图片URL或从媒体库选择">
        <button type="button" class="btn btn-small" onclick="openMediaSelector('cover_image')">从媒体库选择</button>
      </div>
    </div>
    
    <div class="form-group">
      <label for="content">文章内容</label>
      <div id="editor-container"></div>
      <input type="hidden" id="content" name="content" value="<%= article ? article.content : '' %>">
    </div>
    
    <div class="form-group">
      <label>文章附件</label>
      <div class="attachments-section">
        <div class="attachment-upload-zone" id="attachment-upload-zone">
          <i class="fas fa-cloud-upload-alt" style="font-size:24px;color:#007bff;margin-bottom:6px;display:block;"></i>
          <p style="font-weight:600;margin:0 0 4px 0;">拖拽文件到此处上传</p>
          <p style="color:#999;font-size:12px;margin:0;">或 <button type="button" class="upload-browse-btn" onclick="document.getElementById('attachment-file-input').click()">点击选择文件</button></p>
          <p style="color:#999;font-size:11px;margin:4px 0 0 0;">支持 zip/rar/7z/exe/apk/pdf/doc/xls 等格式，最大 200MB，支持断点续传</p>
        </div>
        <div class="attachment-upload-progress" id="attachment-upload-progress" style="display:none;">
          <div class="attachment-progress-info">
            <span id="att-upload-filename" class="att-filename"></span>
            <span id="att-upload-percent" class="att-percent">0%</span>
          </div>
          <div class="progress-bar-track"><div class="progress-bar-fill" id="att-upload-bar"></div></div>
          <span id="att-upload-status" style="font-size:12px;color:#666;"></span>
        </div>
        <input type="file" id="attachment-file-input" style="display:none;" onchange="handleAttachmentFileSelect(event)">
        <div id="attachments-list" class="attachments-list-editor"></div>
      </div>
    </div>
    
    <div class="form-actions">
      <button type="submit" class="btn btn-primary btn-large">保存文章</button>
      <a href="/articles" class="btn">取消</a>
    </div>
  </form>
</div>

<!-- 媒体选择器模态框 -->
<div id="media-modal" class="media-modal">
  <div class="media-modal-content">
    <div class="media-modal-header">
      <h2>选择媒体文件</h2>
      <button type="button" class="close-modal" onclick="closeMediaSelector()">&times;</button>
    </div>
    <div class="media-modal-body">
      <div class="media-upload-zone" id="media-upload-zone">
        <div class="media-upload-inner">
          <i class="fas fa-cloud-upload-alt" style="font-size:28px;color:#007bff;margin-bottom:8px;display:block;"></i>
          <p style="font-weight:600;margin:0 0 4px 0;">拖拽图片到此处上传</p>
          <p style="color:#999;font-size:12px;margin:0;">或 <button type="button" class="upload-browse-btn" onclick="document.getElementById('media-file-input').click()">点击浏览文件</button></p>
          <p style="color:#999;font-size:11px;margin:4px 0 0 0;">支持 JPG、PNG、GIF，最大 10MB</p>
        </div>
        <div class="media-upload-progress" id="media-upload-progress" style="display:none;">
          <div class="progress-bar-track"><div class="progress-bar-fill" id="upload-bar"></div></div>
          <span id="upload-status-text" style="font-size:12px;color:#666;"></span>
        </div>
      </div>
      <input type="file" id="media-file-input" accept="image/jpeg,image/png,image/gif" style="display:none;" onchange="handleFileSelect(event)">
      <div class="media-list" id="media-list">
        <p style="text-align:center;padding:20px;color:#999;">加载中...</p>
      </div>
    </div>
  </div>
</div>

<!-- 引入 Quill 编辑器 - 使用本地版本，备用 CDN -->
<link href="/vendor/quill/quill.snow.css" rel="stylesheet">
<script src="/vendor/quill/quill.js"></script>
<!-- 备用 CDN (如果本地加载失败) -->
<script>
  if (typeof Quill === 'undefined') {
    var cssLink = document.createElement('link');
    cssLink.rel = 'stylesheet';
    cssLink.href = 'https://cdnjs.cloudflare.com/ajax/libs/quill/2.0.0/quill.snow.css';
    document.head.appendChild(cssLink);
    
    var scriptTag = document.createElement('script');
    scriptTag.src = 'https://cdnjs.cloudflare.com/ajax/libs/quill/2.0.0/quill.min.js';
    document.head.appendChild(scriptTag);
  }
</script>

<script>
var quill = null;

// 安全初始化 Quill 编辑器
try {
  if (typeof Quill !== 'undefined') {
    quill = new Quill('#editor-container', {
      theme: 'snow',
      modules: {
        toolbar: [
          [{ 'header': [1, 2, 3, 4, 5, 6, false] }],
          [{ 'font': [] }],
          [{ 'size': ['small', false, 'large', 'huge'] }],
          ['bold', 'italic', 'underline', 'strike'],
          [{ 'color': [] }, { 'background': [] }],
          [{ 'script': 'sub'}, { 'script': 'super' }],
          [{ 'list': 'ordered'}, { 'list': 'bullet' }],
          [{ 'indent': '-1'}, { 'indent': '+1' }],
          [{ 'direction': 'rtl' }],
          [{ 'align': [] }],
          ['link', 'image', 'video'],
          ['blockquote', 'code-block'],
          ['clean']
        ]
      },
      placeholder: '请输入文章内容...'
    });

    // 自定义图片处理器 - 使用媒体库
    var toolbar = quill.getModule('toolbar');
    toolbar.addHandler('image', function() {
      openMediaSelectorForEditor();
    });

    // 设置初始内容
    var contentElement = document.getElementById('content');
    if (contentElement.value) {
      quill.root.innerHTML = contentElement.value;
    }

    // 表单提交前更新隐藏字段
    document.querySelector('.article-form').addEventListener('submit', function(e) {
      document.getElementById('content').value = quill.root.innerHTML;
    });
  } else {
    document.getElementById('editor-container').innerHTML = '<textarea id="content-fallback" name="content" style="width:100%;min-height:400px;padding:10px;border:1px solid #ddd;border-radius:5px;font-size:14px;font-family:inherit;" placeholder="请输入文章内容...">' + (document.getElementById('content').value || '') + '</textarea>';
  }
} catch (e) {
  console.error('Quill编辑器初始化失败:', e);
  document.getElementById('editor-container').innerHTML = '<textarea id="content-fallback" name="content" style="width:100%;min-height:400px;padding:10px;border:1px solid #ddd;border-radius:5px;font-size:14px;font-family:inherit;" placeholder="请输入文章内容...">' + (document.getElementById('content').value || '') + '</textarea>';
}

// ============ 媒体选择器功能 ============

// 打开媒体选择器（用于封面或编辑器）
var pendingEditorTarget = null;

function openMediaSelector(targetInputId) {
  pendingEditorTarget = targetInputId;
  document.getElementById('media-modal').style.display = 'block';
  loadMediaFiles(targetInputId);
}

function openMediaSelectorForEditor() {
  pendingEditorTarget = 'editor';
  document.getElementById('media-modal').style.display = 'block';
  loadMediaFiles(null);
}

// 关闭媒体选择器
function closeMediaSelector() {
  document.getElementById('media-modal').style.display = 'none';
  pendingEditorTarget = null;
  resetUploadZone();
}

function getCsrfToken() {
  var meta = document.querySelector('meta[name="csrf-token"]');
  return meta ? meta.getAttribute('content') : '';
}

function resetUploadZone() {
  var zone = document.getElementById('media-upload-zone');
  var inner = zone.querySelector('.media-upload-inner');
  var progress = document.getElementById('media-upload-progress');
  var fileInput = document.getElementById('media-file-input');
  if (inner) inner.style.display = '';
  if (progress) progress.style.display = 'none';
  if (fileInput) fileInput.value = '';
  zone.classList.remove('drag-over');
}

function handleFileSelect(event) {
  var file = event.target.files[0];
  if (file) uploadMediaFile(file);
}

var uploadZone = document.getElementById('media-upload-zone');
if (uploadZone) {
  uploadZone.addEventListener('dragover', function(e) {
    e.preventDefault();
    e.stopPropagation();
    this.classList.add('drag-over');
  });
  uploadZone.addEventListener('dragleave', function(e) {
    e.preventDefault();
    e.stopPropagation();
    this.classList.remove('drag-over');
  });
  uploadZone.addEventListener('drop', function(e) {
    e.preventDefault();
    e.stopPropagation();
    this.classList.remove('drag-over');
    var file = e.dataTransfer.files[0];
    if (file && file.type.match(/^image\/(jpeg|png|gif)$/)) {
      uploadMediaFile(file);
    } else {
      alert('请拖拽 JPG、PNG 或 GIF 格式的图片文件');
    }
  });
}

function uploadMediaFile(file) {
  if (file.size > 10 * 1024 * 1024) {
    alert('文件超过 10MB 限制，请压缩后上传');
    return;
  }

  var inner = uploadZone.querySelector('.media-upload-inner');
  var progress = document.getElementById('media-upload-progress');
  var bar = document.getElementById('upload-bar');
  var statusText = document.getElementById('upload-status-text');

  if (inner) inner.style.display = 'none';
  if (progress) progress.style.display = '';
  if (bar) bar.style.width = '0%';
  if (statusText) statusText.textContent = '正在上传: ' + file.name;

  var formData = new FormData();
  formData.append('file', file);
  formData.append('_csrf', getCsrfToken());

  var xhr = new XMLHttpRequest();
  xhr.open('POST', '/admin/media/upload');
  xhr.setRequestHeader('X-Requested-With', 'XMLHttpRequest');

  xhr.upload.addEventListener('progress', function(e) {
    if (e.lengthComputable && bar) {
      var pct = Math.round(e.loaded / e.total * 100);
      bar.style.width = pct + '%';
    }
  });

  xhr.addEventListener('load', function() {
    try {
      var result = JSON.parse(xhr.responseText);
    } catch (err) {
      if (statusText) statusText.textContent = '服务器返回异常，请重试';
      return;
    }
    if (result.success) {
      if (statusText) statusText.textContent = '上传成功！';
      setTimeout(function() {
        resetUploadZone();
        loadMediaFiles(null);
      }, 600);
      if (pendingEditorTarget === 'editor') {
        if (quill) {
          var range = quill.getSelection(true);
          quill.insertEmbed(range.index, 'image', result.file.file_path);
        }
        setTimeout(function() { closeMediaSelector(); }, 300);
      } else if (pendingEditorTarget) {
        var input = document.getElementById(pendingEditorTarget);
        if (input) input.value = result.file.file_path;
        setTimeout(function() { closeMediaSelector(); }, 300);
      }
    } else {
      if (statusText) statusText.textContent = '上传失败: ' + (result.message || '未知错误');
    }
  });

  xhr.addEventListener('error', function() {
    if (statusText) statusText.textContent = '网络错误，请重试';
  });

  xhr.send(formData);
}

// 加载媒体文件
function loadMediaFiles(targetInputId) {
  var mediaList = document.getElementById('media-list');
  mediaList.innerHTML = '<p style="text-align:center;padding:20px;color:#999;">加载中...</p>';
  
  fetch('/admin/media/list')
    .then(response => response.json())
    .then(function(media) {
      var html = '';
      if (media.length > 0) {
        media.forEach(function(item) {
          if (item.file_type && item.file_type.startsWith('image/')) {
            html += '<div class="media-item" onclick="selectMedia(\'' + item.file_path + '\')">';
            html += '  <img src="' + item.file_path + '" alt="' + (item.original_name || '') + '">';
            html += '  <p>' + (item.original_name || item.filename) + '</p>';
            html += '</div>';
          }
        });
      }
      mediaList.innerHTML = html || '<p style="text-align:center;padding:20px;color:#999;">没有图片文件</p>';
    })
    .catch(function(err) {
      mediaList.innerHTML = '<p style="text-align:center;padding:20px;color:#999;">加载失败，请重试</p>';
    });
}

// 选择媒体文件
function selectMedia(url) {
  if (pendingEditorTarget === 'editor') {
    if (quill) {
      var range = quill.getSelection(true);
      quill.insertEmbed(range.index, 'image', url);
    }
    closeMediaSelector();
    return;
  }
  
  if (pendingEditorTarget) {
    var input = document.getElementById(pendingEditorTarget);
    if (input) {
      input.value = url;
    }
  }
  closeMediaSelector();
}

// 点击模态框外部关闭
window.onclick = function(event) {
  var modal = document.getElementById('media-modal');
  if (event.target == modal) {
    closeMediaSelector();
  }
}

// ============ 附件上传（断点续传） ============
var uploadedAttachments = [];
var currentUploadAbort = false;

function getAttachmentFileIcon(filename) {
  var ext = filename.split('.').pop().toLowerCase();
  if (['zip','rar','7z','tar','gz','bz2','xz'].includes(ext)) return { icon: 'fa-file-archive', color: '#f59e0b' };
  if (['exe','msi','dmg','apk','ipa'].includes(ext)) return { icon: 'fa-cog', color: '#6366f1' };
  if (['pdf'].includes(ext)) return { icon: 'fa-file-pdf', color: '#ef4444' };
  if (['doc','docx'].includes(ext)) return { icon: 'fa-file-word', color: '#3b82f6' };
  if (['xls','xlsx'].includes(ext)) return { icon: 'fa-file-excel', color: '#10b981' };
  if (['mp3','wav','flac','aac','ogg'].includes(ext)) return { icon: 'fa-file-audio', color: '#8b5cf6' };
  if (['mp4','avi','mkv','mov','wmv','flv'].includes(ext)) return { icon: 'fa-file-video', color: '#ec4899' };
  if (['iso','img'].includes(ext)) return { icon: 'fa-compact-disc', color: '#64748b' };
  return { icon: 'fa-file', color: '#94a3b8' };
}

function formatAttSize(bytes) {
  if (!bytes) return '';
  if (bytes < 1024) return bytes + ' B';
  if (bytes < 1024 * 1024) return (bytes / 1024).toFixed(1) + ' KB';
  if (bytes < 1024 * 1024 * 1024) return (bytes / (1024 * 1024)).toFixed(1) + ' MB';
  return (bytes / (1024 * 1024 * 1024)).toFixed(2) + ' GB';
}

function renderAttachmentsList() {
  var list = document.getElementById('attachments-list');
  if (!list) return;
  if (uploadedAttachments.length === 0) {
    list.innerHTML = '';
    return;
  }
  var html = '';
  uploadedAttachments.forEach(function(att, idx) {
    var fi = getAttachmentFileIcon(att.original_name);
    html += '<div class="att-item">';
    html += '  <div class="att-item-icon"><i class="fas ' + fi.icon + '" style="color:' + fi.color + ';"></i></div>';
    html += '  <div class="att-item-info">';
    html += '    <span class="att-item-name">' + att.original_name + '</span>';
    html += '    <span class="att-item-size">' + formatAttSize(att.file_size) + '</span>';
    html += '  </div>';
    html += '  <button type="button" class="att-item-remove" onclick="removeAttachment(' + idx + ')" title="移除"><i class="fas fa-times"></i></button>';
    html += '</div>';
  });
  list.innerHTML = html;
}

function removeAttachment(idx) {
  var att = uploadedAttachments[idx];
  if (att && att.id) {
    fetch('/admin/attachments/delete/' + att.id, {
      method: 'POST',
      headers: { 'X-Requested-With': 'XMLHttpRequest', 'X-CSRF-Token': getCsrfToken() }
    }).catch(function() {});
  }
  uploadedAttachments.splice(idx, 1);
  renderAttachmentsList();
}

function handleAttachmentFileSelect(event) {
  var file = event.target.files[0];
  if (file) uploadAttachmentChunked(file);
  event.target.value = '';
}

var attUploadZone = document.getElementById('attachment-upload-zone');
if (attUploadZone) {
  attUploadZone.addEventListener('dragover', function(e) {
    e.preventDefault();
    e.stopPropagation();
    this.classList.add('drag-over');
  });
  attUploadZone.addEventListener('dragleave', function(e) {
    e.preventDefault();
    e.stopPropagation();
    this.classList.remove('drag-over');
  });
  attUploadZone.addEventListener('drop', function(e) {
    e.preventDefault();
    e.stopPropagation();
    this.classList.remove('drag-over');
    if (e.dataTransfer.files.length > 0) {
      uploadAttachmentChunked(e.dataTransfer.files[0]);
    }
  });
  attUploadZone.addEventListener('click', function(e) {
    if (e.target.tagName !== 'BUTTON') {
      document.getElementById('attachment-file-input').click();
    }
  });
}

function uploadAttachmentChunked(file) {
  if (file.size > 200 * 1024 * 1024) {
    alert('文件超过 200MB 限制');
    return;
  }

  var CHUNK_SIZE = 2 * 1024 * 1024;
  var totalChunks = Math.ceil(file.size / CHUNK_SIZE);

  var zone = document.getElementById('attachment-upload-zone');
  var progress = document.getElementById('attachment-upload-progress');
  var bar = document.getElementById('att-upload-bar');
  var filenameEl = document.getElementById('att-upload-filename');
  var percentEl = document.getElementById('att-upload-percent');
  var statusEl = document.getElementById('att-upload-status');

  if (zone) zone.style.display = 'none';
  if (progress) progress.style.display = '';
  if (bar) bar.style.width = '0%';
  if (filenameEl) filenameEl.textContent = file.name;
  if (percentEl) percentEl.textContent = '准备中...';
  if (statusEl) statusEl.textContent = '正在初始化上传...';

  currentUploadAbort = false;

  fetch('/admin/attachments/upload/init', {
    method: 'POST',
    headers: {
      'Content-Type': 'application/json',
      'X-Requested-With': 'XMLHttpRequest',
      'X-CSRF-Token': getCsrfToken()
    },
    body: JSON.stringify({
      fileName: file.name,
      fileSize: file.size,
      totalChunks: totalChunks
    })
  })
  .then(function(res) { return res.json(); })
  .then(function(data) {
    if (data.error) {
      alert(data.error);
      resetAttachmentUploadZone();
      return;
    }
    uploadChunksSequentially(file, data.uploadId, 0, totalChunks, CHUNK_SIZE);
  })
  .catch(function(err) {
    alert('上传初始化失败，请重试');
    resetAttachmentUploadZone();
  });
}

function uploadChunksSequentially(file, uploadId, index, total, chunkSize) {
  if (currentUploadAbort) {
    fetch('/admin/attachments/upload/cancel', {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
        'X-Requested-With': 'XMLHttpRequest',
        'X-CSRF-Token': getCsrfToken()
      },
      body: JSON.stringify({ uploadId: uploadId })
    }).catch(function() {});
    resetAttachmentUploadZone();
    return;
  }

  if (index >= total) {
    mergeUpload(file, uploadId);
    return;
  }

  var start = index * chunkSize;
  var end = Math.min(start + chunkSize, file.size);
  var chunk = file.slice(start, end);

  var bar = document.getElementById('att-upload-bar');
  var percentEl = document.getElementById('att-upload-percent');
  var statusEl = document.getElementById('att-upload-status');

  if (bar) bar.style.width = Math.round(index / total * 100) + '%';
  if (percentEl) percentEl.textContent = Math.round(index / total * 100) + '%';
  if (statusEl) statusEl.textContent = '上传分片 ' + (index + 1) + ' / ' + total;

  var xhr = new XMLHttpRequest();
  xhr.open('POST', '/admin/attachments/upload/chunk');
  xhr.setRequestHeader('X-Requested-With', 'XMLHttpRequest');
  xhr.setRequestHeader('X-CSRF-Token', getCsrfToken());
  xhr.setRequestHeader('X-Upload-Id', uploadId);
  xhr.setRequestHeader('X-Chunk-Index', index.toString());
  xhr.setRequestHeader('Content-Type', 'application/octet-stream');

  xhr.addEventListener('load', function() {
    if (xhr.status === 200) {
      uploadChunksSequentially(file, uploadId, index + 1, total, chunkSize);
    } else {
      try {
        var result = JSON.parse(xhr.responseText);
        if (statusEl) statusEl.textContent = '上传失败: ' + (result.error || '未知错误');
      } catch (e) {
        if (statusEl) statusEl.textContent = '上传失败，请重试';
      }
      setTimeout(resetAttachmentUploadZone, 3000);
    }
  });

  xhr.addEventListener('error', function() {
    if (statusEl) statusEl.textContent = '网络错误，3秒后重试...';
    setTimeout(function() {
      uploadChunksSequentially(file, uploadId, index, total, chunkSize);
    }, 3000);
  });

  xhr.send(chunk);
}

function mergeUpload(file, uploadId) {
  var bar = document.getElementById('att-upload-bar');
  var percentEl = document.getElementById('att-upload-percent');
  var statusEl = document.getElementById('att-upload-status');

  if (bar) bar.style.width = '100%';
  if (percentEl) percentEl.textContent = '100%';
  if (statusEl) statusEl.textContent = '正在合并文件...';

  fetch('/admin/attachments/upload/merge', {
    method: 'POST',
    headers: {
      'Content-Type': 'application/json',
      'X-Requested-With': 'XMLHttpRequest',
      'X-CSRF-Token': getCsrfToken()
    },
    body: JSON.stringify({ uploadId: uploadId })
  })
  .then(function(res) { return res.json(); })
  .then(function(data) {
    if (data.error) {
      if (statusEl) statusEl.textContent = '合并失败: ' + data.error;
      setTimeout(resetAttachmentUploadZone, 3000);
      return;
    }

    if (statusEl) statusEl.textContent = '上传完成！';

    var articleId = document.querySelector('input[name="id"]');
    var articleIdVal = articleId ? articleId.value : null;

    fetch('/admin/attachments/save', {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
        'X-Requested-With': 'XMLHttpRequest',
        'X-CSRF-Token': getCsrfToken()
      },
      body: JSON.stringify({
        article_id: articleIdVal || null,
        original_name: data.file.original_name,
        file_name: data.file.file_name,
        file_path: data.file.file_path,
        file_size: data.file.file_size
      })
    })
    .then(function(res) { return res.json(); })
    .then(function(saveData) {
      if (saveData.success && saveData.attachment) {
        uploadedAttachments.push(saveData.attachment);
        renderAttachmentsList();
      }
      setTimeout(resetAttachmentUploadZone, 500);
    })
    .catch(function() {
      uploadedAttachments.push({
        original_name: data.file.original_name,
        file_name: data.file.file_name,
        file_path: data.file.file_path,
        file_size: data.file.file_size
      });
      renderAttachmentsList();
      setTimeout(resetAttachmentUploadZone, 500);
    });
  })
  .catch(function(err) {
    if (statusEl) statusEl.textContent = '合并请求失败，请重试';
    setTimeout(resetAttachmentUploadZone, 3000);
  });
}

function resetAttachmentUploadZone() {
  var zone = document.getElementById('attachment-upload-zone');
  var progress = document.getElementById('attachment-upload-progress');
  if (zone) zone.style.display = '';
  if (progress) progress.style.display = 'none';
  currentUploadAbort = false;
}

// 加载已有附件
function loadExistingAttachments(articleId) {
  if (!articleId) return;
  fetch('/admin/attachments/list/' + articleId, {
    headers: { 'X-Requested-With': 'XMLHttpRequest' }
  })
  .then(function(res) { return res.json(); })
  .then(function(data) {
    if (Array.isArray(data)) {
      uploadedAttachments = data;
      renderAttachmentsList();
    }
  })
  .catch(function() {});
}

// 表单提交时处理附件
(function() {
  var form = document.querySelector('.article-form');
  if (!form) return;

  form.addEventListener('submit', function(e) {
    e.preventDefault();

    // 更新content字段
    if (quill) {
      document.getElementById('content').value = quill.root.innerHTML;
    }

    var formData = new FormData(form);

    fetch('/articles/save', {
      method: 'POST',
      headers: { 'X-Requested-With': 'XMLHttpRequest', 'X-CSRF-Token': getCsrfToken() },
      body: new URLSearchParams(formData)
    })
    .then(function(res) { return res.json(); })
    .then(function(data) {
      if (data.error) {
        alert('保存失败: ' + data.error);
        return;
      }
      var savedArticleId = data.articleId;

      // 关联附件到文章
      if (uploadedAttachments.length > 0 && savedArticleId) {
        var orphanIds = uploadedAttachments.filter(function(a) { return !a.article_id || String(a.article_id) === 'null'; }).map(function(a) { return a.id; });
        if (orphanIds.length > 0) {
          fetch('/admin/attachments/update-article', {
            method: 'POST',
            headers: {
              'Content-Type': 'application/json',
              'X-Requested-With': 'XMLHttpRequest',
              'X-CSRF-Token': getCsrfToken()
            },
            body: JSON.stringify({
              attachment_ids: orphanIds,
              article_id: savedArticleId
            })
          }).then(function() {
            window.location.href = '/articles';
          }).catch(function() {
            window.location.href = '/articles';
          });
          return;
        }
      }

      window.location.href = '/articles';
    })
    .catch(function(err) {
      alert('保存失败，请重试');
    });
  });

  // 加载已有附件
  var articleIdInput = form.querySelector('input[name="id"]');
  if (articleIdInput && articleIdInput.value) {
    loadExistingAttachments(articleIdInput.value);
  }
})();
</script>

