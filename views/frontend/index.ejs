<div class="container">
  <div class="hero-section">
    <h1>欢迎来到<%= settings.site_name || '我的网站' %></h1>
    <p class="site-description"><%= settings.site_description || '这是一个功能完整的网站管理系统' %></p>
  </div>
  
  <section class="articles">
    <h2>最新文章</h2>
    <% if (articles.length > 0) { %>
      <div class="article-list">
        <% articles.forEach(function(article) { %>
          <div class="article-item">
            <% if (article.cover_image) { %>
              <div class="article-thumb">
                <img src="<%= article.cover_image %>" alt="<%= article.title %>">
              </div>
            <% } %>
            <div class="article-info">
              <h3><a href="/articles/<%= article.id %>"><%= article.title %></a></h3>
              <p class="meta">
                发布时间：<%= new Date(article.created_at).toLocaleDateString('zh-CN') %>
                <% if (article.author_name) { %>
                  | 作者：<%= article.author_name %>
                <% } %>
                <% if (article.category) { %>
                  | 分类：<%= article.category %>
                <% } %>
              </p>
            </div>
          </div>
        <% }); %>
      </div>
      <div class="section-footer">
        <a href="/articles" class="btn">查看全部文章</a>
      </div>
    <% } else { %>
      <p class="empty-message">暂无文章</p>
    <% } %>
  </section>

  <section class="site-pages">
    <h2>网站页面</h2>
    <% if (pages.length > 0) { %>
      <ul class="page-list">
        <% pages.forEach(function(page) { %>
          <li><a href="/page/<%= page.slug %>"><%= page.title %></a></li>
        <% }) %>
      </ul>
    <% } else { %>
      <p class="empty-message">暂无页面</p>
    <% } %>
  </section>
</div>

<style>
.hero-section {
  text-align: center;
  padding: 40px 20px;
  margin-bottom: 30px;
}
.hero-section h1 {
  border: none;
  font-size: 32px;
  margin-bottom: 15px;
}
.site-description {
  color: #666;
  font-size: 18px;
}
.section-footer {
  margin-top: 20px;
  text-align: center;
}
.article-item {
  display: flex;
  gap: 20px;
  padding: 20px;
  border-bottom: 1px solid #eee;
  align-items: flex-start;
}
.article-thumb {
  width: 120px;
  height: 80px;
  flex-shrink: 0;
  border-radius: 5px;
  overflow: hidden;
}
.article-thumb img {
  width: 100%;
  height: 100%;
  object-fit: cover;
}
.article-info {
  flex: 1;
}
.article-info h3 {
  margin-bottom: 10px;
}
.page-list {
  list-style: none;
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
  gap: 15px;
  margin: 20px 0;
}
.page-list li {
  background: #f8f9fa;
  border-radius: 8px;
  padding: 15px;
  text-align: center;
  transition: all 0.3s;
}
.page-list li:hover {
  background: #e9ecef;
  transform: translateY(-2px);
}
.page-list li a {
  display: block;
  color: #333;
  font-weight: 500;
}
.data-btn {
  display: inline-block;
  margin-top: 15px;
  padding: 10px 30px;
  background-color: #007bff;
  color: #fff;
  text-decoration: none;
  border-radius: 25px;
  font-size: 16px;
  font-weight: 500;
  transition: background-color 0.3s, transform 0.3s;
}
.data-btn:hover {
  background-color: #0056b3;
  transform: translateY(-2px);
}
}
</style>