<div class="container">
  <h1>📚 小说书架</h1>

  <% if (novels && novels.length > 0) { %>
    <div class="novel-grid" style="display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:24px;margin-top:24px;">
      <% novels.forEach(function(novel) { %>
        <div class="novel-card" style="background:#fff;border-radius:var(--radius-md);overflow:hidden;box-shadow:var(--shadow-md);border:1px solid var(--gray-100);transition:var(--transition-base);">
          <div style="height:220px;overflow:hidden;background:var(--gray-50);display:flex;align-items:center;justify-content:center;">
            <% if (novel.cover_image) { %>
              <img src="<%= novel.cover_image %>" alt="<%= novel.title %>" style="width:100%;height:100%;object-fit:cover;transition:transform 0.4s ease;">
            <% } else { %>
              <div style="font-size:64px;color:var(--gray-300);">📖</div>
            <% } %>
          </div>
          <div style="padding:20px;">
            <h3 style="font-size:18px;font-weight:700;margin-bottom:8px;color:var(--gray-800);"><%= novel.title %></h3>
            <div style="font-size:13px;color:var(--gray-400);margin-bottom:10px;">
              <span>✍️ <%= novel.author || '未知作者' %></span>
              <span style="margin-left:12px;">📄 <%= novel.chapter_count || 0 %> 章</span>
            </div>
            <% if (novel.description) { %>
              <p style="font-size:14px;color:var(--gray-500);line-height:1.7;display:-webkit-box;-webkit-line-clamp:3;-webkit-box-orient:vertical;overflow:hidden;margin-bottom:16px;"><%= novel.description %></p>
            <% } %>
            <a href="/novels/<%= novel.id %>" class="btn btn-primary" style="width:100%;">开始阅读</a>
          </div>
        </div>
      <% }); %>
    </div>
  <% } else { %>
    <div style="text-align:center;padding:80px 20px;color:var(--gray-400);">
      <div style="font-size:80px;margin-bottom:20px;">📚</div>
      <p style="font-size:18px;margin-bottom:8px;">还没有小说内容</p>
      <p style="font-size:14px;">请等待管理员上传</p>
    </div>
  <% } %>
</div>