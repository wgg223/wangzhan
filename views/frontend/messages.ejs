<div class="container" style="max-width: 900px; margin: 0 auto;">
  <div class="page-header" style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 25px; flex-wrap: wrap; gap: 12px;">
    <h1 style="margin: 0;">站内信</h1>
    <div>
      <button type="button" class="btn" onclick="markAllRead()">全部标为已读</button>
    </div>
  </div>

  <% if (messages.length > 0) { %>
    <div class="message-list">
      <% messages.forEach(function(msg) { %>
        <div class="message-item <%= msg.is_read ? 'message-read' : 'message-unread' %>" id="msg-<%= msg.id %>" style="background: #fff; border: 1px solid #ddd; border-left: 4px solid <%= msg.is_read ? '#ddd' : '#007bff' %>; border-radius: 8px; padding: 15px 20px; margin-bottom: 10px; cursor: pointer; transition: all 0.2s;">
          <div style="display: flex; justify-content: space-between; align-items: center;" onclick="toggleMessage(<%= msg.id %>)">
            <div style="flex: 1; min-width: 0;">
              <div style="display: flex; align-items: center; gap: 8px;">
                <% if (!msg.is_read) { %>
                  <span style="display: inline-block; width: 8px; height: 8px; background: #007bff; border-radius: 50%; flex-shrink: 0;"></span>
                <% } %>
                <strong style="font-size: 15px; word-break: break-word;"><%= msg.title %></strong>
              </div>
              <div style="font-size: 13px; color: #999; margin-top: 4px;">
                来自：<%= msg.from_username || '系统' %> · <%= new Date(msg.created_at + 'Z').toLocaleString('zh-CN') %>
              </div>
            </div>
            <div style="display: flex; gap: 8px; align-items: center; flex-shrink: 0;" onclick="event.stopPropagation();">
              <% if (!msg.is_read) { %>
                <span class="badge badge-new" style="background: #007bff; color: #fff; padding: 2px 8px; border-radius: 10px; font-size: 12px;">新</span>
              <% } %>
              <form action="/messages/delete/<%= msg.id %>" method="POST" style="display: inline;" onsubmit="return confirm('确定要删除这条站内信吗？')">
                <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                <button type="submit" class="btn" style="padding: 4px 10px; font-size: 12px; background: #dc3545; color: #fff;">删除</button>
              </form>
            </div>
          </div>
          <div class="message-content" id="msg-content-<%= msg.id %>" style="display: none; margin-top: 12px; padding-top: 12px; border-top: 1px solid #eee; line-height: 1.8; color: #555;">
            <%- msg.content.replace(/\n/g, '<br>') %>
          </div>
        </div>
      <% }); %>
    </div>
  <% } else { %>
    <div class="empty-state" style="text-align: center; padding: 60px 20px; color: #999;">
      <p style="font-size: 48px; margin: 0;">📭</p>
      <p style="font-size: 16px; margin-top: 10px;">暂无站内信</p>
    </div>
  <% } %>
</div>

<style>
@media (max-width: 768px) {
  .container {
    padding: 0 12px !important;
  }
  .page-header {
    margin-bottom: 16px !important;
  }
  .page-header h1 {
    font-size: 20px !important;
  }
  .message-item {
    padding: 12px 14px !important;
  }
  .message-item strong {
    font-size: 14px !important;
  }
}

@media (max-width: 480px) {
  .container {
    padding: 0 8px !important;
  }
  .page-header {
    flex-direction: column !important;
    align-items: flex-start !important;
  }
  .message-item {
    padding: 10px 12px !important;
  }
}
</style>

<script>
function toggleMessage(id) {
  var content = document.getElementById('msg-content-' + id);
  var msgItem = document.getElementById('msg-' + id);

  if (content.style.display === 'none' || content.style.display === '') {
    content.style.display = 'block';
    if (msgItem.classList.contains('message-unread')) {
      fetch('/messages/mark-read/' + id, { method: 'POST', headers: { 'X-CSRF-Token': getCsrfToken() } })
        .then(function() {
          msgItem.classList.remove('message-unread');
          msgItem.classList.add('message-read');
          msgItem.style.borderLeftColor = '#ddd';
          var badge = msgItem.querySelector('.badge-new');
          if (badge) badge.remove();
          var dot = msgItem.querySelector('span[style*="background: #007bff"]');
          if (dot) dot.style.display = 'none';
          refreshUnreadCount();
        });
    }
  } else {
    content.style.display = 'none';
  }
}

function getCsrfToken() {
  var meta = document.querySelector('meta[name="csrf-token"]');
  return meta ? meta.getAttribute('content') : '';
}

function markAllRead() {
  if (!confirm('确定将所有站内信标记为已读？')) return;
  fetch('/messages/mark-all-read', { method: 'POST', headers: { 'X-CSRF-Token': getCsrfToken() } })
    .then(function() { location.reload(); });
}

function refreshUnreadCount() {
  fetch('/messages/unread-count')
    .then(function(r) { return r.json(); })
    .then(function(data) {
      var badge = document.getElementById('msg-unread-badge');
      if (badge) {
        if (data.count > 0) {
          badge.textContent = data.count;
          badge.style.display = '';
        } else {
          badge.style.display = 'none';
        }
      }
    });
}
</script>
