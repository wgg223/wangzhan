                paragraphs: p.p,
                dynasty: p.d,
                source: p.s,
                category: p.c
            }));
        }
        // 如果原始数据是长属性名格式，也复制一份
        if (typeof POEMS_DATA !== 'undefined' && POEMS_DATA.length > 0 && POEMS_DATA[0].title) {
            POEMS_DATA_NORMALIZED = POEMS_DATA;
        }

        // 如果数据不足300首，添加内置诗词数据
        if (POEMS_DATA_NORMALIZED.length < 300) {
            // 将内置数据转换为标准格式
            const BUILTIN_NORMALIZED = BUILTIN_POEMS.map(p => ({
                id: p.id,
                title: p.t,
                author: p.a,
                paragraphs: p.p,
                dynasty: p.d,
                source: p.s,
                category: p.c
            }));
            // 合并数据，确保不重复
            const existingIds = new Set(POEMS_DATA_NORMALIZED.map(p => p.id));
            const newPoems = BUILTIN_NORMALIZED.filter(p => !existingIds.has(p.id));
            POEMS_DATA_NORMALIZED = POEMS_DATA_NORMALIZED.concat(newPoems);
        }

        // ===== 游戏状态 =====
        let gameState = {
            mode: 'fill',
            difficulty: 'easy',
            category: '全部',
            score: 0,
            combo: 0,
            maxCombo: 0,
            currentQuestion: 0,
            totalQuestions: 10,
            timer: null,
            timeLeft: 0,
            startTime: 0,
            usedPoems: new Set(),
            correctPoems: [],
            wrongPoems: []
        };

        let showPinyin = false;
        let homeCurrentPoem = null;
        let filteredPoems = [];

        // ===== 诗词查询状态 =====
        let searchState = {
            keyword: '',
            filter: 'all',
            currentPage: 1,
            pageSize: 15,
            results: []
        };

        // ===== 排行榜状态 =====
        let leaderboardState = {
            mode: 'all',
            difficulty: 'all',
            page: 1,
            limit: 20,
            records: [],
            total: 0
        };

        // ===== 工具函数 =====
        function randomInt(min, max) {
            return Math.floor(Math.random() * (max - min + 1)) + min;
        }

        function shuffleArray(arr) {
            const a = [...arr];
            for (let i = a.length - 1; i > 0; i--) {
                const j = randomInt(0, i);
                [a[i], a[j]] = [a[j], a[i]];
            }
            return a;
        }

        function getPoemPool() {
            if (!POEMS_DATA_NORMALIZED || POEMS_DATA_NORMALIZED.length === 0) return [];
            if (gameState.category === '全部') return POEMS_DATA_NORMALIZED;
            return POEMS_DATA_NORMALIZED.filter(p => p.category === gameState.category);
        }

        function getRandomPoem() {
            const pool = getPoemPool();
            if (pool.length === 0) return null;
            let attempts = 0;
            while (attempts < 100) {
                const idx = randomInt(0, pool.length - 1);
                const poem = pool[idx];
                const key = poem.id || idx;
                if (!gameState.usedPoems.has(key)) {
                    gameState.usedPoems.add(key);
                    return poem;
                }
                attempts++;
            }
            gameState.usedPoems.clear();
            return getRandomPoem();
        }

        function getSuitableLine(paragraphs) {
            const suitable = paragraphs.filter(p => {
                const clean = p.replace(/[，。！？、；：""''《》（）\s]/g, '');
                return clean.length >= 5 && clean.length <= 20;
            });
            return suitable.length > 0 ? suitable[randomInt(0, suitable.length - 1)] : paragraphs[0];
        }

        // ===== 拼音核心函数（使用 pinyin-pro 库） =====

        // 获取某一行的逐字拼音数组
        // 优先使用预计算数据，否则用 pinyin-pro 生成
        function getCharPinyin(poem, lineIdx) {
            if (!poem || !poem.paragraphs || !poem.paragraphs[lineIdx]) return null;
            // 检查是否有预计算的拼音数据（字符串格式，空格分隔）
            if (poem.pinyin && Array.isArray(poem.pinyin) && poem.pinyin[lineIdx]) {
                const pyData = poem.pinyin[lineIdx];
                if (typeof pyData === 'string') {
                    return pyData.trim().split(/\s+/);
                }
                if (Array.isArray(pyData)) return pyData;
            }
            // 使用 pinyin-pro 生成（带声调符号的逐字拼音数组）
            if (typeof pinyinPro !== 'undefined') {
                return pinyinPro.pinyin(poem.paragraphs[lineIdx], {
                    toneType: 'symbol',
                    type: 'array'
                });
            }
            return null;
        }

        // 将一行文本渲染为带 ruby 注音的 HTML（拼音显示在文字上方）
        function textToRubyHtml(text, pinyinArr) {
            if (!text) return '';
            let html = '';
            let pyIdx = 0;
            for (const ch of text) {
                if (/[\u4e00-\u9fff]/.test(ch)) {
                    const py = (pinyinArr && pyIdx < pinyinArr.length) ? pinyinArr[pyIdx] : '';
                    html += '<ruby>' + ch + '<rt>' + py + '</rt></ruby>';
                    pyIdx++;
                } else {
                    html += ch;
                }
            }
            return html;
        }

        // 兼容旧接口：返回每行拼音字符串的数组
        function getPoemPinyin(poem) {
            if (!poem || !poem.paragraphs) return null;
            return poem.paragraphs.map(function(line, idx) {
                const arr = getCharPinyin(poem, idx);
                return arr ? arr.join(' ') : '';
            });
        }

        // 渲染带拼音的诗行（ruby 注音方式）
        function renderLinesWithPinyin(poem, options) {
            if (!poem || !poem.paragraphs) return '';
            options = options || {};
            var color = options.color || '#4a4a4a';
            var opacity = options.opacity || 1;
            var linesHtml = '';
            poem.paragraphs.forEach(function(line, idx) {
                var lineContent;
                if (showPinyin) {
                    var pinyinArr = getCharPinyin(poem, idx);
                    lineContent = textToRubyHtml(line, pinyinArr);
                } else {
                    lineContent = line;
                }
                var style = 'color: ' + color + '; opacity: ' + opacity + ';';
                linesHtml += '<div class="line" style="' + style + '">' + lineContent + '</div>';
            });
            return linesHtml;
        }

        // 渲染带拼音的单行（用于答案显示等）
        function renderLineWithPinyin(poem, lineIdx, options) {
            if (!poem || !poem.paragraphs || lineIdx < 0) return '';
            options = options || {};
            var line = poem.paragraphs[lineIdx];
            if (showPinyin) {
                var pinyinArr = getCharPinyin(poem, lineIdx);
                return textToRubyHtml(line, pinyinArr);
            }
            return line;
        }

        // 高亮搜索关键词
        function highlightText(text, keyword) {
            if (!keyword) return text;
            const regex = new RegExp(`(${keyword.replace(/[.*+?^${}()|[\]\\]/g, '\\$&')})`, 'gi');
            return text.replace(regex, '<mark style="background: rgba(139, 115, 85, 0.2); color: inherit; padding: 0 2px;">$1</mark>');
        }

        // ===== 分类统计 =====
        function getCategoryCounts() {
            const counts = { '全部': POEMS_DATA_NORMALIZED ? POEMS_DATA_NORMALIZED.length : 0 };
            if (!POEMS_DATA_NORMALIZED || POEMS_DATA_NORMALIZED.length === 0) return counts;
            POEMS_DATA_NORMALIZED.forEach(p => {
                const cat = p.category || '其他';
                counts[cat] = (counts[cat] || 0) + 1;
            });
            return counts;
        }

        function initCategoryList() {
            const counts = getCategoryCounts();
            const container = document.getElementById('category-list');
            let html = '';
            const order = ['全部', '唐诗', '宋词', '诗经', '楚辞'];
            for (const cat of order) {
                if (counts[cat] !== undefined) {
                    const active = gameState.category === cat ? ' active' : '';
                    html += `<button class="cat-btn${active}" onclick="setCategory('${cat}', this)">${cat}<span class="cat-count">${counts[cat]}</span></button>`;
                }
            }
            for (const [cat, count] of Object.entries(counts)) {
                if (!order.includes(cat)) {
                    const active = gameState.category === cat ? ' active' : '';
                    html += `<button class="cat-btn${active}" onclick="setCategory('${cat}', this)">${cat}<span class="cat-count">${count}</span></button>`;
                }
            }
            container.innerHTML = html;
        }

        function setCategory(cat, btn) {
            gameState.category = cat;
            gameState.usedPoems.clear();
            document.querySelectorAll('.cat-btn').forEach(b => b.classList.remove('active'));
            btn.classList.add('active');
            showRandomPoem();
        }

        function togglePinyin() {
            showPinyin = !showPinyin;
            const toggle = document.getElementById('pinyin-toggle');
            toggle.classList.toggle('active', showPinyin);
            // 刷新当前显示的诗词
            showRandomPoem();
        }

        // ===== 显示首页 =====
        function showHome() {
            stopTimer();
            document.getElementById('home-screen').style.display = 'block';
            document.getElementById('fill-game').classList.remove('active');
            document.getElementById('feihua-game').classList.remove('active');
            document.getElementById('search-screen').classList.remove('active');
            document.getElementById('leaderboard-screen').classList.remove('active');
            document.getElementById('result-screen').classList.remove('active');

            document.querySelectorAll('.nav-btn').forEach((btn, i) => {
                btn.classList.toggle('active', i === 0);
            });

            showRandomPoem();
        }

        function showRandomPoem() {
            gameState.usedPoems.clear();
            const poem = getRandomPoem();
            homeCurrentPoem = poem;
            if (poem) {
                let linesHtml = '';
                poem.paragraphs.forEach((p, idx) => {
                    if (showPinyin) {
                        const pinyinArr = getCharPinyin(poem, idx);
                        linesHtml += '<p>' + textToRubyHtml(p, pinyinArr) + '</p>';
                    } else {
                        linesHtml += '<p>' + p + '</p>';
                    }
                });
                document.getElementById('random-poem').innerHTML = linesHtml;
                document.getElementById('random-poem-info').textContent = `—— ${poem.author}《${poem.title}》`;

                // 点击诗词区域打开详情弹窗
                const poemDisplay = document.querySelector('.poem-display');
                poemDisplay.style.cursor = 'pointer';
                poemDisplay.onclick = function() {
                    renderPoemModal(homeCurrentPoem);
                };
            }
            gameState.usedPoems.clear();
        }

        function setDifficulty(diff, btn) {
            gameState.difficulty = diff;
            document.querySelectorAll('.diff-btn').forEach(b => b.classList.remove('active'));
            btn.classList.add('active');
        }

        // ===== 计时器 =====
        function startTimer(seconds, elementId, onEnd) {
            stopTimer();
            gameState.timeLeft = seconds;
            updateTimerDisplay(elementId);
            gameState.timer = setInterval(() => {
                gameState.timeLeft--;
                updateTimerDisplay(elementId);
                if (gameState.timeLeft <= 0) {
                    stopTimer();
                    if (onEnd) onEnd();
                }
            }, 1000);
        }

        function stopTimer() {
            if (gameState.timer) {
                clearInterval(gameState.timer);
                gameState.timer = null;
            }
        }

        function updateTimerDisplay(elementId) {
            const el = document.getElementById(elementId);
            if (el) {
                if (typeof gameState.timeLeft === 'number' && gameState.timeLeft >= 0) {
                    el.textContent = gameState.timeLeft;
                }
            }
        }

        // ===== 连击显示 =====
        function showCombo(combo) {
            if (combo >= 3) {
                const el = document.getElementById('combo-display');
                el.textContent = `${combo}连击!`;
                el.classList.remove('show');
                void el.offsetWidth;
                el.classList.add('show');
                setTimeout(() => el.classList.remove('show'), 1200);
            }
        }

        // ===== 诗词填空模式 =====
        let fillCurrentPoem = null;
        let fillBlanks = [];
        let fillBlankIndex = 0;
        let fillCorrectLine = '';
        let fillHintCount = 0;

        function startFillGame() {
            gameState.mode = 'fill';
            gameState.score = 0;
            gameState.combo = 0;
            gameState.maxCombo = 0;
            gameState.currentQuestion = 0;
            gameState.totalQuestions = gameState.difficulty === 'easy' ? 8 :
                                       gameState.difficulty === 'medium' ? 12 : 16;
            gameState.correctPoems = [];
            gameState.wrongPoems = [];
            gameState.usedPoems.clear();
            gameState.startTime = Date.now();

            updateFillUI();
            nextFillQuestion();
        }

        function updateFillUI() {
            document.getElementById('fill-score').textContent = gameState.score;
            document.getElementById('fill-progress').textContent =
                `${gameState.currentQuestion + 1}/${gameState.totalQuestions}`;
            document.getElementById('fill-combo').textContent = gameState.combo;
        }

        function nextFillQuestion() {
            if (gameState.currentQuestion >= gameState.totalQuestions) {
                endGame();
                return;
            }

            fillHintCount = 0;
            fillCurrentPoem = getRandomPoem();
            if (!fillCurrentPoem) {
                endGame();
                return;
            }

            const allLines = fillCurrentPoem.paragraphs.filter(p =>
                p.replace(/[，。！？、；：""''《》（）\s]/g, '').length >= 5
            );

            if (allLines.length === 0) {
                gameState.currentQuestion++;
                nextFillQuestion();
                return;
            }

            const blankCount = gameState.difficulty === 'easy' ? 1 :
                               gameState.difficulty === 'medium' ? Math.min(2, allLines.length) :
                               Math.min(3, allLines.length);

            const lineIndices = shuffleArray(Array.from({length: allLines.length}, (_, i) => i)).slice(0, blankCount);
            fillBlanks = lineIndices.sort((a, b) => a - b);
            fillBlankIndex = 0;
            fillCorrectLine = allLines[fillBlanks[0]];

            renderFillPoem(allLines);

            document.getElementById('fill-input').value = '';
            document.getElementById('fill-reveal').classList.remove('show');
            document.getElementById('fill-hint').textContent = '请填写空缺的诗句';
            document.getElementById('fill-submit').disabled = false;
            document.getElementById('fill-input').focus();

            const timeLimit = gameState.difficulty === 'easy' ? 60 :
                              gameState.difficulty === 'medium' ? 45 : 30;
            startTimer(timeLimit, 'fill-timer', () => {
                showFillAnswer(false);
                setTimeout(nextFillQuestion, 2000);
            });
        }

        function renderFillPoem(allLines) {
            let html = '';
            let blankIdx = 0;

            // 找到原始段落中的索引映射
            const origParagraphs = fillCurrentPoem.paragraphs;

            for (let i = 0; i < allLines.length; i++) {
                const line = allLines[i];
                // 在原始段落中找到这行的索引
                const origIdx = origParagraphs.indexOf(line);

                if (fillBlanks.includes(i)) {
                    let charIdx = 0;
                    let displayed = '';
                    for (const ch of line) {
                        if (/[\u3001\u3002\uFF0C\uFF01\uFF1F\uFF1B\uFF1A\u201C\u201D\u2018\u2019\u300A\u300B\uFF08\uFF09\s]/.test(ch)) {
                            displayed += ch;
                        } else {
                            displayed += `<span class="blank-cell${blankIdx === fillBlankIndex ? ' current' : ''}" data-line="${blankIdx}" data-char="${charIdx}"></span>`;
                            charIdx++;
                        }
                    }
                    // 填空行的拼音半透明显示
                    let pinyinHtml = '';
                    if (showPinyin && origIdx >= 0) {
                        const pinyinArr = getCharPinyin(fillCurrentPoem, origIdx);
                        if (pinyinArr) {
                            pinyinHtml = '<div style="opacity: 0.3; line-height: 1.2;">' + textToRubyHtml(line, pinyinArr) + '</div>';
                        }
                    }
                    html += `<div class="line">${displayed}</div>${pinyinHtml}`;
                    blankIdx++;
                } else {
                    // 非填空行：显示完整文字+拼音
                    let lineContent = line;
                    if (showPinyin && origIdx >= 0) {
                        const pinyinArr = getCharPinyin(fillCurrentPoem, origIdx);
                        lineContent = textToRubyHtml(line, pinyinArr);
                    }
                    html += `<div class="line" style="color: #8b7355;">${lineContent}</div>`;
                }
            }

            document.getElementById('fill-title').textContent = fillCurrentPoem.title;
            document.getElementById('fill-author').textContent = `${fillCurrentPoem.author}`;
            document.getElementById('fill-poem').innerHTML = html;
        }

        function checkFillAnswer() {
            const input = document.getElementById('fill-input').value.trim();
            if (!input) return;

            const cleanCorrect = fillCorrectLine.replace(/\s/g, '');
            const cleanInput = input.replace(/\s/g, '');

            const stripPunct = s => s.replace(/[，。！？、；：""''《》（）,.!?;:'"()\s]/g, '');

            if (stripPunct(cleanInput) === stripPunct(cleanCorrect) ||
                cleanInput === cleanCorrect ||
                cleanCorrect.includes(cleanInput) && cleanInput.length > cleanCorrect.length * 0.6) {
                handleFillCorrect();
            } else {
                const inputChars = new Set(stripPunct(cleanInput));
                const correctChars = new Set(stripPunct(cleanCorrect));
                let matchCount = 0;
                inputChars.forEach(c => { if (correctChars.has(c)) matchCount++; });

                if (matchCount >= correctChars.size * 0.7 && cleanInput.length >= cleanCorrect.length * 0.6) {
                    handleFillCorrect();
                } else {
                    handleFillWrong();
                }
            }
        }

        function handleFillCorrect() {
            gameState.combo++;
            gameState.maxCombo = Math.max(gameState.maxCombo, gameState.combo);

            let points = 100;
            if (gameState.difficulty === 'medium') points = 150;
            if (gameState.difficulty === 'hard') points = 200;
            points += gameState.combo * 20;
            if (fillHintCount > 0) points = Math.floor(points * 0.5);

            gameState.score += points;
            gameState.correctPoems.push(fillCurrentPoem);

            showCombo(gameState.combo);

            document.querySelectorAll('.blank-cell.current').forEach(el => {
                el.classList.add('correct');
            });

            document.getElementById('fill-input').value = '';
            document.getElementById('fill-input').style.color = '#5a8a5a';
            document.getElementById('fill-hint').textContent = `正确! +${points}分`;

            stopTimer();
            updateFillUI();

            setTimeout(() => {
                document.getElementById('fill-input').style.color = '';
                gameState.currentQuestion++;
                nextFillQuestion();
            }, 1500);
        }

        function handleFillWrong() {
            gameState.combo = 0;
            gameState.wrongPoems.push({
                poem: fillCurrentPoem,
                yourAnswer: document.getElementById('fill-input').value
            });

            document.querySelectorAll('.blank-cell.current').forEach(el => {
                el.classList.add('wrong');
            });

            document.getElementById('fill-input').value = '';
            document.getElementById('fill-input').style.color = '#b85c4a';
            document.getElementById('fill-hint').textContent = '答错了';

            stopTimer();
            updateFillUI();

            showFillAnswer(true);

            setTimeout(() => {
                document.getElementById('fill-input').style.color = '';
                gameState.currentQuestion++;
                nextFillQuestion();
            }, 3000);
        }

        function showFillAnswer(showReveal) {
            const reveal = document.getElementById('fill-reveal');
            const revealText = document.getElementById('fill-reveal-text');

            // 找到正确答案行在原始段落中的索引
            const lineIdx = fillCurrentPoem.paragraphs.indexOf(fillCorrectLine);

            let answerHtml = '<div>';
            if (showPinyin && lineIdx >= 0) {
                answerHtml += renderLineWithPinyin(fillCurrentPoem, lineIdx);
            } else {
                answerHtml += fillCorrectLine;
            }
            answerHtml += '</div>';
            answerHtml += `<div style="font-size: 0.8em; color: #8b7355; margin-top: 12px;">
                    —— ${fillCurrentPoem.author}《${fillCurrentPoem.title}》
                </div>`;

            revealText.innerHTML = answerHtml;
            reveal.classList.add('show');
        }

        function giveFillHint() {
            fillHintCount++;
            const cleanLine = fillCorrectLine.replace(/[，。！？、；：""''《》（）\s]/g, '');

            if (fillHintCount === 1) {
                document.getElementById('fill-hint').textContent =
                    `提示: 第一个字是「${cleanLine[0]}」，共${cleanLine.length}个字`;
            } else if (fillHintCount === 2) {
                document.getElementById('fill-hint').textContent =
                    `提示: 前两个字是「${cleanLine.substring(0, 2)}」`;
            } else {
                document.getElementById('fill-hint').textContent = `答案: ${fillCorrectLine}`;
                document.getElementById('fill-input').value = fillCorrectLine;
            }
        }

        function skipFillQuestion() {
            gameState.combo = 0;
            gameState.wrongPoems.push({
                poem: fillCurrentPoem,
                yourAnswer: '(跳过)'
            });

            stopTimer();
            showFillAnswer(true);
            updateFillUI();

            setTimeout(() => {
                gameState.currentQuestion++;
                nextFillQuestion();
            }, 2000);
        }

        // ===== 飞花令模式 =====
        let feihuaTargetChar = '';
        let feihuaUsedPoems = new Set();
        let feihuaTimeLimit = 60;
        let feihuaAnswerCount = 0;

        function startFeihuaGame() {
            gameState.mode = 'feihua';
            gameState.score = 0;
            gameState.combo = 0;
            gameState.maxCombo = 0;
            gameState.correctPoems = [];
            gameState.wrongPoems = [];
            feihuaUsedPoems.clear();
            feihuaAnswerCount = 0;
            gameState.startTime = Date.now();

            feihuaTimeLimit = gameState.difficulty === 'easy' ? 90 :
                              gameState.difficulty === 'medium' ? 60 : 40;

            updateFeihuaUI();
            nextFeihuaChar();
        }

        function updateFeihuaUI() {
            document.getElementById('feihua-score').textContent = gameState.score;
            document.getElementById('feihua-count').textContent = feihuaAnswerCount;
            document.getElementById('feihua-combo').textContent = gameState.combo;
        }

        function nextFeihuaChar() {
            const commonChars = '春风花月雨山水云天日雪夜酒山河人情梦愁思归故乡秋霜露松竹梅兰柳烟';
            feihuaTargetChar = commonChars[randomInt(0, commonChars.length - 1)];
            feihuaUsedPoems.clear();

            document.getElementById('feihua-char').textContent = feihuaTargetChar;
            document.getElementById('feihua-input').value = '';
            document.getElementById('feihua-answers').innerHTML = '';
            document.getElementById('feihua-reveal').classList.remove('show');
            document.getElementById('feihua-hint').textContent = `请说出含有「${feihuaTargetChar}」字的诗句`;
            document.getElementById('feihua-submit').disabled = false;
            document.getElementById('feihua-input').focus();

            startTimer(feihuaTimeLimit, 'feihua-timer', () => {
                endFeihuaRound();
            });
        }

        function checkFeihuaAnswer() {
            const input = document.getElementById('feihua-input').value.trim();
            if (!input) return;

            if (!input.includes(feihuaTargetChar)) {
                document.getElementById('feihua-hint').textContent =
                    `这句诗中没有「${feihuaTargetChar}」字，请重新输入`;
                document.getElementById('feihua-input').value = '';
                return;
            }

            const pool = getPoemPool();

            let found = false;
            let foundPoem = null;

            // 辅助函数：移除标点符号和空格
            const stripPunctuation = (str) => str.replace(/[，。！？、；：""''《》（）,.!?;:'"()\s]/g, '');

            for (const poem of pool) {
                const key = poem.id || poem.title;
                if (feihuaUsedPoems.has(key)) continue;

                for (const para of poem.paragraphs) {
                    const cleanPara = stripPunctuation(para);
                    const cleanInput = stripPunctuation(input);

                    if (cleanPara === cleanInput ||
                        cleanPara.includes(cleanInput) && cleanInput.length >= cleanPara.length * 0.7 ||
                        cleanInput.includes(cleanPara) && cleanPara.length >= cleanInput.length * 0.7) {
                        found = true;
                        foundPoem = poem;
                        feihuaUsedPoems.add(key);
                        break;
                    }
                }
                if (found) break;
            }

            if (found && foundPoem) {
                gameState.combo++;
                gameState.maxCombo = Math.max(gameState.maxCombo, gameState.combo);
                feihuaAnswerCount++;

                let points = 100;
                if (gameState.difficulty === 'medium') points = 150;
                if (gameState.difficulty === 'hard') points = 200;
                points += gameState.combo * 20;

                gameState.score += points;
                gameState.correctPoems.push(foundPoem);

                showCombo(gameState.combo);

                const answerEl = document.createElement('div');
                answerEl.className = 'answer-item new';
                answerEl.innerHTML = `${escapeHtml(input)} <span style="color: #8b7355; font-size: 0.8em;">—— ${escapeHtml(foundPoem.author)}《${escapeHtml(foundPoem.title)}》 +${points}</span>`;
                const answersContainer = document.getElementById('feihua-answers');
                answersContainer.insertBefore(answerEl, answersContainer.firstChild);

                setTimeout(() => answerEl.classList.remove('new'), 500);

                document.getElementById('feihua-input').value = '';
                document.getElementById('feihua-hint').textContent = `正确! +${points}分 继续背诵...`;

            } else if (found) {
                gameState.combo++;
                gameState.maxCombo = Math.max(gameState.maxCombo, gameState.combo);
                feihuaAnswerCount++;

                let points = 80;
                points += gameState.combo * 10;
                gameState.score += points;

                showCombo(gameState.combo);

                const answerEl = document.createElement('div');
                answerEl.className = 'answer-item new';
                answerEl.innerHTML = `${escapeHtml(input)} <span style="color: #5a8a5a; font-size: 0.8em;">+${points}</span>`;
                const answersContainer = document.getElementById('feihua-answers');
                answersContainer.insertBefore(answerEl, answersContainer.firstChild);
                setTimeout(() => answerEl.classList.remove('new'), 500);

                document.getElementById('feihua-input').value = '';
                document.getElementById('feihua-hint').textContent = `正确! +${points}分 继续背诵...`;

            } else {
                if (input.includes(feihuaTargetChar) && input.length >= 5) {
                    gameState.combo++;
                    gameState.maxCombo = Math.max(gameState.maxCombo, gameState.combo);
                    feihuaAnswerCount++;

                    let points = 60;
                    points += gameState.combo * 10;
                    gameState.score += points;

                    showCombo(gameState.combo);

                    const answerEl = document.createElement('div');
                    answerEl.className = 'answer-item new';
                    answerEl.innerHTML = `${escapeHtml(input)} <span style="color: #5a7a9a; font-size: 0.8em;">未在数据库中找到 +${points}</span>`;
                    const answersContainer = document.getElementById('feihua-answers');
                    answersContainer.insertBefore(answerEl, answersContainer.firstChild);
                    setTimeout(() => answerEl.classList.remove('new'), 500);

                    document.getElementById('feihua-input').value = '';
                    document.getElementById('feihua-hint').textContent = `已记录! +${points}分 继续...`;
                } else {
                    gameState.combo = 0;
                    document.getElementById('feihua-hint').textContent = '未识别到有效诗句，请重新输入';
                    document.getElementById('feihua-input').value = '';
                }
            }

            updateFeihuaUI();
        }

        function giveFeihuaHint() {
            const pool = getPoemPool();
            const poemsWithChar = pool.filter(p => {
                return p.paragraphs.some(para => para.includes(feihuaTargetChar));
            });

            if (poemsWithChar.length > 0) {
                const hintPoem = poemsWithChar[randomInt(0, poemsWithChar.length - 1)];
                const hintLine = hintPoem.paragraphs.find(p => p.includes(feihuaTargetChar));

                if (hintLine) {
                    const lineIdx = hintPoem.paragraphs.indexOf(hintLine);
                    let hintContent;
                    if (showPinyin && lineIdx >= 0) {
                        const pinyinArr = getCharPinyin(hintPoem, lineIdx);
                        hintContent = textToRubyHtml(hintLine, pinyinArr);
                    } else {
                        hintContent = hintLine;
                    }
                    let hintHtml = `提示: 「${hintContent}」—— ${hintPoem.author}《${hintPoem.title}》`;
                    document.getElementById('feihua-hint').innerHTML = hintHtml;

                    gameState.score = Math.max(0, gameState.score - 30);
                    updateFeihuaUI();
                }
            }
        }

        function skipFeihuaQuestion() {
            stopTimer();
            nextFeihuaChar();
        }

        function endFeihuaRound() {
            stopTimer();
            document.getElementById('feihua-submit').disabled = true;

            const pool = getPoemPool();
            const poemsWithChar = pool.filter(p =>
                p.paragraphs.some(para => para.includes(feihuaTargetChar))
            ).slice(0, 5);

            const revealText = poemsWithChar.map(p => {
                const line = p.paragraphs.find(para => para.includes(feihuaTargetChar));
                const lineIdx = p.paragraphs.indexOf(line);
                let lineContent;
                if (showPinyin && lineIdx >= 0) {
                    const pinyinArr = getCharPinyin(p, lineIdx);
                    lineContent = textToRubyHtml(line, pinyinArr);
                } else {
                    lineContent = line;
                }
                return `${lineContent} —— ${p.author}《${p.title}》`;
            }).join('<br><br>');

            document.getElementById('feihua-reveal-text').innerHTML = revealText || '暂无更多参考答案';
            document.getElementById('feihua-reveal').classList.add('show');

            setTimeout(() => {
                endGame();
            }, 4000);
        }

        // ===== 诗词查询功能 =====
        function showSearch() {
            stopTimer();
            document.getElementById('home-screen').style.display = 'none';
            document.getElementById('fill-game').classList.remove('active');
            document.getElementById('feihua-game').classList.remove('active');
            document.getElementById('search-screen').classList.add('active');
            document.getElementById('leaderboard-screen').classList.remove('active');
            document.getElementById('result-screen').classList.remove('active');

            document.querySelectorAll('.nav-btn').forEach((btn, i) => {
                btn.classList.toggle('active', i === 3);
            });

            document.getElementById('search-input').focus();
        }

        function setSearchFilter(filter, btn) {
            searchState.filter = filter;
            searchState.currentPage = 1;
            document.querySelectorAll('.filter-btn').forEach(b => b.classList.remove('active'));
            btn.classList.add('active');
