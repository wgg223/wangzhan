                    <span>朗读</span>
                </button>
            </div>

            <!-- 分类选择 -->
            <div class="start-section">
                <div class="category-section">
                    <div class="section-label">选择分类</div>
                    <div class="category-list" id="category-list"></div>
                </div>

                <!-- 拼音开关 -->
                <div class="pinyin-toggle">
                    <span>显示拼音</span>
                    <div class="toggle-switch" id="pinyin-toggle" onclick="togglePinyin()"></div>
                </div>

                <div class="difficulty">
                    <button class="diff-btn active" data-diff="easy" onclick="setDifficulty('easy', this)">简单</button>
                    <button class="diff-btn" data-diff="medium" onclick="setDifficulty('medium', this)">中等</button>
                    <button class="diff-btn" data-diff="hard" onclick="setDifficulty('hard', this)">困难</button>
                </div>
            </div>
        </div>

        <!-- 诗词填空游戏 -->
        <div id="fill-game" class="game-area">
            <div class="game-info">
                <div class="info-item">
                    <span>得分:</span>
                    <span class="info-value" id="fill-score">0</span>
                </div>
                <div class="info-item">
                    <span>题目:</span>
                    <span class="info-value" id="fill-progress">1/10</span>
                </div>
                <div class="info-item">
                    <span>连击:</span>
                    <span class="info-value" id="fill-combo">0</span>
                </div>
                <div class="info-item timer">
                    <span>时间:</span>
                    <span class="info-value" id="fill-timer">--:--</span>
                </div>
            </div>

            <div class="poem-card">
                <div class="poem-title-display" id="fill-title"></div>
                <div class="poem-author-display" id="fill-author"></div>
                <div class="poem-lines" id="fill-poem"></div>
            </div>

            <div class="input-area">
