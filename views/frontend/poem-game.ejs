<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>飞花令 · 诗词填空</title>
    <link rel="stylesheet" href="<%= typeof cdn !== 'undefined' ? cdn.getUrl('/css/style.css') : '/css/style.css' %>">
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        @font-face {
            font-family: 'Noto Serif SC';
            src: local('Noto Serif SC'), local('SimSun'), local('宋体');
        }

        body {
            font-family: 'Noto Serif SC', 'SimSun', 'STSong', serif;
            background: #f5f0e8;
            color: #3a3a3a;
            min-height: 100vh;
            overflow-x: hidden;
        }

        /* 水墨纹理背景 */
        .bg-texture {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            z-index: 0;
            pointer-events: none;
            background: 
                radial-gradient(ellipse at 20% 30%, rgba(180, 160, 130, 0.15) 0%, transparent 50%),
                radial-gradient(ellipse at 80% 70%, rgba(160, 140, 110, 0.1) 0%, transparent 50%),
                linear-gradient(180deg, #f5f0e8 0%, #ebe5d8 100%);
        }

        .container {
            position: relative;
            z-index: 1;
            max-width: 860px;
            margin: 0 auto;
            padding: 24px 20px;
            min-height: 100vh;
        }

        /* 标题区域 - 简约典雅 */
        .header {
            text-align: center;
            padding: 48px 0 32px;
            position: relative;
        }

        .header::after {
            content: '';
            display: block;
            width: 120px;
            height: 1px;
            background: linear-gradient(90deg, transparent, #8b7355, transparent);
            margin: 24px auto 0;
        }

        .header h1 {
            font-size: 2.6em;
            color: #4a3f35;
            letter-spacing: 16px;
            font-weight: 400;
            margin-bottom: 8px;
        }

        .header .subtitle {
            font-size: 0.95em;
            color: #8b7355;
            letter-spacing: 8px;
            font-weight: 300;
        }

        /* 导航菜单 - 极简风格 */
        .nav-menu {
            display: flex;
            justify-content: center;
            gap: 8px;
            margin: 32px 0 40px;
            flex-wrap: wrap;
        }

        .nav-btn {
            padding: 10px 28px;
            background: transparent;
            border: none;
            color: #6b5b4a;
            font-size: 1em;
            font-family: inherit;
            cursor: pointer;
            transition: all 0.3s ease;
            letter-spacing: 4px;
            position: relative;
        }

        .nav-btn::after {
            content: '';
            position: absolute;
            bottom: 4px;
            left: 50%;
            width: 0;
            height: 1px;
            background: #8b7355;
            transition: all 0.3s ease;
            transform: translateX(-50%);
        }

        .nav-btn:hover, .nav-btn.active {
            color: #4a3f35;
        }

        .nav-btn:hover::after, .nav-btn.active::after {
            width: 60%;
        }

        /* 首页 */
        .home-screen {
            text-align: center;
            padding: 20px 0;
        }

        .home-screen .poem-display {
            margin: 0 0 40px;
            padding: 40px 32px;
            position: relative;
            background: rgba(255, 252, 245, 0.6);
            border: 1px solid rgba(139, 115, 85, 0.15);
        }

        .home-screen .poem-display::before,
        .home-screen .poem-display::after {
            content: '';
            position: absolute;
            width: 24px;
            height: 24px;
            border: 1px solid rgba(139, 115, 85, 0.3);
        }

        .home-screen .poem-display::before {
            top: -1px;
            left: -1px;
            border-right: none;
            border-bottom: none;
        }

        .home-screen .poem-display::after {
            bottom: -1px;
            right: -1px;
            border-left: none;
            border-top: none;
        }

        .home-screen .poem-display p {
            font-size: 1.15em;
            line-height: 2.4;
            color: #4a4a4a;
            letter-spacing: 2px;
        }

        .home-screen .poem-info {
            margin-top: 20px;
            color: #8b7355;
            font-size: 0.9em;
            letter-spacing: 2px;
        }

        .start-section {
            margin-top: 40px;
        }

        .start-section .difficulty {
            display: flex;
            justify-content: center;
            gap: 16px;
            margin-bottom: 24px;
            flex-wrap: wrap;
        }

        .diff-btn {
            padding: 8px 24px;
            background: transparent;
            border: 1px solid rgba(139, 115, 85, 0.3);
            color: #6b5b4a;
            font-family: inherit;
            font-size: 0.9em;
            cursor: pointer;
            transition: all 0.3s;
            letter-spacing: 2px;
        }

        .diff-btn:hover, .diff-btn.active {
            border-color: #8b7355;
            color: #4a3f35;
            background: rgba(139, 115, 85, 0.05);
        }

        /* 分类选择 */
        .category-section {
            margin-bottom: 32px;
        }

        .category-section .section-label {
            color: #8b7355;
            font-size: 0.9em;
            margin-bottom: 16px;
            letter-spacing: 4px;
        }

        .category-list {
            display: flex;
            justify-content: center;
            gap: 12px;
            flex-wrap: wrap;
        }

        .cat-btn {
            padding: 6px 16px;
            background: transparent;
            border: 1px solid rgba(139, 115, 85, 0.2);
            color: #7a6a5a;
            font-family: inherit;
            font-size: 0.85em;
            cursor: pointer;
            transition: all 0.3s;
            letter-spacing: 2px;
        }

        .cat-btn:hover, .cat-btn.active {
            border-color: #8b7355;
            color: #4a3f35;
            background: rgba(139, 115, 85, 0.08);
        }

        .cat-btn .cat-count {
            font-size: 0.85em;
            color: #a09080;
            margin-left: 4px;
        }

        .cat-btn:hover .cat-count, .cat-btn.active .cat-count {
            color: #7a6a5a;
        }

        /* 拼音开关 */
        .pinyin-toggle {
            display: flex;
            justify-content: center;
            align-items: center;
            gap: 12px;
            margin: 24px 0;
            color: #8b7355;
            font-size: 0.85em;
            letter-spacing: 2px;
        }

        .toggle-switch {
            position: relative;
            width: 40px;
            height: 20px;
            background: rgba(139, 115, 85, 0.15);
            border: 1px solid rgba(139, 115, 85, 0.3);
            border-radius: 10px;
            cursor: pointer;
            transition: all 0.3s;
        }

        .toggle-switch.active {
            background: rgba(139, 115, 85, 0.25);
            border-color: #8b7355;
        }

        .toggle-switch::after {
            content: '';
            position: absolute;
            top: 2px;
            left: 2px;
            width: 14px;
            height: 14px;
            background: #a09080;
            border-radius: 50%;
            transition: all 0.3s;
        }

        .toggle-switch.active::after {
            left: 22px;
            background: #6b5b4a;
        }

        /* 游戏区域 */
        .game-area {
            display: none;
            padding: 20px 0;
        }

        .game-area.active {
            display: block;
            animation: fadeIn 0.4s ease;
        }

        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(8px); }
            to { opacity: 1; transform: translateY(0); }
        }

        /* 游戏信息栏 */
        .game-info {
            display: flex;
            justify-content: center;
            align-items: center;
            padding: 16px 24px;
            background: rgba(255, 252, 245, 0.5);
            border: 1px solid rgba(139, 115, 85, 0.12);
            margin-bottom: 28px;
            flex-wrap: wrap;
            gap: 20px;
        }

        .game-info .info-item {
            display: flex;
            align-items: center;
            gap: 8px;
            color: #8b7355;
            font-size: 0.9em;
            letter-spacing: 1px;
        }

        .game-info .info-value {
            color: #4a3f35;
            font-weight: 500;
        }

        .timer {
            color: #b85c4a !important;
        }

        .timer .info-value {
            color: #b85c4a !important;
        }

        /* 诗词显示区域 */
        .poem-card {
            background: rgba(255, 252, 245, 0.7);
            border: 1px solid rgba(139, 115, 85, 0.12);
            padding: 40px 32px;
            margin-bottom: 28px;
            position: relative;
        }

        .poem-title-display {
            text-align: center;
            margin-bottom: 8px;
            font-size: 1.25em;
            color: #4a3f35;
            letter-spacing: 6px;
        }

        .poem-author-display {
            text-align: center;
            margin-bottom: 28px;
            font-size: 0.85em;
            color: #8b7355;
            letter-spacing: 2px;
        }

        .poem-lines {
            text-align: center;
            line-height: 2.8;
            font-size: 1.25em;
        }

        .poem-lines .line {
            margin: 4px 0;
            letter-spacing: 3px;
            color: #4a4a4a;
        }

        /* 拼音行（兼容旧显示） */
        .pinyin-line {
            font-size: 0.42em;
            color: #a09080;
            letter-spacing: 1px;
            line-height: 1.2;
            margin-top: 2px;
            margin-bottom: 4px;
        }

        /* Ruby 注音标签样式 - 拼音显示在文字上方 */
        ruby {
            ruby-align: center;
        }

        ruby rt {
            font-size: 0.48em;
            color: #8b7355;
            font-family: 'Noto Sans SC', 'Microsoft YaHei', sans-serif;
            font-weight: 400;
            letter-spacing: 0;
        }

        /* 填空相关样式 */
        .blank-cell {
            display: inline-block;
            width: 40px;
            height: 40px;
            border-bottom: 1px solid #8b7355;
            margin: 0 1px;
            vertical-align: bottom;
            text-align: center;
            line-height: 40px;
            font-size: 1.05em;
            color: #4a3f35;
            transition: all 0.3s;
            position: relative;
        }

        .blank-cell.filled {
            color: #4a3f35;
            border-bottom-color: #4a3f35;
        }

        .blank-cell.correct {
            color: #5a8a5a;
            border-bottom-color: #5a8a5a;
            animation: correctPulse 0.4s ease;
        }

        .blank-cell.wrong {
            color: #b85c4a;
            border-bottom-color: #b85c4a;
            animation: shake 0.3s ease;
        }

        .blank-cell.hint {
            color: #5a7a9a;
            border-bottom-color: #5a7a9a;
        }

        .blank-cell.current {
            border-bottom-width: 2px;
            border-bottom-color: #6b5b4a;
        }

        @keyframes correctPulse {
            0% { transform: scale(1); }
            50% { transform: scale(1.15); }
            100% { transform: scale(1); }
        }

        @keyframes shake {
            0%, 100% { transform: translateX(0); }
            25% { transform: translateX(-4px); }
            75% { transform: translateX(4px); }
        }

        /* 飞花令特殊样式 */
        .feihua-char {
            display: inline-block;
            width: 56px;
            height: 56px;
            line-height: 56px;
            text-align: center;
            font-size: 1.6em;
            color: #4a3f35;
            border: 1px solid rgba(139, 115, 85, 0.4);
            margin: 16px 12px;
            background: rgba(255, 252, 245, 0.5);
        }

        /* 输入区域 */
        .input-area {
            margin-top: 28px;
            padding: 24px;
            background: rgba(255, 252, 245, 0.5);
            border: 1px solid rgba(139, 115, 85, 0.1);
        }

        .input-hint {
            color: #8b7355;
            margin-bottom: 16px;
            font-size: 0.85em;
            text-align: center;
            letter-spacing: 2px;
        }

        .input-row {
            display: flex;
            gap: 16px;
            justify-content: center;
            align-items: center;
            flex-wrap: wrap;
        }

        .poem-input {
            width: 320px;
            padding: 12px 16px;
            background: rgba(255, 252, 245, 0.8);
            border: 1px solid rgba(139, 115, 85, 0.2);
            color: #4a3f35;
            font-size: 1.05em;
            font-family: inherit;
            text-align: center;
            letter-spacing: 3px;
            outline: none;
            transition: border-color 0.3s;
        }

        .poem-input:focus {
            border-color: #8b7355;
        }

        .poem-input::placeholder {
            color: #b8a898;
            letter-spacing: 2px;
        }

        .submit-btn {
            padding: 12px 32px;
            background: #4a3f35;
            border: none;
            color: #f5f0e8;
            font-size: 0.95em;
            font-family: inherit;
            cursor: pointer;
            transition: all 0.3s;
            letter-spacing: 3px;
        }

        .submit-btn:hover {
            background: #5a4f45;
        }

        .submit-btn:disabled {
            opacity: 0.5;
            cursor: not-allowed;
        }

        /* 功能按钮 */
        .action-buttons {
            display: flex;
            justify-content: center;
            gap: 20px;
            margin-top: 20px;
            flex-wrap: wrap;
        }

        .action-btn {
            padding: 8px 20px;
            background: transparent;
            border: 1px solid rgba(139, 115, 85, 0.25);
            color: #7a6a5a;
            font-family: inherit;
            font-size: 0.85em;
            cursor: pointer;
            transition: all 0.3s;
            letter-spacing: 2px;
        }

        .action-btn:hover {
            border-color: #8b7355;
            color: #4a3f35;
        }

        .action-btn.hint-btn:hover {
            border-color: #5a7a9a;
            color: #5a7a9a;
        }

        .action-btn.skip-btn:hover {
            border-color: #b85c4a;
            color: #b85c4a;
        }

        /* 提示/答案显示 */
        .answer-reveal {
            margin-top: 24px;
            padding: 24px;
            background: rgba(255, 252, 245, 0.6);
            border: 1px solid rgba(139, 115, 85, 0.12);
            display: none;
        }

        .answer-reveal.show {
            display: block;
            animation: fadeIn 0.4s ease;
        }

        .answer-reveal .reveal-label {
            color: #8b7355;
            margin-bottom: 12px;
            font-size: 0.9em;
            letter-spacing: 2px;
        }

        .answer-reveal .reveal-text {
            color: #5a8a5a;
            font-size: 1.15em;
            line-height: 2;
            text-align: center;
            letter-spacing: 2px;
        }

        /* 飞花令答案列表 */
        .feihua-answers {
            margin-top: 24px;
        }

        .feihua-answers .answer-item {
            display: inline-block;
            margin: 6px 10px;
            padding: 8px 16px;
            background: rgba(255, 252, 245, 0.6);
            border: 1px solid rgba(139, 115, 85, 0.15);
            color: #4a4a4a;
            font-size: 0.9em;
            animation: fadeIn 0.3s ease;
        }

        .feihua-answers .answer-item.new {
            border-color: #8b7355;
            color: #4a3f35;
        }

        /* 结算画面 */
        .result-screen {
            text-align: center;
            padding: 48px 24px;
            display: none;
        }

        .result-screen.active {
            display: block;
            animation: fadeIn 0.4s ease;
        }

        .result-score {
            font-size: 3.2em;
            color: #4a3f35;
            margin: 24px 0;
            font-weight: 300;
        }

        .result-detail {
            color: #6b5b4a;
            font-size: 0.95em;
            line-height: 2.2;
            margin: 20px 0;
            letter-spacing: 1px;
        }

        .result-poems {
            margin: 36px 0;
            text-align: left;
        }

        .result-poems h3 {
            color: #4a3f35;
            text-align: center;
            margin-bottom: 20px;
            letter-spacing: 6px;
            font-weight: 400;
        }

        .result-poem-item {
            padding: 16px 20px;
            margin: 10px 0;
            background: rgba(255, 252, 245, 0.5);
            border-left: 2px solid rgba(139, 115, 85, 0.3);
        }

        .result-poem-item .poem-text {
            color: #4a4a4a;
            font-size: 0.9em;
            line-height: 2;
            letter-spacing: 1px;
        }

        .result-poem-item .poem-meta {
            color: #8b7355;
            font-size: 0.8em;
            margin-top: 8px;
            letter-spacing: 2px;
        }

        /* 连击提示 */
        .combo-display {
            position: fixed;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            font-size: 1.8em;
            color: #4a3f35;
            pointer-events: none;
            z-index: 100;
            opacity: 0;
            transition: opacity 0.3s;
        }

        .combo-display.show {
            opacity: 1;
            animation: comboAnim 1s ease forwards;
        }

        @keyframes comboAnim {
            0% { transform: translate(-50%, -50%) scale(0.5); opacity: 0; }
            30% { transform: translate(-50%, -50%) scale(1.1); opacity: 1; }
            100% { transform: translate(-50%, -80%) scale(1); opacity: 0; }
        }

        /* 加载动画 */
        .loading {
            text-align: center;
            padding: 60px 0;
            color: #8b7355;
        }

        .loading .dots {
            display: inline-block;
        }

        .loading .dot {
            display: inline-block;
            width: 6px;
            height: 6px;
            background: #8b7355;
            border-radius: 50%;
            margin: 0 4px;
            animation: dotBounce 1.4s ease-in-out infinite;
        }

        .loading .dot:nth-child(2) { animation-delay: 0.2s; }
        .loading .dot:nth-child(3) { animation-delay: 0.4s; }

        @keyframes dotBounce {
            0%, 80%, 100% { transform: translateY(0); }
            40% { transform: translateY(-8px); }
        }

        /* ========== 诗词查询样式 ========== */
        .search-screen {
            display: none;
            padding: 20px 0;
        }

        .search-screen.active {
            display: block;
            animation: fadeIn 0.4s ease;
        }

        .search-header {
            text-align: center;
            margin-bottom: 32px;
        }

        .search-header h2 {
            font-size: 1.4em;
            color: #4a3f35;
            letter-spacing: 6px;
            font-weight: 400;
            margin-bottom: 8px;
        }

        .search-header p {
            color: #8b7355;
            font-size: 0.85em;
            letter-spacing: 2px;
        }

        .search-box {
            display: flex;
            gap: 12px;
            justify-content: center;
            margin-bottom: 24px;
            flex-wrap: wrap;
        }

        .search-input {
            width: 400px;
            max-width: 100%;
            padding: 14px 20px;
            background: rgba(255, 252, 245, 0.8);
            border: 1px solid rgba(139, 115, 85, 0.25);
            color: #4a3f35;
            font-size: 1em;
            font-family: inherit;
            letter-spacing: 2px;
            outline: none;
            transition: border-color 0.3s;
        }

        .search-input:focus {
            border-color: #8b7355;
        }

        .search-input::placeholder {
            color: #b8a898;
            letter-spacing: 2px;
        }

        .search-btn {
            padding: 14px 36px;
            background: #4a3f35;
            border: none;
            color: #f5f0e8;
            font-size: 0.95em;
            font-family: inherit;
            cursor: pointer;
            transition: all 0.3s;
            letter-spacing: 3px;
        }

        .search-btn:hover {
            background: #5a4f45;
        }

        .search-filters {
            display: flex;
            justify-content: center;
            gap: 16px;
            margin-bottom: 32px;
            flex-wrap: wrap;
        }

        .filter-btn {
            padding: 6px 18px;
            background: transparent;
            border: 1px solid rgba(139, 115, 85, 0.2);
            color: #7a6a5a;
            font-family: inherit;
            font-size: 0.85em;
            cursor: pointer;
            transition: all 0.3s;
            letter-spacing: 2px;
        }

        .filter-btn:hover, .filter-btn.active {
            border-color: #8b7355;
            color: #4a3f35;
            background: rgba(139, 115, 85, 0.08);
        }

        .search-results {
            margin-top: 8px;
        }

        .search-stats {
            text-align: center;
            color: #8b7355;
            font-size: 0.85em;
            margin-bottom: 24px;
            letter-spacing: 2px;
        }

        .search-result-item {
            padding: 20px 24px;
            margin: 12px 0;
            background: rgba(255, 252, 245, 0.6);
            border: 1px solid rgba(139, 115, 85, 0.1);
            cursor: pointer;
            transition: all 0.3s;
        }

        .search-result-item:hover {
            border-color: rgba(139, 115, 85, 0.3);
            background: rgba(255, 252, 245, 0.8);
        }

        .search-result-item .result-title {
            font-size: 1.1em;
            color: #4a3f35;
            letter-spacing: 3px;
            margin-bottom: 6px;
        }

        .search-result-item .result-author {
            font-size: 0.85em;
            color: #8b7355;
            letter-spacing: 2px;
            margin-bottom: 10px;
        }

        .search-result-item .result-preview {
            font-size: 0.9em;
            color: #6b5b4a;
            line-height: 1.8;
            letter-spacing: 1px;
        }

        .search-result-item .result-category {
            display: inline-block;
            margin-top: 10px;
            padding: 2px 10px;
            background: rgba(139, 115, 85, 0.08);
            border: 1px solid rgba(139, 115, 85, 0.15);
            color: #8b7355;
            font-size: 0.75em;
            letter-spacing: 1px;
        }

        .author-link {
            color: #8b7355;
            cursor: pointer;
            text-decoration: underline;
            text-decoration-style: dotted;
            text-underline-offset: 3px;
            transition: color 0.3s;
        }

        .author-link:hover {
            color: #4a3f35;
            text-decoration-style: solid;
        }

        .search-pagination {
            display: flex;
            justify-content: center;
            gap: 8px;
            margin-top: 32px;
            flex-wrap: wrap;
        }

        .page-btn {
            padding: 8px 16px;
            background: transparent;
            border: 1px solid rgba(139, 115, 85, 0.2);
            color: #7a6a5a;
            font-family: inherit;
            font-size: 0.85em;
            cursor: pointer;
            transition: all 0.3s;
        }

        .page-btn:hover, .page-btn.active {
            border-color: #8b7355;
            color: #4a3f35;
            background: rgba(139, 115, 85, 0.08);
        }

        .page-btn:disabled {
            opacity: 0.4;
            cursor: not-allowed;
        }

        /* 诗词详情弹窗 */
        .poem-modal {
            display: none;
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            z-index: 200;
            background: rgba(0, 0, 0, 0.4);
            justify-content: center;
            align-items: center;
            padding: 20px;
        }

        .poem-modal.show {
            display: flex;
            animation: fadeIn 0.3s ease;
        }

        .poem-modal-content {
            background: #f5f0e8;
            max-width: 600px;
            width: 100%;
            max-height: 80vh;
            overflow-y: auto;
            padding: 40px 36px;
            position: relative;
            border: 1px solid rgba(139, 115, 85, 0.2);
        }

        .poem-modal-content::before,
        .poem-modal-content::after {
            content: '';
            position: absolute;
            width: 20px;
            height: 20px;
            border: 1px solid rgba(139, 115, 85, 0.3);
        }

        .poem-modal-content::before {
            top: -1px;
            left: -1px;
            border-right: none;
            border-bottom: none;
        }

        .poem-modal-content::after {
            bottom: -1px;
            right: -1px;
            border-left: none;
            border-top: none;
        }

        .modal-close {
            position: absolute;
            top: 12px;
            right: 16px;
            background: none;
            border: none;
            font-size: 1.4em;
            color: #8b7355;
            cursor: pointer;
            transition: color 0.3s;
            line-height: 1;
        }

        .modal-close:hover {
            color: #4a3f35;
        }

        .modal-title {
            text-align: center;
            font-size: 1.4em;
            color: #4a3f35;
            letter-spacing: 6px;
            margin-bottom: 8px;
        }

        .modal-author {
            text-align: center;
            color: #8b7355;
            font-size: 0.9em;
            letter-spacing: 2px;
            margin-bottom: 28px;
        }

        .modal-poem-text {
            text-align: center;
            line-height: 2.6;
            font-size: 1.15em;
            color: #4a4a4a;
            letter-spacing: 2px;
            margin-bottom: 24px;
        }

        .modal-meta {
            text-align: center;
            color: #a09080;
            font-size: 0.8em;
            letter-spacing: 1px;
            padding-top: 16px;
            border-top: 1px solid rgba(139, 115, 85, 0.15);
        }

        .search-empty {
            text-align: center;
            padding: 60px 20px;
            color: #8b7355;
        }

        .search-empty .empty-icon {
            font-size: 3em;
            margin-bottom: 16px;
            opacity: 0.5;
        }

        .search-empty p {
            letter-spacing: 2px;
            font-size: 0.9em;
        }

        /* ========== 排行榜样式 ========== */
        .leaderboard-screen {
            display: none;
            padding: 20px 0;
        }

        .leaderboard-screen.active {
            display: block;
            animation: fadeIn 0.4s ease;
        }

        .leaderboard-header {
            text-align: center;
            margin-bottom: 32px;
        }

        .leaderboard-header h2 {
            font-size: 1.4em;
            color: #4a3f35;
            letter-spacing: 6px;
            font-weight: 400;
            margin-bottom: 8px;
        }

        .leaderboard-header p {
            color: #8b7355;
            font-size: 0.85em;
            letter-spacing: 2px;
        }

        .leaderboard-filters {
            display: flex;
            justify-content: center;
            gap: 16px;
            margin-bottom: 32px;
            flex-wrap: wrap;
        }

        .leaderboard-table {
            width: 100%;
            border-collapse: collapse;
            margin-top: 20px;
        }

        .leaderboard-table th,
        .leaderboard-table td {
            padding: 12px 16px;
            text-align: left;
            border-bottom: 1px solid rgba(139, 115, 85, 0.15);
        }

        .leaderboard-table th {
            background: rgba(255, 252, 245, 0.5);
            color: #8b7355;
            font-weight: 500;
            letter-spacing: 2px;
            font-size: 0.9em;
        }

        .leaderboard-table td {
            color: #4a4a4a;
            letter-spacing: 1px;
        }

        .leaderboard-table tr:hover {
            background: rgba(255, 252, 245, 0.4);
        }

        .rank-badge {
            display: inline-block;
            width: 24px;
            height: 24px;
            line-height: 24px;
            text-align: center;
            border-radius: 50%;
            font-size: 0.8em;
            font-weight: 500;
        }

        .rank-1 {
            background: #ffd700;
            color: #4a3f35;
        }

        .rank-2 {
            background: #c0c0c0;
            color: #4a3f35;
        }

        .rank-3 {
            background: #cd7f32;
            color: #fff;
        }

        /* ========== 语音朗读按钮 ========== */
        .speak-btn {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            padding: 6px 16px;
            background: transparent;
            border: 1px solid rgba(139, 115, 85, 0.25);
            color: #7a6a5a;
            font-family: inherit;
            font-size: 0.85em;
            cursor: pointer;
            transition: all 0.3s;
            letter-spacing: 2px;
            margin-top: 12px;
        }

        .speak-btn:hover {
            border-color: #8b7355;
            color: #4a3f35;
        }

        .speak-btn.speaking {
            border-color: #b85c4a;
            color: #b85c4a;
            animation: speakPulse 1s ease infinite;
        }

        @keyframes speakPulse {
            0%, 100% { opacity: 1; }
            50% { opacity: 0.6; }
        }

        .speak-icon {
            font-size: 1.1em;
        }

        /* ========== 响应式 ========== */
        @media (max-width: 600px) {
            .header h1 { font-size: 2em; letter-spacing: 10px; }
            .poem-lines { font-size: 1.1em; }
            .blank-cell { width: 32px; height: 32px; line-height: 32px; font-size: 0.95em; }
            .poem-card { padding: 24px 16px; }
            .poem-input { width: 100%; }
            .search-input { width: 100%; }
            .nav-btn { padding: 8px 20px; font-size: 0.9em; }
            .feihua-char { width: 48px; height: 48px; line-height: 48px; font-size: 1.4em; }
        }
    </style>
</head>
<body>
    <div class="bg-texture"></div>

    <div class="container">
        <div class="header">
            <h1>飞花令</h1>
            <div class="subtitle">诗词填空小游戏</div>
        </div>

        <!-- 导航 -->
        <div class="nav-menu">
            <button class="nav-btn active" onclick="showHome()">首页</button>
            <button class="nav-btn" onclick="startGame('fill')">诗词填空</button>
            <button class="nav-btn" onclick="startGame('feihua')">飞花令</button>
            <button class="nav-btn" onclick="showSearch()">诗词查询</button>
            <button class="nav-btn" onclick="showLeaderboard()">排行榜</button>
            <a href="https://a.dalaowang233.top" class="nav-btn" target="_blank" rel="noopener noreferrer" style="text-decoration: none;">完整数据</a>
            <a href="/home" class="nav-btn" style="text-decoration: none;">返回网站</a>
        </div>

        <!-- 首页 -->
        <div id="home-screen" class="home-screen">
            <div class="poem-display">
                <p id="random-poem"></p>
                <div class="poem-info" id="random-poem-info"></div>
                <button class="speak-btn" id="home-speak-btn" onclick="speakPoem('home')">
