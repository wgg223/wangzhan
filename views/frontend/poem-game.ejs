                    <button class="submit-btn" id="fill-submit" onclick="checkFillAnswer()">确认</button>
                </div>
                <div class="action-buttons">
                    <button class="action-btn hint-btn" onclick="giveFillHint()">提示</button>
                    <button class="action-btn skip-btn" onclick="skipFillQuestion()">跳过</button>
                </div>
            </div>

            <div class="answer-reveal" id="fill-reveal">
                <div class="reveal-label">正确答案</div>
                <div class="reveal-text" id="fill-reveal-text"></div>
            </div>
        </div>

        <!-- 飞花令游戏 -->
        <div id="feihua-game" class="game-area">
