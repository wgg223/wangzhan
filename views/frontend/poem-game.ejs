        // 繁简互转辅助，用于搜索增强
        const traditionalToSimplified = {};
        (function buildTraditionalMap() {
            const pairs = [
                '東东','車车','馬马','龍龙','鳳凤','鳥鸟','魚鱼','蟲虫','門门','雲云','會会','風风','氣气',
                '書书','學学','國国','話话','說说','請请','語语','讀读','記记','該该','調调','論论','證证','識识',
                '詩诗','詞词','賦赋','歌歌','唱唱','曲曲',
                '歸归','處处','來来','葉叶','發发','頭头',
                '關关','遠远','長长','鄉乡','夢梦','愁愁','思思',
                '聲声','淚泪','情情','心心','意意','酒酒','夜夜',
                '燈灯','樓楼','門门','江江','河河','海海','路路',
                '國国','家家','王王','帝帝','君君','臣臣',
                '筆笔','墨墨','紙纸','硯砚','琴琴','棋棋','書书','畫画',
                '春春','夏夏','秋秋','冬冬','霜霜','露露','雷雷','電电',
                '松松','竹竹','梅梅','蘭兰','柳柳','煙烟','鶴鹤',
                '歲岁','年年','月月','日日','時时','期期',
                '飛飞','落落','開开','謝谢','生生死死','離离','合合',
                '愛爱','恨恨','苦苦','樂乐','憂忧','悲悲','歡欢',
                '雲云','霧雾','雨雨','雪雪','霜霜','露露',
                '龍龙','鳳凤','鳳凤','鸞鸾',
                '寶宝','玉玉','金金','銀银','鐵铁',
                '鸚鹦','鵡鹉',
                '鳳凤','凰凰',
                '鸞鸾','鳳凤',
                '驊骅','騮骝',
                '鴛鸳','鴦鸯'
            ];
            for (const pair of pairs) {
                traditionalToSimplified[pair[0]] = pair[1];
            }
        })();

        function toTraditionalSearch(text) {
            if (!text) return '';
            let result = '';
            for (const ch of text) {
                result += traditionalToSimplified[ch] || ch;
            }
            return result;
        }

        function performSearch() {
            const keyword = document.getElementById('search-input').value.trim();
            if (!keyword) {
                document.getElementById('search-results').innerHTML = `
                    <div class="search-empty">
                        <div class="empty-icon">卷</div>
                        <p>请输入搜索关键词</p>
                    </div>
                `;
                document.getElementById('search-pagination').innerHTML = '';
                return;
            }

            searchState.keyword = keyword;
            searchState.currentPage = 1;

            // 搜索诗词 - 增强匹配（支持繁简互查、拼音搜索、模糊匹配）
            const results = [];
            const lowerKeyword = keyword.toLowerCase();
            const tradKeyword = toTraditionalSearch(keyword);

            const searchData = (typeof SEARCH_DATA !== 'undefined' && SEARCH_DATA) ? SEARCH_DATA : POEMS_DATA;
            if (searchData) {
                for (const poem of searchData) {
                    let match = false;
                    let matchType = '';

                    // 标题匹配
                    if (searchState.filter === 'all' || searchState.filter === 'title') {
                        const title = (poem.title || '').trim();
                        if (title && (
                            title.toLowerCase().includes(lowerKeyword) ||
                            title.includes(tradKeyword) ||
                            lowerKeyword.includes(title.toLowerCase())
                        )) {
                            match = true;
                            matchType = 'title';
                        }
                    }

                    // 作者匹配 - 增强：去除空格、支持部分匹配、去除"（朝代）"后缀
                    if (searchState.filter === 'all' || searchState.filter === 'author') {
                        const author = (poem.author || '').trim();
                        if (author) {
                            // 去除括号中的朝代信息，如 "李白（唐）" -> "李白"
                            const cleanAuthor = author.replace(/[（(][^）)]*[）)]/g, '').trim();
                            const authorLower = cleanAuthor.toLowerCase();
                            const authorNoSpace = cleanAuthor.replace(/\s/g, '');

                            if (
                                authorLower.includes(lowerKeyword) ||
                                authorNoSpace.includes(lowerKeyword) ||
                                cleanAuthor.includes(tradKeyword) ||
                                lowerKeyword.includes(authorLower) ||
                                lowerKeyword.includes(authorNoSpace)
                            ) {
                                match = true;
                                matchType = matchType || 'author';
                            }
                        }
                    }

                    // 内容匹配
                    if (searchState.filter === 'all' || searchState.filter === 'content') {
                        if (poem.paragraphs) {
                            for (const para of poem.paragraphs) {
                                if (para.toLowerCase().includes(lowerKeyword) || para.includes(tradKeyword)) {
                                    match = true;
                                    matchType = matchType || 'content';
                                    break;
                                }
                            }
                        }
                    }

                    // 拼音搜索（无声调）
                    if (!match && poem.pinyin) {
                        for (const py of poem.pinyin) {
                            if (py && py.toLowerCase().includes(lowerKeyword)) {
                                match = true;
                                matchType = 'pinyin';
                                break;
                            }
                        }
                    }

                    // 朝代/分类搜索
                    if (!match) {
                        const dynasty = (poem.dynasty || '').toLowerCase();
                        const category = (poem.category || '').toLowerCase();
                        if (dynasty.includes(lowerKeyword) || category.includes(lowerKeyword)) {
                            match = true;
                            matchType = 'category';
                        }
                    }

                    if (match) {
                        results.push({ ...poem, matchType });
                    }
                }
            }

            searchState.results = results;
            renderSearchResults();
        }

        function renderSearchResults() {
            const { results, currentPage, pageSize, keyword } = searchState;
            const totalPages = Math.ceil(results.length / pageSize);
            const startIdx = (currentPage - 1) * pageSize;
            const pageResults = results.slice(startIdx, startIdx + pageSize);

            const container = document.getElementById('search-results');

            if (results.length === 0) {
                container.innerHTML = `
                    <div class="search-empty">
                        <div class="empty-icon">无</div>
                        <p>未找到相关诗词</p>
                    </div>
                `;
                document.getElementById('search-pagination').innerHTML = '';
                return;
            }

            let html = `<div class="search-stats">共找到 ${results.length} 首诗词</div>`;

            pageResults.forEach((poem, idx) => {
                // 显示更多行的预览，最多4行
                const previewLines = poem.paragraphs.slice(0, 4);
                const preview = previewLines.join('<br>');
                const previewText = preview.length > 120 ? preview.substring(0, 120) + '...' : preview;
                const globalIdx = startIdx + idx;

                // 标记匹配类型
                let matchBadge = '';
                if (poem.matchType === 'author') matchBadge = '<span style="color: #5a7a9a; font-size: 0.75em; margin-left: 8px;">[作者匹配]</span>';
                else if (poem.matchType === 'title') matchBadge = '<span style="color: #5a8a5a; font-size: 0.75em; margin-left: 8px;">[标题匹配]</span>';
                else if (poem.matchType === 'pinyin') matchBadge = '<span style="color: #8b7355; font-size: 0.75em; margin-left: 8px;">[拼音匹配]</span>';
                else if (poem.matchType === 'category') matchBadge = '<span style="color: #a09080; font-size: 0.75em; margin-left: 8px;">[分类匹配]</span>';

                // 作者名可点击，点击后搜索该作者的全部诗词
                const authorClickable = `<span class="author-link" onclick="event.stopPropagation(); searchByAuthor('${poem.author.replace(/'/g, "\\'")}')">${highlightText(poem.author, keyword)}</span>`;

                html += `
                    <div class="search-result-item" onclick="showPoemDetailByIndex(${globalIdx})">
                        <div class="result-title">${highlightText(poem.title, keyword)}${matchBadge}</div>
                        <div class="result-author">${authorClickable} · ${poem.dynasty || ''} · ${poem.category || ''}</div>
                        <div class="result-preview">${previewText}</div>
                        <div style="margin-top: 10px; display: flex; justify-content: space-between; align-items: center;">
                            <div class="result-category">${poem.source || ''}</div>
                            <span style="color: #8b7355; font-size: 0.8em; cursor: pointer; text-decoration: underline;" onclick="event.stopPropagation(); showPoemDetailByIndex(${globalIdx})">查看完整内容 →</span>
                        </div>
                    </div>
                `;
            });

            container.innerHTML = html;

            // 渲染分页
            let paginationHtml = '';
            if (totalPages > 1) {
                paginationHtml += `<button class="page-btn" onclick="goToPage(${currentPage - 1})" ${currentPage === 1 ? 'disabled' : ''}>上一页</button>`;

                const maxVisible = 5;
                let startPage = Math.max(1, currentPage - Math.floor(maxVisible / 2));
                let endPage = Math.min(totalPages, startPage + maxVisible - 1);
                if (endPage - startPage < maxVisible - 1) {
                    startPage = Math.max(1, endPage - maxVisible + 1);
                }

                if (startPage > 1) {
                    paginationHtml += `<button class="page-btn" onclick="goToPage(1)">1</button>`;
                    if (startPage > 2) paginationHtml += `<span style="color: #8b7355; padding: 0 8px;">...</span>`;
                }

                for (let i = startPage; i <= endPage; i++) {
                    paginationHtml += `<button class="page-btn ${i === currentPage ? 'active' : ''}" onclick="goToPage(${i})">${i}</button>`;
                }

                if (endPage < totalPages) {
                    if (endPage < totalPages - 1) paginationHtml += `<span style="color: #8b7355; padding: 0 8px;">...</span>`;
                    paginationHtml += `<button class="page-btn" onclick="goToPage(${totalPages})">${totalPages}</button>`;
                }

                paginationHtml += `<button class="page-btn" onclick="goToPage(${currentPage + 1})" ${currentPage === totalPages ? 'disabled' : ''}>下一页</button>`;
            }

            document.getElementById('search-pagination').innerHTML = paginationHtml;
        }

        function goToPage(page) {
            const totalPages = Math.ceil(searchState.results.length / searchState.pageSize);
            if (page < 1 || page > totalPages) return;
            searchState.currentPage = page;
            renderSearchResults();
            document.getElementById('search-results').scrollIntoView({ behavior: 'smooth' });
        }

        // 点击作者名搜索该作者全部诗词
        function searchByAuthor(authorName) {
            if (!authorName) return;
            document.getElementById('search-input').value = authorName;
            searchState.filter = 'author';
            searchState.currentPage = 1;
            // 更新筛选按钮状态
            document.querySelectorAll('.filter-btn').forEach(b => {
                b.classList.toggle('active', b.getAttribute('data-filter') === 'author');
            });
            performSearch();
            document.getElementById('search-results').scrollIntoView({ behavior: 'smooth' });
        }

        // 通过搜索结果索引显示诗词详情（避免 id 类型不匹配问题）
        function showPoemDetailByIndex(globalIdx) {
            const poem = searchState.results[globalIdx];
            if (!poem) return;
            renderPoemModal(poem);
        }

        function showPoemDetail(id, title) {
            // 查找诗词 - 兼容 id 类型差异
            let poem = null;
            if (POEMS_DATA) {
                poem = POEMS_DATA.find(p => {
                    if (id !== null && id !== undefined && String(p.id) === String(id)) return true;
                    if (p.title === title) return true;
                    return false;
                });
            }

            if (!poem) return;
            renderPoemModal(poem);
        }

        function renderPoemModal(poem) {
            document.getElementById('modal-title').textContent = poem.title;
            document.getElementById('modal-author').innerHTML = `—— ${poem.author}（${poem.dynasty || ''}）`;

            let linesHtml = '';
            poem.paragraphs.forEach((line, idx) => {
                if (showPinyin) {
                    const pinyinArr = getCharPinyin(poem, idx);
                    linesHtml += '<div>' + textToRubyHtml(line, pinyinArr) + '</div>';
                } else {
                    linesHtml += '<div>' + line + '</div>';
                }
            });
            document.getElementById('modal-poem-text').innerHTML = linesHtml;

            // 显示完整元信息
            const metaParts = [];
            if (poem.dynasty) metaParts.push(`朝代: ${poem.dynasty}`);
            if (poem.source) metaParts.push(`来源: ${poem.source}`);
            if (poem.category) metaParts.push(`分类: ${poem.category}`);
            if (poem.id) metaParts.push(`编号: ${poem.id}`);
            document.getElementById('modal-meta').textContent = metaParts.join(' · ') || '未知';

            document.getElementById('poem-modal').classList.add('show');
        }

        function closePoemModal(event) {
            if (event && event.target !== event.currentTarget) return;
            document.getElementById('poem-modal').classList.remove('show');
        }

        // ESC关闭弹窗
        document.addEventListener('keydown', function(e) {
            if (e.key === 'Escape') {
                closePoemModal();
            }
        });

        // ===== 游戏控制 =====
        function startGame(mode) {
            gameState.mode = mode;
            gameState.usedPoems.clear();

            document.getElementById('home-screen').style.display = 'none';
            document.getElementById('fill-game').classList.remove('active');
            document.getElementById('feihua-game').classList.remove('active');
            document.getElementById('search-screen').classList.remove('active');
            document.getElementById('leaderboard-screen').classList.remove('active');
            document.getElementById('result-screen').classList.remove('active');

            document.querySelectorAll('.nav-btn').forEach((btn, i) => {
                btn.classList.toggle('active', i === (mode === 'fill' ? 1 : 2));
            });

            if (mode === 'fill') {
                document.getElementById('fill-game').classList.add('active');
                startFillGame();
            } else {
                document.getElementById('feihua-game').classList.add('active');
                startFeihuaGame();
            }
        }

        function endGame() {
            stopTimer();
            const duration = Math.floor((Date.now() - gameState.startTime) / 1000);

            document.getElementById('fill-game').classList.remove('active');
            document.getElementById('feihua-game').classList.remove('active');
            document.getElementById('result-screen').classList.add('active');

            document.getElementById('result-score').textContent = gameState.score;

            const detail = [];
            if (gameState.mode === 'fill') {
                detail.push(`完成题目: ${gameState.currentQuestion}/${gameState.totalQuestions}`);
                detail.push(`正确: ${gameState.correctPoems.length} 首`);
            } else {
                detail.push(`背诵诗句: ${feihuaAnswerCount} 句`);
            }
            detail.push(`最高连击: ${gameState.maxCombo}`);
            detail.push(`游戏模式: ${gameState.mode === 'fill' ? '诗词填空' : '飞花令'}`);
            detail.push(`难度: ${{easy: '简单', medium: '中等', hard: '困难'}[gameState.difficulty]}`);
            detail.push(`分类: ${gameState.category}`);
            detail.push(`用时: ${duration}秒`);

            document.getElementById('result-detail').innerHTML = detail.join('<br>');

            if (gameState.correctPoems.length > 0) {
                let poemsHtml = '<h3>答对的诗词</h3>';
                gameState.correctPoems.slice(0, 20).forEach(p => {
                    let linesHtml = '';
                    p.paragraphs.forEach((line, idx) => {
                        if (showPinyin) {
                            const pinyinArr = getCharPinyin(p, idx);
                            linesHtml += textToRubyHtml(line, pinyinArr) + '<br>';
                        } else {
                            linesHtml += line + '<br>';
                        }
                    });
                    poemsHtml += `
                        <div class="result-poem-item">
                            <div class="poem-text">${linesHtml}</div>
                            <div class="poem-meta">—— ${p.author}《${p.title}》</div>
                        </div>
                    `;
                });
                document.getElementById('result-poems').innerHTML = poemsHtml;
            }

            // 提交分数到排行榜
            submitScore(duration);
        }

        // ===== 排行榜功能 =====
        async function submitScore(duration) {
            try {
                const response = await fetch('/poem-game/api/poem-leaderboard', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json'
                    },
                    body: JSON.stringify({
                        game_mode: gameState.mode,
                        difficulty: gameState.difficulty,
                        category: gameState.category,
                        score: gameState.score,
                        combo_max: gameState.maxCombo,
                        correct_count: gameState.correctPoems.length,
                        total_count: gameState.mode === 'fill' ? gameState.totalQuestions : feihuaAnswerCount,
                        duration: duration
                    })
                });
                const data = await response.json();
                if (data.success) {
                    console.log('分数已提交到排行榜，最高分:', data.bestScore);
                }
            } catch (error) {
                console.error('提交分数失败:', error);
            }
        }

        async function showLeaderboard() {
            stopTimer();
            document.getElementById('home-screen').style.display = 'none';
            document.getElementById('fill-game').classList.remove('active');
            document.getElementById('feihua-game').classList.remove('active');
            document.getElementById('search-screen').classList.remove('active');
            document.getElementById('leaderboard-screen').classList.add('active');
            document.getElementById('result-screen').classList.remove('active');

            document.querySelectorAll('.nav-btn').forEach((btn, i) => {
                btn.classList.toggle('active', i === 4);
            });

            await loadLeaderboard();
        }

        function setLeaderboardFilter(mode, btn) {
            leaderboardState.mode = mode;
            leaderboardState.page = 1;
            document.querySelectorAll('#leaderboard-screen .leaderboard-filters .filter-btn').forEach(b => b.classList.remove('active'));
            btn.classList.add('active');
            loadLeaderboard();
        }

        function setLeaderboardDifficulty(diff, btn) {
            leaderboardState.difficulty = diff;
            leaderboardState.page = 1;
            document.querySelectorAll('#leaderboard-screen .difficulty .diff-btn').forEach(b => b.classList.remove('active'));
            btn.classList.add('active');
            loadLeaderboard();
        }

        async function loadLeaderboard() {
            const container = document.getElementById('leaderboard-content');
            container.innerHTML = `
                <div class="loading">
                    <div class="dots">
                        <div class="dot"></div>
                        <div class="dot"></div>
                        <div class="dot"></div>
                    </div>
                </div>
            `;

            try {
                let url = `/poem-game/api/poem-leaderboard?page=${leaderboardState.page}&limit=${leaderboardState.limit}`;
                if (leaderboardState.mode !== 'all') {
                    url += `&mode=${leaderboardState.mode}`;
                }
                if (leaderboardState.difficulty !== 'all') {
                    url += `&difficulty=${leaderboardState.difficulty}`;
                }

                const response = await fetch(url);
                const data = await response.json();

                if (data.success && data.records.length > 0) {
                    leaderboardState.records = data.records;
                    leaderboardState.total = data.total;

                    let html = `
                        <div class="search-stats">共 ${data.total} 条记录</div>
                        <table class="leaderboard-table">
                            <thead>
                                <tr>
                                    <th>排名</th>
                                    <th>玩家</th>
                                    <th>得分</th>
                                    <th>模式</th>
                                    <th>难度</th>
                                    <th>连击</th>
                                    <th>时间</th>
                                </tr>
                            </thead>
                            <tbody>
                    `;

                    data.records.forEach((record, idx) => {
                        const rank = (leaderboardState.page - 1) * leaderboardState.limit + idx + 1;
                        let rankBadge = '';
                        if (rank === 1) rankBadge = '<span class="rank-badge rank-1">1</span>';
                        else if (rank === 2) rankBadge = '<span class="rank-badge rank-2">2</span>';
                        else if (rank === 3) rankBadge = '<span class="rank-badge rank-3">3</span>';
                        else rankBadge = `<span class="rank-badge">${rank}</span>`;

                        const modeText = record.game_mode === 'fill' ? '诗词填空' : '飞花令';
                        const diffText = { easy: '简单', medium: '中等', hard: '困难' }[record.difficulty] || record.difficulty;
                        const date = new Date(record.created_at).toLocaleDateString('zh-CN');

                        html += `
                            <tr>
                                <td>${rankBadge}</td>
                                <td>${escapeHtml(record.username)}</td>
                                <td style="font-weight: 500; color: #4a3f35;">${record.score}</td>
                                <td>${modeText}</td>
                                <td>${diffText}</td>
                                <td>${record.combo_max}</td>
                                <td style="font-size: 0.85em; color: #a09080;">${date}</td>
                            </tr>
                        `;
                    });

                    html += '</tbody></table>';

                    // 分页
                    const totalPages = Math.ceil(data.total / leaderboardState.limit);
                    if (totalPages > 1) {
                        html += '<div class="search-pagination" style="margin-top: 24px;">';
                        html += `<button class="page-btn" onclick="goToLeaderboardPage(${leaderboardState.page - 1})" ${leaderboardState.page === 1 ? 'disabled' : ''}>上一页</button>`;
                        
                        const maxVisible = 5;
                        let startPage = Math.max(1, leaderboardState.page - Math.floor(maxVisible / 2));
                        let endPage = Math.min(totalPages, startPage + maxVisible - 1);
                        
                        for (let i = startPage; i <= endPage; i++) {
                            html += `<button class="page-btn ${i === leaderboardState.page ? 'active' : ''}" onclick="goToLeaderboardPage(${i})">${i}</button>`;
                        }
                        
                        html += `<button class="page-btn" onclick="goToLeaderboardPage(${leaderboardState.page + 1})" ${leaderboardState.page === totalPages ? 'disabled' : ''}>下一页</button>`;
                        html += '</div>';
                    }

                    container.innerHTML = html;
                } else {
                    container.innerHTML = `
                        <div class="search-empty">
                            <div class="empty-icon">无</div>
                            <p>暂无排行榜数据</p>
                        </div>
                    `;
                }
            } catch (error) {
                console.error('加载排行榜失败:', error);
                container.innerHTML = `
                    <div class="search-empty">
                        <div class="empty-icon">错</div>
                        <p>加载排行榜失败，请稍后重试</p>
                    </div>
                `;
            }
        }

        function goToLeaderboardPage(page) {
            const totalPages = Math.ceil(leaderboardState.total / leaderboardState.limit);
            if (page < 1 || page > totalPages) return;
            leaderboardState.page = page;
            loadLeaderboard();
            document.getElementById('leaderboard-content').scrollIntoView({ behavior: 'smooth' });
        }

        function restartGame() {
            startGame(gameState.mode);
        }

        // ===== 键盘事件 =====
        document.getElementById('fill-input').addEventListener('keydown', function(e) {
            if (e.key === 'Enter') checkFillAnswer();
        });

        document.getElementById('feihua-input').addEventListener('keydown', function(e) {
            if (e.key === 'Enter') checkFeihuaAnswer();
        });

        document.getElementById('search-input').addEventListener('keydown', function(e) {
            if (e.key === 'Enter') performSearch();
        });

        // ===== 初始化 =====
        // ===== 语音朗读功能 =====
        let currentSpeakingBtn = null;

        function speakPoem(source) {
            if (!window.speechSynthesis) {
                alert('您的浏览器不支持语音朗读功能');
                return;
            }

            // 如果正在朗读，停止
            if (window.speechSynthesis.speaking) {
                window.speechSynthesis.cancel();
                if (currentSpeakingBtn) {
                    currentSpeakingBtn.classList.remove('speaking');
                    const textSpan = currentSpeakingBtn.querySelector('span:last-child');
                    if (textSpan) textSpan.textContent = source === 'home' ? '朗读' : '朗读这首诗';
                    currentSpeakingBtn = null;
                }
                return;
            }

            let textToSpeak = '';
            let btnId = '';

            if (source === 'home') {
                const poemEl = document.getElementById('random-poem');
                const infoEl = document.getElementById('random-poem-info');
                if (poemEl) textToSpeak = poemEl.innerText || poemEl.textContent;
                if (infoEl) textToSpeak += '\n' + (infoEl.textContent || '');
                btnId = 'home-speak-btn';
            } else if (source === 'modal') {
                const titleEl = document.getElementById('modal-title');
                const authorEl = document.getElementById('modal-author');
                const poemEl = document.getElementById('modal-poem-text');
                if (titleEl) textToSpeak = (titleEl.textContent || '') + '\n';
                if (poemEl) textToSpeak += (poemEl.innerText || poemEl.textContent || '');
                if (authorEl) textToSpeak += '\n' + (authorEl.textContent || '');
                btnId = 'modal-speak-btn';
            }

            if (!textToSpeak.trim()) return;

            textToSpeak = textToSpeak.replace(/\s+/g, '\n').trim();

            const utterance = new SpeechSynthesisUtterance(textToSpeak);
            utterance.lang = 'zh-CN';
            utterance.rate = 0.85;
            utterance.pitch = 1.0;
            utterance.volume = 1.0;

            const voices = window.speechSynthesis.getVoices();
            const zhVoice = voices.find(v => v.lang.startsWith('zh'));
            if (zhVoice) utterance.voice = zhVoice;

            if (btnId) {
                const btn = document.getElementById(btnId);
                if (btn) {
                    btn.classList.add('speaking');
                    btn.querySelector('span:last-child').textContent = '停止';
                    currentSpeakingBtn = btn;
                }
            }

            utterance.onend = function() {
                if (currentSpeakingBtn) {
                    currentSpeakingBtn.classList.remove('speaking');
                    const textSpan = currentSpeakingBtn.querySelector('span:last-child');
                    if (textSpan) textSpan.textContent = btnId === 'home-speak-btn' ? '朗读' : '朗读这首诗';
                    currentSpeakingBtn = null;
                }
            };

            utterance.onerror = function() {
                if (currentSpeakingBtn) {
                    currentSpeakingBtn.classList.remove('speaking');
                    const textSpan = currentSpeakingBtn.querySelector('span:last-child');
                    if (textSpan) textSpan.textContent = btnId === 'home-speak-btn' ? '朗读' : '朗读这首诗';
                    currentSpeakingBtn = null;
                }
            };

            window.speechSynthesis.speak(utterance);
        }

        // 预加载语音列表
        if (window.speechSynthesis) {
            window.speechSynthesis.onvoiceschanged = function() {
                window.speechSynthesis.getVoices();
            };
        }
        initCategoryList();
        showHome();
    </script>
</body>
</html>