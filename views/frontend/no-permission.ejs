<div class="container">
  <div class="no-permission-page">
    <div class="icon-wrapper">
      <svg xmlns="http://www.w3.org/2000/svg" width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="#e74c3c" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <circle cx="12" cy="12" r="10"></circle>
        <line x1="4.93" y1="4.93" x2="19.07" y2="19.07"></line>
      </svg>
    </div>
    <h1>无权访问</h1>
    <p class="perm-info">您没有访问此功能所需的权限：<strong><%= permName %></strong></p>
    <% if (permDesc) { %>
      <p class="perm-desc">权限说明：<%= permDesc %></p>
    <% } %>
    <div class="actions">
      <a href="/permissions/apply" class="btn btn-primary">申请权限</a>
      <a href="/" class="btn btn-secondary">返回首页</a>
    </div>
    <p class="help-text">如需访问此功能，请点击"申请权限"按钮提交申请，等待管理员审核</p>
  </div>
</div>

<style>
.no-permission-page {
  text-align: center;
  padding: 60px 20px;
  max-width: 500px;
  margin: 0 auto;
}

.icon-wrapper {
  margin-bottom: 24px;
}

.no-permission-page h1 {
  font-size: 28px;
  color: #333;
  margin-bottom: 16px;
}

.perm-info {
  font-size: 16px;
  color: #666;
  margin-bottom: 12px;
}

.perm-desc {
  font-size: 14px;
  color: #888;
  margin-bottom: 24px;
}

.actions {
  display: flex;
  gap: 12px;
  justify-content: center;
  margin-bottom: 24px;
}

.btn {
  padding: 10px 24px;
  border-radius: 6px;
  text-decoration: none;
  font-size: 14px;
  transition: all 0.2s;
}

.btn-primary {
  background: #3498db;
  color: #fff;
}

.btn-primary:hover {
  background: #2980b9;
}

.btn-secondary {
  background: #95a5a6;
  color: #fff;
}

.btn-secondary:hover {
  background: #7f8c8d;
}

.help-text {
  font-size: 13px;
  color: #999;
}
</style>
