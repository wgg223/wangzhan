<div class="container">
  <div class="chat-page">
    <div class="chat-header">
      <h1>私信</h1>
      <div class="chat-actions">
        <a href="/api/messages/settings" class="btn btn-settings" title="私信设置">⚙️</a>
      </div>
    </div>

    <div class="conversation-list" id="conversationList">
      <div class="loading">加载中...</div>
    </div>

    <div class="empty-state" id="emptyState" style="display: none;">
      <div class="empty-icon">💬</div>
      <h3>暂无私信</h3>
      <p>与其他用户互动后，可以在这里发送私信</p>
    </div>
  </div>
</div>

<!-- 私信设置弹窗 -->
<div id="settingsModal" class="modal-overlay" style="display: none;">
  <div class="modal-content">
    <div class="modal-header">
      <h3>私信设置</h3>
      <button class="modal-close" onclick="closeSettingsModal()">&times;</button>
    </div>
    <div class="modal-body">
      <p>谁可以给我发私信：</p>
      <div class="settings-options">
        <label class="radio-item">
          <input type="radio" name="allow_from" value="all">
          <span>所有人</span>
        </label>
        <label class="radio-item">
          <input type="radio" name="allow_from" value="following">
          <span>我关注的人</span>
        </label>
        <label class="radio-item">
          <input type="radio" name="allow_from" value="mutual">
          <span>互关好友</span>
        </label>
      </div>
    </div>
    <div class="modal-footer">
      <button class="btn btn-primary" onclick="saveSettings()">保存</button>
      <button class="btn" onclick="closeSettingsModal()">取消</button>
    </div>
  </div>
</div>

<style>
.chat-page {
  max-width: 600px;
  margin: 0 auto;
  padding: 20px;
}

.chat-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20px;
}

.chat-header h1 {
  font-size: 24px;
  margin: 0;
}

.btn-settings {
  background: #f0f0f0;
  border: none;
  width: 40px;
  height: 40px;
  border-radius: 50%;
  font-size: 20px;
  cursor: pointer;
  text-decoration: none;
  display: flex;
  align-items: center;
  justify-content: center;
}

.conversation-list {
  background: #fff;
  border-radius: 12px;
  overflow: hidden;
  box-shadow: 0 2px 8px rgba(0,0,0,0.08);
}

.conv-item {
  display: flex;
  align-items: center;
  padding: 16px;
  border-bottom: 1px solid #f0f0f0;
  cursor: pointer;
  transition: background 0.2s;
  text-decoration: none;
  color: inherit;
}

.conv-item:hover {
  background: #f5f5f5;
}

.conv-item:last-child {
  border-bottom: none;
}

.conv-avatar {
  width: 50px;
  height: 50px;
  border-radius: 50%;
  object-fit: cover;
  margin-right: 12px;
  flex-shrink: 0;
}

.conv-info {
  flex: 1;
  min-width: 0;
}

.conv-name {
  font-weight: 600;
  margin-bottom: 4px;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.conv-time {
  font-size: 12px;
  color: #999;
  font-weight: normal;
}

.conv-preview {
  font-size: 14px;
  color: #666;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.conv-unread {
  background: #3498db;
  color: #fff;
  min-width: 20px;
  height: 20px;
  border-radius: 10px;
  font-size: 12px;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 6px;
  margin-left: 8px;
}

.loading {
  padding: 40px;
  text-align: center;
  color: #999;
}

.empty-state {
  text-align: center;
  padding: 60px 20px;
  background: #fff;
  border-radius: 12px;
  margin-top: 20px;
}

.empty-icon {
  font-size: 48px;
  margin-bottom: 16px;
}

.empty-state h3 {
  margin-bottom: 8px;
}

.empty-state p {
  color: #666;
}

.btn {
  padding: 10px 24px;
  border-radius: 8px;
  border: none;
  cursor: pointer;
  font-size: 14px;
}

.btn-primary {
  background: #3498db;
  color: #fff;
}

.btn-primary:hover {
  background: #2980b9;
}

.modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0,0,0,0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.modal-content {
  background: #fff;
  border-radius: 12px;
  width: 400px;
  max-width: 90%;
}

.modal-header {
  padding: 16px 20px;
  border-bottom: 1px solid #eee;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.modal-header h3 {
  margin: 0;
}

.modal-close {
  background: none;
  border: none;
  font-size: 24px;
  cursor: pointer;
  color: #999;
}

.modal-body {
  padding: 20px;
}

.settings-options {
  display: flex;
  flex-direction: column;
  gap: 12px;
  margin-top: 12px;
}

.radio-item {
  display: flex;
  align-items: center;
  gap: 8px;
  cursor: pointer;
}

.modal-footer {
  padding: 16px 20px;
  border-top: 1px solid #eee;
  display: flex;
  justify-content: flex-end;
  gap: 12px;
}

@media (max-width: 768px) {
  .chat-page {
    padding: 12px;
  }
  .chat-header h1 {
    font-size: 20px;
  }
  .conv-item {
    padding: 12px;
  }
  .conv-avatar {
    width: 42px;
    height: 42px;
  }
}

@media (max-width: 480px) {
  .chat-page {
    padding: 8px;
  }
  .conv-name {
    font-size: 14px;
  }
  .conv-preview {
    font-size: 13px;
  }
  .modal-content {
    width: 95%;
  }
}
</style>

<script>
document.addEventListener('DOMContentLoaded', function() {
  // 检查是否有 user 参数（从用户主页点击"发私信"过来）
  var urlParams = new URLSearchParams(window.location.search);
  var targetUserId = urlParams.get('user');
  
  if (targetUserId) {
    // 自动创建对话并跳转
    createConversationAndRedirect(parseInt(targetUserId));
  } else {
    loadConversations();
  }
  
  // 设置按钮
  var settingsBtn = document.querySelector('.btn-settings');
  if (settingsBtn) {
    settingsBtn.addEventListener('click', function(e) {
      e.preventDefault();
      openSettingsModal();
    });
  }
});

async function createConversationAndRedirect(targetUserId) {
  try {
    var res = await fetch('/api/messages/conversations', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ target_user_id: targetUserId })
    });
    var data = await res.json();
    
    if (data.success && data.data) {
      // 跳转到聊天页面
      window.location.href = '/chat/' + data.data.id;
    } else {
      alert(data.error || '无法创建对话');
      // 加载对话列表
      loadConversations();
    }
  } catch (err) {
    alert('创建对话失败');
    loadConversations();
  }
}

async function loadConversations() {
  try {
    var res = await fetch('/api/messages/conversations');
    var data = await res.json();
    var list = document.getElementById('conversationList');
    var emptyState = document.getElementById('emptyState');
    
    if (data.success && data.data && data.data.length > 0) {
      list.innerHTML = data.data.map(function(conv) {
        return '<a href="/chat/' + conv.id + '" class="conv-item">' +
          '<img src="' + (conv.other_avatar || '/assets/images/default-avatar.png') + '" alt="" class="conv-avatar">' +
          '<div class="conv-info">' +
            '<div class="conv-name">' +
              '<span>' + escapeHtml(conv.other_nickname || conv.other_username) + '</span>' +
              '<span class="conv-time">' + formatTime(conv.last_message_at) + '</span>' +
            '</div>' +
            '<div class="conv-preview">' + escapeHtml(conv.last_message || '暂无消息') + '</div>' +
          '</div>' +
          (conv.unread_count > 0 ? '<span class="conv-unread">' + conv.unread_count + '</span>' : '') +
        '</a>';
      }).join('');
    } else {
      list.style.display = 'none';
      emptyState.style.display = 'block';
    }
  } catch (err) {
    console.error('加载对话列表失败:', err);
  }
}

function formatTime(timeStr) {
  if (!timeStr) return '';
  var date = new Date(timeStr);
  var now = new Date();
  var diff = now - date;
  
  if (diff < 60000) return '刚刚';
  if (diff < 3600000) return Math.floor(diff / 60000) + '分钟前';
  if (diff < 86400000) return Math.floor(diff / 3600000) + '小时前';
  if (diff < 604800000) return Math.floor(diff / 86400000) + '天前';
  return date.toLocaleDateString('zh-CN');
}

function escapeHtml(text) {
  if (!text) return '';
  var div = document.createElement('div');
  div.textContent = text;
  return div.innerHTML;
}

async function openSettingsModal() {
  try {
    var res = await fetch('/api/messages/settings');
    var data = await res.json();
    if (data.success) {
      var radio = document.querySelector('input[name="allow_from"][value="' + data.data.allow_from + '"]');
      if (radio) radio.checked = true;
    }
  } catch (err) {}
  document.getElementById('settingsModal').style.display = 'flex';
}

function closeSettingsModal() {
  document.getElementById('settingsModal').style.display = 'none';
}

async function saveSettings() {
  var selected = document.querySelector('input[name="allow_from"]:checked');
  if (!selected) return;
  
  try {
    var res = await fetch('/api/messages/settings', {
      method: 'PUT',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ allow_from: selected.value })
    });
    var data = await res.json();
    if (data.success) {
      closeSettingsModal();
      alert('设置已保存');
    }
  } catch (err) {
    alert('保存失败');
  }
}

// 点击遮罩层关闭
document.getElementById('settingsModal').addEventListener('click', function(e) {
  if (e.target === this) closeSettingsModal();
});
</script>
