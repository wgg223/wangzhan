<%- include('../header') %>

<h2 style="margin-bottom: 20px;"><i class="fas fa-cog"></i> 图片分享管理</h2>

<div class="stats">
  <div class="stat-card">
    <div class="number"><%= stats.total %></div>
    <div class="label">总图片</div>
  </div>
  <div class="stat-card">
    <div class="number" style="color: #ffc107;"><%= stats.pending %></div>
    <div class="label">待审核</div>
  </div>
  <div class="stat-card">
    <div class="number" style="color: #28a745;"><%= stats.approved %></div>
    <div class="label">已通过</div>
  </div>
  <div class="stat-card">
    <div class="number" style="color: #dc3545;"><%= stats.rejected %></div>
    <div class="label">已驳回</div>
  </div>
  <div class="stat-card">
    <div class="number"><%= stats.users %></div>
    <div class="label">用户数</div>
  </div>
  <div class="stat-card">
    <div class="number"><%= stats.categories %></div>
    <div class="label">分类数</div>
  </div>
</div>

<div style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-bottom: 20px;">
  <a href="/image-share/admin/images?status=0" class="card" style="text-align: center; cursor: pointer; border-left: 4px solid #ffc107;">
    <i class="fas fa-clock" style="font-size: 24px; color: #ffc107;"></i>
    <h3 style="margin-top: 10px;">审核图片</h3>
  </a>
  <a href="/image-share/admin/categories" class="card" style="text-align: center; cursor: pointer; border-left: 4px solid #667eea;">
    <i class="fas fa-folder" style="font-size: 24px; color: #667eea;"></i>
    <h3 style="margin-top: 10px;">分类管理</h3>
  </a>
  <a href="/image-share/admin/users" class="card" style="text-align: center; cursor: pointer; border-left: 4px solid #28a745;">
    <i class="fas fa-users" style="font-size: 24px; color: #28a745;"></i>
    <h3 style="margin-top: 10px;">用户管理</h3>
  </a>
  <a href="/image-share/admin/settings" class="card" style="text-align: center; cursor: pointer; border-left: 4px solid #17a2b8;">
    <i class="fas fa-cog" style="font-size: 24px; color: #17a2b8;"></i>
    <h3 style="margin-top: 10px;">网站设置</h3>
  </a>
</div>

<div class="card">
  <h3 style="margin-bottom: 15px;"><i class="fas fa-history"></i> 最近操作日志</h3>
  <% if (recentLogs.length > 0) { %>
    <table>
      <thead>
        <tr>
          <th>管理员</th>
          <th>操作内容</th>
          <th>时间</th>
        </tr>
      </thead>
      <tbody>
        <% recentLogs.forEach(function(log) { %>
          <tr>
            <td><%= log.admin_name || '未知' %></td>
            <td><%= log.content %></td>
            <td style="color: #999; font-size: 12px;"><%= log.created_at %></td>
          </tr>
        <% }); %>
      </tbody>
    </table>
  <% } else { %>
    <p style="color: #999; text-align: center;">暂无操作日志</p>
  <% } %>
</div>

<%- include('../footer') %>