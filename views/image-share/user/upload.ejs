<%- include('../header') %>

<div style="margin-bottom: 20px;">
  <a href="/image-share/user" style="color: #667eea;"><i class="fas fa-arrow-left"></i> 返回我的图片</a>
  <span style="margin-left: 10px;">|</span>
  <a href="/image-share/user/upload-batch" style="color: #667eea; margin-left: 10px;"><i class="fas fa-images"></i> 批量上传</a>
</div>

<div class="card" style="max-width: 600px;">
  <h2 style="margin-bottom: 20px;"><i class="fas fa-upload"></i> 上传图片</h2>
  
  <% if (typeof error !== 'undefined' && error) { %>
    <div class="alert alert-danger"><%= error %></div>
  <% } %>
  
  <form method="POST" enctype="multipart/form-data">
    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
    <div class="form-group">
      <label>图片文件 <span style="color: red;">*</span></label>
      <input type="file" name="image" accept="image/*" required>
      <small style="color: #999;">支持 JPG、PNG、GIF 格式，最大 10MB</small>
    </div>
    <div class="form-group">
      <label>图片标题 <span style="color: red;">*</span></label>
      <input type="text" name="title" required maxlength="100" placeholder="请输入图片标题">
    </div>
    <div class="form-group">
      <label>图片描述</label>
      <textarea name="description" placeholder="请输入图片描述（选填）"></textarea>
    </div>
    <div class="form-group">
      <label>所属分类 <span style="color: red;">*</span></label>
      <select name="cate_id" required>
        <option value="">请选择分类</option>
        <% categories.forEach(function(cat) { %>
          <option value="<%= cat.id %>"><%= cat.name %></option>
        <% }); %>
      </select>
    </div>
    <button type="submit" class="btn btn-primary" style="width: 100%;"><i class="fas fa-upload"></i> 上传</button>
  </form>
</div>

<%- include('../footer') %>