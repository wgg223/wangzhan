<%- include('../header') %>

<div style="margin-bottom: 20px;">
  <a href="/image-share/user" style="color: #667eea;"><i class="fas fa-arrow-left"></i> 返回我的图片</a>
</div>

<div class="card" style="max-width: 500px;">
  <h2 style="margin-bottom: 20px;"><i class="fas fa-user-cog"></i> 个人资料</h2>
  
  <form method="POST">
    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
    <div class="form-group">
      <label>用户名</label>
      <input type="text" value="<%= userInfo.username %>" disabled style="background: #f5f5f5;">
    </div>
    <div class="form-group">
      <label>昵称</label>
      <input type="text" name="nickname" value="<%= userInfo.nickname || '' %>" placeholder="请输入昵称">
    </div>
    <div class="form-group">
      <label>邮箱</label>
      <input type="email" name="email" value="<%= userInfo.email || '' %>" placeholder="请输入邮箱">
    </div>
    <hr style="margin: 20px 0; border: none; border-top: 1px solid #eee;">
    <h3 style="margin-bottom: 15px; font-size: 16px;">修改密码</h3>
    <div class="form-group">
      <label>当前密码</label>
      <input type="password" name="current_password" placeholder="输入当前密码（修改密码时必填）">
    </div>
    <div class="form-group">
      <label>新密码</label>
      <input type="password" name="new_password" placeholder="输入新密码（留空则不修改）">
    </div>
    <button type="submit" class="btn btn-primary" style="width: 100%;"><i class="fas fa-save"></i> 保存修改</button>
  </form>
</div>

<%- include('../footer') %>