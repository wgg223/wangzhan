<%- include('../header') %>

<div style="margin-bottom: 20px;">
  <a href="/image-share/user" style="color: #667eea;"><i class="fas fa-arrow-left"></i> 返回我的图片</a>
  <span style="margin-left: 10px;">|</span>
  <a href="/image-share/user/upload" style="color: #667eea; margin-left: 10px;"><i class="fas fa-upload"></i> 单张上传</a>
</div>

<div class="card" style="max-width: 800px;">
  <h2 style="margin-bottom: 20px;"><i class="fas fa-images"></i> 批量上传图片</h2>
  
  <% if (typeof error !== 'undefined' && error) { %>
    <div class="alert alert-danger"><%= error %></div>
  <% } %>
  
  <form method="POST" enctype="multipart/form-data" id="uploadForm">
    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
    <div class="form-group">
      <label>选择图片文件 <span style="color: red;">*</span></label>
      <div style="border: 2px dashed #ddd; padding: 20px; text-align: center; border-radius: 8px; background: #f9f9f9;" id="dropZone">
        <input type="file" name="images" id="imageInput" accept="image/*" multiple style="display: none;">
        <div id="uploadPrompt">
          <i class="fas fa-cloud-upload-alt" style="font-size: 48px; color: #667eea;"></i>
          <p style="margin: 15px 0; color: #666;">点击选择文件或拖拽图片到此处</p>
          <p style="color: #999; font-size: 12px;">支持 JPG、PNG、GIF 格式，每张最大 10MB，最多 20 张</p>
        </div>
        <div id="previewArea" style="display: none;"></div>
      </div>
    </div>
    
    <div class="form-group">
      <label>图片标题（基础名称） <span style="color: red;">*</span></label>
      <input type="text" name="title" required maxlength="100" placeholder="例如：风景照，实际标题将是"风景照 (1)"、"风景照 (2)"等">
      <small style="color: #999;">实际标题 = 基础名称 + 序号</small>
    </div>
    
    <div class="form-group">
      <label>图片描述</label>
      <textarea name="description" rows="3" placeholder="所有图片将使用相同的描述（选填）"></textarea>
    </div>
    
    <div class="form-group">
      <label>所属分类 <span style="color: red;">*</span></label>
      <select name="cate_id" required>
        <option value="">请选择分类</option>
        <% categories.forEach(function(cat) { %>
          <option value="<%= cat.id %>"><%= cat.name %></option>
        <% }); %>
      </select>
    </div>
    
    <div style="display: flex; gap: 10px;">
      <button type="submit" class="btn btn-primary" style="flex: 1;" id="uploadBtn">
        <i class="fas fa-upload"></i> 开始上传
      </button>
      <button type="button" class="btn btn-secondary" onclick="clearSelection()">
        <i class="fas fa-times"></i> 清除选择
      </button>
    </div>
  </form>
</div>

<script>
// 文件选择预览
const dropZone = document.getElementById('dropZone');
const imageInput = document.getElementById('imageInput');
const previewArea = document.getElementById('previewArea');
const uploadPrompt = document.getElementById('uploadPrompt');
const uploadBtn = document.getElementById('uploadBtn');

// 点击触发文件选择
dropZone.addEventListener('click', () => imageInput.click());

// 文件选择
imageInput.addEventListener('change', handleFiles);

// 拖拽处理
dropZone.addEventListener('dragover', (e) => {
  e.preventDefault();
  dropZone.style.borderColor = '#667eea';
  dropZone.style.background = '#f0f0ff';
});

dropZone.addEventListener('dragleave', (e) => {
  e.preventDefault();
  dropZone.style.borderColor = '#ddd';
  dropZone.style.background = '#f9f9f9';
});

dropZone.addEventListener('drop', (e) => {
  e.preventDefault();
  dropZone.style.borderColor = '#ddd';
  dropZone.style.background = '#f9f9f9';
  
  const files = e.dataTransfer.files;
  if (files.length > 20) {
    alert('最多只能选择 20 张图片');
    return;
  }
  
  imageInput.files = files;
  handleFiles();
});

function handleFiles() {
  const files = Array.from(imageInput.files);
  
  if (files.length === 0) {
    previewArea.style.display = 'none';
    uploadPrompt.style.display = 'block';
    return;
  }
  
  // 验证文件类型和大小
  const validFiles = [];
  const errors = [];
  
  files.forEach(file => {
    const validTypes = ['image/jpeg', 'image/jpg', 'image/png', 'image/gif'];
    if (!validTypes.includes(file.type)) {
      errors.push(`${file.name}: 不支持的格式`);
      return;
    }
    if (file.size > 10 * 1024 * 1024) {
      errors.push(`${file.name}: 文件超过 10MB`);
      return;
    }
    validFiles.push(file);
  });
  
  if (errors.length > 0) {
    alert('以下文件无法上传：\n' + errors.join('\n'));
    imageInput.value = '';
    return;
  }
  
  // 显示预览
  uploadPrompt.style.display = 'none';
  previewArea.style.display = 'grid';
  previewArea.innerHTML = '';
  previewArea.style.gridTemplateColumns = 'repeat(auto-fill, minmax(120px, 1fr))';
  previewArea.style.gap = '10px';
  
  validFiles.forEach((file, index) => {
    const reader = new FileReader();
    reader.onload = (e) => {
      const div = document.createElement('div');
      div.style.cssText = 'position: relative; padding: 5px; border: 1px solid #ddd; border-radius: 4px;';
      div.innerHTML = `
        <img src="${e.target.result}" style="width: 100%; height: 100px; object-fit: cover; border-radius: 4px;">
        <div style="position: absolute; top: 5px; right: 5px; background: rgba(0,0,0,0.6); color: white; border-radius: 50%; width: 20px; height: 20px; display: flex; align-items: center; justify-content: center; font-size: 12px;">${index + 1}</div>
        <div style="font-size: 11px; color: #666; margin-top: 5px; text-align: center; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">${file.name}</div>
      `;
      previewArea.appendChild(div);
    };
    reader.readAsDataURL(file);
  });
  
  // 显示文件信息
  const infoDiv = document.createElement('div');
  infoDiv.style.cssText = 'grid-column: 1 / -1; text-align: center; padding: 10px; background: #e8f5e9; border-radius: 4px; color: #2e7d32;';
  infoDiv.innerHTML = `<strong>已选择 ${validFiles.length} 张图片</strong>`;
  previewArea.appendChild(infoDiv);
}

function clearSelection() {
  imageInput.value = '';
  previewArea.innerHTML = '';
  previewArea.style.display = 'none';
  uploadPrompt.style.display = 'block';
}

// 表单提交
document.getElementById('uploadForm').addEventListener('submit', function(e) {
  if (imageInput.files.length === 0) {
    e.preventDefault();
    alert('请选择要上传的图片');
    return;
  }
  
  if (imageInput.files.length > 20) {
    e.preventDefault();
    alert('最多只能上传 20 张图片');
    return;
  }
  
  uploadBtn.disabled = true;
  uploadBtn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> 上传中，请稍候...';
});
</script>

<%- include('../footer') %>
