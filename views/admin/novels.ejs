<div class="page-header">
  <h1>小说管理</h1>
  <div class="actions">
    <a href="/admin/novels/new" class="btn btn-primary">+ 新建小说</a>
  </div>
</div>

<% if (typeof success !== 'undefined' && success) { %>
  <div class="alert alert-success">操作成功</div>
<% } %>

<% if (typeof error !== 'undefined' && error) { %>
  <div class="alert alert-error"><%= error %></div>
<% } %>

<% if (novels && novels.length > 0) { %>
  <table class="admin-table">
    <thead>
      <tr>
        <th>封面</th>
        <th>标题</th>
        <th>作者</th>
        <th>章节数</th>
        <th>状态</th>
        <th>上传者</th>
        <th>创建时间</th>
        <th>操作</th>
      </tr>
    </thead>
    <tbody>
      <% novels.forEach(function(novel) { %>
        <tr>
          <td>
            <% if (novel.cover_image) { %>
              <img src="<%= novel.cover_image %>" alt="封面" style="width:50px;height:70px;object-fit:cover;border-radius:4px;">
            <% } else { %>
              <span style="color:var(--gray-400)">无封面</span>
            <% } %>
          </td>
          <td><strong><%= novel.title %></strong></td>
          <td><%= novel.author || '未知' %></td>
          <td><%= novel.chapter_count || 0 %> 章</td>
          <td>
            <span class="status-badge status-<%= novel.status %>">
              <%= novel.status === 'published' ? '已发布' : (novel.status === 'draft' ? '草稿' : novel.status) %>
            </span>
          </td>
          <td><%= novel.uploader_name || '未知' %></td>
          <td><%= new Date(novel.created_at).toLocaleDateString('zh-CN') %></td>
          <td class="actions">
            <a href="/admin/novels/edit/<%= novel.id %>" class="btn btn-small btn-primary">编辑</a>
            <form method="POST" action="/admin/novels/delete/<%= novel.id %>" class="inline-form" onsubmit="return confirm('确定要删除小说「<%= novel.title %>」吗？所有章节将一并删除。')">
              <input type="hidden" name="_csrf" value="<%= csrfToken %>">
              <button type="submit" class="btn btn-small btn-danger">删除</button>
            </form>
          </td>
        </tr>
      <% }); %>
    </tbody>
  </table>
<% } else { %>
  <div class="card" style="text-align:center;padding:60px 20px;color:var(--gray-400);">
    <p style="font-size:48px;margin-bottom:16px;">📚</p>
    <p>还没有小说，<a href="/admin/novels/new">新建第一部小说</a></p>
  </div>
<% } %>