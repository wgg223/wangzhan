        <div class="perm-group perm-group-leaderboard">
          <h3>🏆 排行榜权限</h3>
          <div class="perm-group-items">
            <% permissions.filter(function(p) { return p.perm_key.startsWith('leaderboard.'); }).forEach(function(perm) { %>
              <div class="perm-tree-item">
                <span class="perm-key"><%= perm.perm_key %></span>
                <span class="perm-name"><%= perm.perm_name %></span>
