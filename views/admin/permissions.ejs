<% var active = 'permissions' %>
<div class="admin-page">
  <div class="page-header">
    <h1>🔐 权限管理</h1>
  </div>
  
  <div class="alert alert-info">
    <span>💡</span> 权限管理说明：管理员无法直接授予用户权限，所有权限变更必须通过用户的权限申请流程。管理员可以撤销用户已有的权限。
  </div>

  <!-- 权限申请审核 -->
  <div class="section-card accent-warning">
    <div class="section-header bg-gradient-warning">
      <h2>📋 待审核的权限申请 <span class="badge badge-warning"><%= pendingApplications.length %></span></h2>
    </div>
    <div class="section-body">
      <% if (pendingApplications.length > 0) { %>
        <table class="admin-table">
          <thead>
            <tr>
              <th>申请人</th>
              <th>邮箱</th>
              <th>申请权限</th>
              <th>申请理由</th>
              <th>申请时间</th>
              <th>操作</th>
            </tr>
          </thead>
          <tbody>
            <% pendingApplications.forEach(function(app) { %>
              <tr>
                <td><strong><%= app.username %></strong></td>
                <td><%= app.email || '未填写' %></td>
                <td><span class="perm-tag perm-default"><%= app.perm_name || app.perm_key %></span></td>
                <td><%= app.reason || '无' %></td>
                <td><%= new Date(app.created_at).toLocaleString('zh-CN') %></td>
                <td class="actions">
                  <button class="btn btn-small btn-success" onclick="approveApplication(<%= app.id %>)">✓ 批准</button>
                  <button class="btn btn-small btn-danger" onclick="rejectApplication(<%= app.id %>)">✗ 拒绝</button>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      <% } else { %>
        <div class="empty-state">
          <span class="empty-state-icon">✅</span>
          <p class="empty-state-text">暂无待审核的权限申请</p>
        </div>
      <% } %>
    </div>
  </div>

  <!-- 用户权限管理 -->
  <div class="section-card accent-primary">
    <div class="section-header bg-gradient-primary">
      <h2>👥 用户权限管理</h2>
    </div>
    <div class="section-body">
      <div class="alert alert-warning">
        <span>⚠️</span> 注意：管理员无法直接授予用户权限，请引导用户提交权限申请。管理员可以撤销用户已有的权限。
      </div>
      <table class="admin-table">
        <thead>
          <tr>
            <th>用户</th>
            <th>邮箱</th>
            <th>角色</th>
            <th>状态</th>
            <th>已分配权限</th>
            <th>操作</th>
          </tr>
        </thead>
        <tbody>
          <% if (users.length > 0) { %>
            <% users.forEach(u => { %>
              <tr>
                <td><strong><%= u.username %></strong></td>
                <td><%= u.email || '未填写' %></td>
                <td>
                  <span class="role-badge role-<%= u.role %>">
                    <% if (u.role === 'super_admin') { %>👑 超级管理员<% } %>
                    <% if (u.role === 'admin') { %>🛡️ 管理员<% } %>
                    <% if (u.role === 'user') { %>👤 普通用户<% } %>
                    <% if (u.role === 'visitor') { %>👁️ 访客<% } %>
                  </span>
                </td>
                <td>
                  <span class="status-badge status-<%= u.status %>">
                    <% if (u.status === 'active') { %>✅ 已激活<% } %>
                    <% if (u.status === 'pending') { %>⏳ 待审核<% } %>
                    <% if (u.status === 'disabled') { %>🚫 已禁用<% } %>
                  </span>
                </td>
                <td>
                  <% if (u.role === 'super_admin') { %>
                    <span style="color: var(--success); font-weight: 500;">🔑 所有权限（超级管理员）</span>
                  <% } else { %>
                    <% var _pMap = typeof userPerms !== 'undefined' ? userPerms : {}; var _perms = _pMap[u.id] || [] %>
                    <% if (_perms.length > 0) { %>
                      <div class="perms-list">
                        <% _perms.forEach(function(pk) { %>
                          <% var permInfo = permissions.find(function(p) { return p.perm_key === pk; }); %>
                          <% var permCls = 'perm-default';
                             if (pk.startsWith('articles.') || pk.startsWith('novels.')) permCls = 'perm-article';
                             else if (pk.startsWith('image-share.')) permCls = 'perm-image';
                             else if (pk.startsWith('community.') || pk.startsWith('messages.')) permCls = 'perm-community';
                             else if (pk.startsWith('users.') || pk.startsWith('permissions.')) permCls = 'perm-admin';
                             else if (pk.startsWith('pages.') || pk.startsWith('settings.')) permCls = 'perm-system';
                             else if (pk.endsWith('.access') || pk.endsWith('.read')) permCls = 'perm-basic';
                          %>
                          <span class="perm-tag <%= permCls %>" title="<%= pk %>"><%= permInfo ? permInfo.perm_name : pk %></span>
                        <% }) %>
                      </div>
                    <% } else { %>
                      <span style="color: var(--gray-400); font-size: var(--text-sm);">无特殊权限</span>
                    <% } %>
                  <% } %>
                </td>
                <td class="actions">
                  <% if (u.role !== 'super_admin') { %>
                    <% var _pMap2 = typeof userPerms !== 'undefined' ? userPerms : {}; var _perms2 = _pMap2[u.id] || [] %>
                    <% if (_perms2.length > 0) { %>
                      <% 
                        var permNamesMap = {};
                        _perms2.forEach(function(pk) {
                          var pInfo = permissions.find(function(p) { return p.perm_key === pk; });
                          permNamesMap[pk] = pInfo ? pInfo.perm_name : pk;
                        });
                      %>
                      <button class="btn btn-small btn-danger" onclick="showRevokeModal(<%= u.id %>, this)" 
                        data-username="<%= u.username %>" 
                        data-perms="<%- encodeURIComponent(JSON.stringify(_perms2)) %>"
                        data-perm-names="<%- encodeURIComponent(JSON.stringify(permNamesMap)) %>">撤销权限</button>
                    <% } else { %>
                      <span style="color: var(--gray-400); font-size: var(--text-xs);">无权限可撤销</span>
                    <% } %>
                  <% } else { %>
                    <span style="color: var(--gray-400); font-size: var(--text-xs);">超级管理员</span>
                  <% } %>
                </td>
              </tr>
            <% }) %>
          <% } else { %>
            <tr>
              <td colspan="6" class="empty-row">暂无用户</td>
            </tr>
          <% } %>
        </tbody>
      </table>
    </div>
  </div>

  <!-- 权限列表 -->
