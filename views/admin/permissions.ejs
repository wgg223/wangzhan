              </div>
            <% }); %>
          </div>
        </div>
        
        <div class="perm-group perm-group-user">
          <h3>👥 用户管理权限</h3>
          <div class="perm-group-items">
            <% permissions.filter(function(p) { return p.perm_key.startsWith('users.'); }).forEach(function(perm) { %>
              <div class="perm-tree-item">
                <span class="perm-key"><%= perm.perm_key %></span>
                <span class="perm-name"><%= perm.perm_name %></span>
                <span class="perm-desc"><%= perm.description %></span>
              </div>
            <% }); %>
          </div>
        </div>
        
        <div class="perm-group perm-group-permission">
          <h3>🔐 权限管理权限</h3>
          <div class="perm-group-items">
            <% permissions.filter(function(p) { return p.perm_key.startsWith('permissions.'); }).forEach(function(perm) { %>
              <div class="perm-tree-item">
                <span class="perm-key"><%= perm.perm_key %></span>
                <span class="perm-name"><%= perm.perm_name %></span>
