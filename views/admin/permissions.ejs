  <!-- 历史申请记录 -->
  <div class="section-card accent-purple">
    <div class="section-header bg-gradient-purple">
      <h2>📜 申请历史记录</h2>
    </div>
    <div class="section-body">
      <% if (allApplications.length > 0) { %>
        <table class="admin-table">
          <thead>
            <tr>
              <th>申请人</th>
              <th>申请权限</th>
              <th>申请理由</th>
              <th>申请时间</th>
              <th>状态</th>
              <th>拒绝原因</th>
              <th>审核人</th>
            </tr>
          </thead>
          <tbody>
            <% allApplications.forEach(function(app) { %>
              <tr>
                <td><strong><%= app.username %></strong></td>
                <td><span class="perm-tag perm-default"><%= app.perm_name || app.perm_key %></span></td>
                <td><%= app.reason || '无' %></td>
                <td><%= new Date(app.created_at).toLocaleString('zh-CN') %></td>
                <td>
                  <span class="status-badge status-<%= app.status %>">
                    <% if (app.status === 'pending') { %>⏳ 待审核<% } %>
                    <% if (app.status === 'approved') { %>✅ 已批准<% } %>
                    <% if (app.status === 'rejected') { %>❌ 已拒绝<% } %>
                  </span>
                </td>
                <td><% if (app.status === 'rejected') { %><span style="color: var(--danger); font-size: var(--text-sm);"><%= app.reject_reason || '未填写' %></span><% } else { %><span style="color: var(--gray-300);">-</span><% } %></td>
                <td><%= app.reviewer_name || '-' %></td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      <% } else { %>
        <div class="empty-state">
          <span class="empty-state-icon">📭</span>
          <p class="empty-state-text">暂无申请记录</p>
        </div>
      <% } %>
    </div>
  </div>
</div>

<!-- 撤销权限弹窗 -->
<div id="revokeModal" class="modal-overlay" style="display: none;">
  <div class="modal-content">
    <div class="modal-header">
      <h3>撤销用户权限 - <span id="revokeUsername"></span></h3>
      <button class="modal-close" onclick="closeRevokeModal()">&times;</button>
    </div>
    <div class="modal-body">
      <input type="hidden" id="revokeUserId">
      <p>请选择要撤销的权限：</p>
      <div id="revokePermList" class="perm-checkboxes"></div>
    </div>
    <div class="modal-footer">
      <button class="btn btn-danger" onclick="confirmRevoke()">确认撤销</button>
      <button class="btn" onclick="closeRevokeModal()">取消</button>
    </div>
  </div>
</div>

<!-- 拒绝申请弹窗 -->
<div id="rejectModal" class="modal-overlay" style="display: none;">
  <div class="modal-content">
    <div class="modal-header">
      <h3>拒绝权限申请</h3>
      <button class="modal-close" onclick="closeRejectModal()">&times;</button>
    </div>
    <div class="modal-body">
      <input type="hidden" id="rejectApplicationId">
      <div class="form-group">
        <label>拒绝原因（可选）</label>
        <textarea id="rejectReasonInput" rows="4" placeholder="请输入拒绝原因，将展示给申请人..." style="width:100%;padding:10px;border:1px solid var(--gray-200);border-radius:var(--radius-sm);resize:vertical;font-family:inherit;"></textarea>
      </div>
    </div>
    <div class="modal-footer">
      <button class="btn btn-danger" onclick="confirmReject()">确认拒绝</button>
      <button class="btn" onclick="closeRejectModal()">取消</button>
    </div>
  </div>
</div>

<script>
function getCsrfToken() {
  var meta = document.querySelector('meta[name="csrf-token"]');
  return meta ? meta.getAttribute('content') : '';
}

// 显示撤销权限弹窗
function showRevokeModal(userId, btn) {
  var username = btn.getAttribute('data-username');
  var permsEncoded = btn.getAttribute('data-perms');
  var perms = JSON.parse(decodeURIComponent(permsEncoded));
  var permNamesEncoded = btn.getAttribute('data-perm-names');
  var permNames = permNamesEncoded ? JSON.parse(decodeURIComponent(permNamesEncoded)) : {};
  
  document.getElementById('revokeUserId').value = userId;
  document.getElementById('revokeUsername').textContent = username;
  
  var categories = {
    '访问权限': [],
    '用户功能': [],
    '后台管理': []
  };
  
  perms.forEach(function(permKey) {
    var displayName = permNames[permKey] || permKey;
    var item = { key: permKey, name: displayName };
    
    if (permKey.endsWith('.access')) {
      categories['访问权限'].push(item);
    } else if (permKey.includes('.manage') || permKey.includes('.review') || 
               permKey.includes('.categories') || permKey.includes('.users') ||
               permKey.includes('.role') || permKey.includes('.view') ||
               permKey.includes('.backup') || permKey.includes('.export') ||
               permKey.includes('.seo') || permKey.includes('.settings')) {
      categories['后台管理'].push(item);
    } else {
      categories['用户功能'].push(item);
    }
  });
  
  var permListHtml = '';
  Object.keys(categories).forEach(function(catName) {
    if (categories[catName].length > 0) {
      permListHtml += '<div class="perm-category"><strong>' + catName + '</strong></div>';
      categories[catName].forEach(function(perm) {
        permListHtml += '<div class="perm-item"><label><input type="checkbox" name="revoke_perms" value="' + perm.key + '"> ' + perm.name + ' <span class="perm-key">(' + perm.key + ')</span></label></div>';
      });
    }
  });
  
  document.getElementById('revokePermList').innerHTML = permListHtml;
  document.getElementById('revokeModal').style.display = 'flex';
}

function closeRevokeModal() {
  document.getElementById('revokeModal').style.display = 'none';
}

function confirmRevoke() {
  var userId = document.getElementById('revokeUserId').value;
  var checkboxes = document.querySelectorAll('input[name="revoke_perms"]:checked');
  
  if (checkboxes.length === 0) {
    alert('请选择要撤销的权限');
    return;
  }
  
  if (!confirm('确定要撤销选中的 ' + checkboxes.length + ' 个权限吗？')) {
    return;
  }
  
  var requests = [];
  checkboxes.forEach(function(cb) {
    requests.push(
      fetch('/admin/permissions/revoke', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
          'X-CSRF-Token': getCsrfToken()
        },
        body: JSON.stringify({
          user_id: userId,
          perm_key: cb.value,
          _csrf: getCsrfToken()
        })
      })
    );
  });
  
  Promise.all(requests).then(function() {
    location.reload();
  }).catch(function(err) {
    alert('撤销权限失败: ' + err.message);
  });
}

document.getElementById('revokeModal').addEventListener('click', function(e) {
  if (e.target === this) closeRevokeModal();
});
document.getElementById('rejectModal').addEventListener('click', function(e) {
  if (e.target === this) closeRejectModal();
});

function approveApplication(applicationId) {
  if (!confirm('确定批准此权限申请吗？')) return;

  fetch('/admin/permissions/approve', {
    method: 'POST',
    headers: {
      'Content-Type': 'application/json',
      'X-CSRF-Token': getCsrfToken()
    },
    body: JSON.stringify({ application_id: applicationId, _csrf: getCsrfToken() })
  })
  .then(function(response) { return response.json(); })
  .then(function(data) {
    if (data.success) {
      location.reload();
    } else {
      alert(data.error || '操作失败');
    }
  })
  .catch(function(err) {
    alert('操作失败: ' + err.message);
  });
}

function rejectApplication(applicationId) {
  document.getElementById('rejectApplicationId').value = applicationId;
  document.getElementById('rejectReasonInput').value = '';
  document.getElementById('rejectModal').style.display = 'flex';
}

function closeRejectModal() {
  document.getElementById('rejectModal').style.display = 'none';
}

function confirmReject() {
  var applicationId = document.getElementById('rejectApplicationId').value;
  var reason = document.getElementById('rejectReasonInput').value.trim();

  fetch('/admin/permissions/reject', {
    method: 'POST',
    headers: {
      'Content-Type': 'application/json',
      'X-CSRF-Token': getCsrfToken()
    },
    body: JSON.stringify({ application_id: applicationId, reason: reason, _csrf: getCsrfToken() })
  })
  .then(function(response) { return response.json(); })
  .then(function(data) {
    if (data.success) {
      location.reload();
    } else {
      alert(data.error || '操作失败');
    }
  })
  .catch(function(err) {
    alert('操作失败: ' + err.message);
  });
}
</script>

