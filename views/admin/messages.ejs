<% var active = 'messages' %>
<div class="admin-page">
  <div class="page-header">
    <h1>站内信管理</h1>
    <a href="/admin/messages/send" class="btn btn-primary">发送站内信</a>
  </div>

  <% if (typeof sent !== 'undefined' && sent) { %>
    <div class="alert alert-success">站内信已发送</div>
  <% } %>

  <% if (messages.length > 0) { %>
    <form action="/admin/messages/broadcast-delete" method="POST" id="messages-form">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
      <div style="margin-bottom: 10px;">
        <button type="button" class="btn btn-small" onclick="toggleSelectAll()">全选/取消</button>
        <button type="submit" class="btn btn-small btn-danger" onclick="return confirm('确定要删除选中的站内信吗？')">批量删除</button>
      </div>
      <table class="admin-table">
        <thead>
          <tr>
            <th style="width:40px;"><input type="checkbox" id="select-all" onclick="toggleSelectAll()"></th>
            <th>ID</th>
            <th>标题</th>
            <th>发送者</th>
            <th>接收者</th>
            <th>弹窗</th>
            <th>已读</th>
            <th>时间</th>
            <th>操作</th>
          </tr>
        </thead>
        <tbody>
          <% messages.forEach(function(msg) { %>
            <tr>
              <td><input type="checkbox" name="ids" value="<%= msg.id %>" class="msg-checkbox"></td>
              <td><%= msg.id %></td>
              <td><strong><%= msg.title %></strong></td>
              <td><%= msg.from_username || '系统' %></td>
              <td><%= msg.to_username || '用户已删除' %></td>
              <td><%= msg.is_popup ? '✅' : '—' %></td>
              <td><%= msg.is_read ? '✅' : '📩' %></td>
              <td><%= new Date(msg.created_at + 'Z').toLocaleString('zh-CN') %></td>
              <td>
                <form action="/admin/messages/delete/<%= msg.id %>" method="POST" style="display:inline;" onsubmit="return confirm('确定要删除这条站内信吗？')">
                  <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                  <button type="submit" class="btn btn-small btn-danger">删除</button>
                </form>
              </td>
            </tr>
          <% }); %>
        </tbody>
      </table>
    </form>
  <% } else { %>
    <div class="empty-state">
      <p>暂无站内信记录</p>
    </div>
  <% } %>
</div>

<script>
function toggleSelectAll() {
  var selectAll = document.getElementById('select-all');
  var checkboxes = document.querySelectorAll('.msg-checkbox');
  var newState = !selectAll.checked;
  selectAll.checked = newState;
  checkboxes.forEach(function(cb) { cb.checked = newState; });
}
</script>
