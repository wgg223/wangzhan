<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>后台管理 - 网站管理系统</title>
  <link rel="stylesheet" href="<%= typeof cdn !== 'undefined' ? cdn.getUrl('/css/admin.css') : '/css/admin.css' %>">
  <!-- Quill rich text editor CSS + JS - 使用本地版本，备用 CDN -->
  <link href="<%= typeof cdn !== 'undefined' ? cdn.getUrl('/vendor/quill/quill.snow.css') : '/vendor/quill/quill.snow.css' %>" rel="stylesheet" id="quill-css">
  <script src="<%= typeof cdn !== 'undefined' ? cdn.getUrl('/vendor/quill/quill.js') : '/vendor/quill/quill.js' %>"></script>
  <!-- 备用 CDN (如果本地加载失败) -->
  <script>
    if (typeof Quill === 'undefined') {
      var cssLink = document.createElement('link');
      cssLink.rel = 'stylesheet';
      cssLink.href = 'https://cdnjs.cloudflare.com/ajax/libs/quill/2.0.0/quill.snow.css';
      document.head.appendChild(cssLink);
      
      var scriptTag = document.createElement('script');
      scriptTag.src = 'https://cdnjs.cloudflare.com/ajax/libs/quill/2.0.0/quill.min.js';
      document.head.appendChild(scriptTag);
    }
  </script>
</head>
<body>
<%
  // 辅助函数：检查用户是否有某个模块的任意权限（前缀匹配）
  function hasPerm(permissions, permKey) {
    if (!permissions || !Array.isArray(permissions)) return false;
    if (permissions.indexOf(permKey) !== -1) return true;
    var prefix = permKey.split('.')[0] + '.';
    return permissions.some(function(key) { return key.indexOf(prefix) === 0; });
  }
%>
<div class="admin-container">
    <aside class="sidebar">
      <div class="sidebar-header">
        <h2>后台管理</h2>
      </div>
      <nav class="sidebar-nav">
        <ul>
          <% if (user.role === 'super_admin') { %>
          <li><a href="/admin">📊 仪表盘</a></li>
          <% } %>
          <% if (user.role === 'super_admin') { %>
          <li><a href="/admin/activity-logs">📋 操作日志</a></li>
          <% } %>
          <% if (typeof userPermissions !== 'undefined' && hasPerm(userPermissions, 'pages.manage')) { %>
          <li><a href="/admin/pages">📄 页面管理</a></li>
          <% } %>
          <% if (typeof userPermissions !== 'undefined' && hasPerm(userPermissions, 'articles.manage')) { %>
          <li><a href="/admin/articles">📝 文章管理</a></li>
          <% } %>
          <% if (typeof userPermissions !== 'undefined' && hasPerm(userPermissions, 'novels.manage')) { %>
          <li><a href="/admin/novels">📚 小说管理</a></li>
          <% } %>
          <% if (typeof userPermissions !== 'undefined' && hasPerm(userPermissions, 'users.manage')) { %>
          <li><a href="/admin/users">👥 用户管理</a></li>
          <% } %>
          <% if (typeof userPermissions !== 'undefined' && hasPerm(userPermissions, 'permissions.manage')) { %>
          <li><a href="/admin/permissions">🔐 权限管理</a></li>
          <% } %>
          <% if (typeof userPermissions !== 'undefined' && hasPerm(userPermissions, 'comments.manage')) { %>
          <li><a href="/admin/comments">💬 评论管理</a></li>
          <% } %>
          <% if (typeof userPermissions !== 'undefined' && hasPerm(userPermissions, 'messages.manage')) { %>
          <li><a href="/admin/messages">📬 站内信</a></li>
          <% } %>
          <% if (typeof userPermissions !== 'undefined' && hasPerm(userPermissions, 'leaderboard.manage')) { %>
          <li><a href="/admin/leaderboard">🏆 排行榜</a></li>
          <% } %>
          <% if (typeof userPermissions !== 'undefined' && hasPerm(userPermissions, 'image-share.manage')) { %>
          <li><a href="/admin/image-share">🖼️ 图片分享</a></li>
          <% } %>
          <% if (typeof userPermissions !== 'undefined' && hasPerm(userPermissions, 'settings.manage')) { %>
          <li><a href="/admin/settings/basic">⚙️ 基础设置</a></li>
          <li><a href="/admin/settings/smtp">📧 SMTP配置</a></li>
          <li><a href="/admin/settings/agreement">📄 协议设置</a></li>
          <li><a href="/admin/settings/popup">🪟 弹窗设置</a></li>
          <li><a href="/admin/settings">🚀 CDN设置</a></li>
          <% } %>
          <% if (typeof userPermissions !== 'undefined' && hasPerm(userPermissions, 'settings.manage')) { %>
          <li><a href="/admin/system-update">🔄 系统更新</a></li>
          <% } %>
          <% if (typeof userPermissions !== 'undefined' && hasPerm(userPermissions, 'data.manage')) { %>
            <li><a href="/admin/backup">💾 备份管理</a></li>
          <% } %>
          <% if (user.role === 'super_admin') { %>
            <li><a href="/admin/backup">💾 备份管理</a></li>
            <li><a href="/admin/maintenance">🔧 服务器维护</a></li>
            <li><a href="/admin/projects">📦 项目管理</a></li>
            <li><a href="/admin/reset" style="color:#ef4444;">⚠️ 重置服务器</a></li>
          <% } %>
        </ul>
      </nav>
      <div class="sidebar-footer">
        <p>当前用户：<%= user.username %></p>
        <a href="/admin/profile">账户设置</a>
        <a href="/auth/logout">退出登录</a>
        <a href="/" target="_blank">查看网站</a>
      </div>
    </aside>
    <main class="admin-main">
      <%- body %>
    </main>
  </div>
  <script>
  window.addEventListener('load', function() {
    if (typeof Quill === 'undefined') {
      console.warn('Quill编辑器CDN加载失败，编辑器功能将不可用');
      document.querySelectorAll('#editor-container').forEach(function(el) {
        el.innerHTML = '<div style="padding:20px;color:#999;text-align:center;">⚠️ 编辑器组件加载失败，请刷新页面重试</div>';
      });
    }
  });
  </script>
  <script src="<%= typeof cdn !== 'undefined' ? cdn.getUrl('/js/admin.js') : '/js/admin.js' %>"></script>
</body>
</html>