<% var active = 'maintenance' %>
<div class="admin-page">
  <div class="page-header">
    <h1>🔧 服务器维护</h1>
    <p class="page-desc">管理服务器维护模式和系统工具</p>
  </div>

  <div class="settings-section">
    <h2>维护状态</h2>
    <div class="card">
      <div class="maintenance-status" id="statusDisplay">
        <div class="status-icon" id="statusIcon">🟢</div>
        <div class="status-info">
          <h3 id="statusTitle">当前状态：正常运行</h3>
          <p id="statusDesc" class="text-muted">网站可正常访问</p>
        </div>
        <div class="status-badge" id="statusBadge">运行中</div>
      </div>
    </div>
  </div>

  <div class="settings-section">
    <h2>维护设置</h2>
    <div class="card">
      <div class="form-group">
        <label>维护模式</label>
        <div class="toggle-row">
          <label class="toggle-switch">
            <input type="checkbox" id="maintenanceEnabled" <%= settings.maintenance_mode === 'true' ? 'checked' : '' %>>
            <span class="toggle-slider"></span>
          </label>
          <span class="toggle-label" id="toggleLabel"><%= settings.maintenance_mode === 'true' ? '已开启' : '已关闭' %></span>
        </div>
        <p class="help-text">开启后，前端页面将显示维护页面，只有管理员可以访问后台</p>
      </div>

      <div class="form-group">
        <label for="maintenanceTitle">维护标题</label>
        <input type="text" id="maintenanceTitle" class="form-control" value="<%= settings.maintenance_title || '系统维护中' %>" placeholder="系统维护中">
      </div>

      <div class="form-group">
        <label for="maintenanceMessage">维护消息</label>
        <textarea id="maintenanceMessage" class="form-control" rows="3" placeholder="系统正在进行维护升级，请稍后再试。"><%= settings.maintenance_message || '系统正在进行维护升级，请稍后再试。' %></textarea>
      </div>

      <div class="form-actions">
        <button type="button" class="btn btn-primary" id="saveBtn" onclick="saveMaintenance()">
          <span class="btn-text">保存设置</span>
          <span class="btn-loading" style="display: none;">保存中...</span>
        </button>
        <button type="button" class="btn" id="toggleBtn" onclick="toggleMaintenance()">
          <span class="btn-text" id="toggleBtnText"><%= settings.maintenance_mode === 'true' ? '关闭维护模式' : '开启维护模式' %></span>
          <span class="btn-loading" style="display: none;">处理中...</span>
        </button>
      </div>

      <div id="saveStatus" class="status-msg" style="display: none;"></div>
    </div>
  </div>

  <div class="settings-section">
    <h2>系统工具</h2>
    <div class="tools-grid">
      <div class="tool-card">
        <div class="tool-header">
          <span class="tool-icon">🗑️</span>
          <div>
            <h3>清除缓存</h3>
            <p>清除所有内存缓存（设置/查询/页面）</p>
          </div>
        </div>
        <button type="button" class="btn btn-warning btn-sm" onclick="runTool('clear-cache', this)">
          <span class="btn-text">清除缓存</span>
          <span class="btn-loading" style="display: none;">处理中...</span>
        </button>
      </div>

      <div class="tool-card">
        <div class="tool-header">
          <span class="tool-icon">📁</span>
          <div>
            <h3>清理临时文件</h3>
            <p>清理临时目录和过期日志文件</p>
          </div>
        </div>
        <button type="button" class="btn btn-warning btn-sm" onclick="runTool('clean-temp', this)">
          <span class="btn-text">清理临时文件</span>
          <span class="btn-loading" style="display: none;">处理中...</span>
        </button>
      </div>

      <div class="tool-card">
        <div class="tool-header">
          <span class="tool-icon">📊</span>
          <div>
            <h3>优化数据库</h3>
            <p>运行 VACUUM 命令压缩数据库文件</p>
          </div>
        </div>
        <button type="button" class="btn btn-warning btn-sm" onclick="runTool('optimize-db', this)">
          <span class="btn-text">优化数据库</span>
          <span class="btn-loading" style="display: none;">处理中...</span>
        </button>
      </div>

      <div class="tool-card">
        <div class="tool-header">
          <span class="tool-icon">📋</span>
          <div>
            <h3>清理活动日志</h3>
            <p>清理指定天数前的日志记录</p>
          </div>
        </div>
        <div class="tool-actions">
          <select id="logDays" class="form-control" style="width: auto;">
            <option value="7">7天前</option>
            <option value="30" selected>30天前</option>
            <option value="90">90天前</option>
            <option value="180">180天前</option>
          </select>
          <button type="button" class="btn btn-warning btn-sm" onclick="cleanLogs(this)">
            <span class="btn-text">清理日志</span>
            <span class="btn-loading" style="display: none;">处理中...</span>
          </button>
        </div>
      </div>
    </div>
    <div id="toolStatus" class="status-msg" style="display: none; margin-top: 16px;"></div>
  </div>

  <div class="settings-section">
    <h2>备份管理</h2>
    <div class="card">
      <div class="form-group">
        <label>手动备份</label>
        <div class="backup-row">
          <select id="backupType" class="form-control" style="width: auto; min-width: 160px;">
            <option value="database">数据库备份</option>
            <option value="uploads">上传文件备份</option>
            <option value="config">配置文件备份</option>
            <option value="full">完整备份</option>
          </select>
          <label class="checkbox-label">
            <input type="checkbox" id="backupSendEmail"> 发送邮件通知
          </label>
          <button type="button" class="btn btn-primary" onclick="backupNow(this)">
            <span class="btn-text">立即备份</span>
            <span class="btn-loading" style="display: none;">备份中...</span>
          </button>
        </div>
        <div id="backupStatus" class="status-msg" style="display: none; margin-top: 12px;"></div>
      </div>

      <div class="divider"></div>

      <div class="form-group">
        <label>定时备份</label>
        <div class="toggle-row">
          <label class="toggle-switch">
            <input type="checkbox" id="scheduledBackupEnabled">
            <span class="toggle-slider"></span>
          </label>
          <span class="toggle-label" id="scheduledToggleLabel">已关闭</span>
        </div>
        <div class="scheduled-settings" id="scheduledSettings">
          <div class="form-row">
            <div class="form-group">
              <label for="scheduledCron">Cron 表达式</label>
              <input type="text" id="scheduledCron" class="form-control" value="0 3 * * *" placeholder="0 3 * * *">
              <p class="help-text">默认每天凌晨3点。格式：分 时 日 月 周</p>
            </div>
            <div class="form-group">
              <label for="scheduledType">备份类型</label>
              <select id="scheduledType" class="form-control">
                <option value="database">数据库备份</option>
                <option value="uploads">上传文件备份</option>
                <option value="config">配置文件备份</option>
                <option value="full">完整备份</option>
              </select>
            </div>
          </div>
          <div class="form-group">
            <label for="scheduledNotifyEmail">通知邮箱</label>
            <input type="email" id="scheduledNotifyEmail" class="form-control" placeholder="admin@example.com">
            <p class="help-text">备份完成后发送通知邮件（需配置SMTP）</p>
          </div>
          <button type="button" class="btn btn-primary" onclick="saveScheduledBackup(this)">
            <span class="btn-text">保存定时备份设置</span>
            <span class="btn-loading" style="display: none;">保存中...</span>
          </button>
        </div>
        <div id="scheduledStatus" class="status-msg" style="display: none; margin-top: 12px;"></div>
      </div>
    </div>
  </div>

  <div class="settings-section">
    <h2>系统信息</h2>
    <div class="card">
      <button type="button" class="btn btn-info btn-sm" onclick="loadSystemInfo()" style="margin-bottom: 16px;">
        <span class="btn-text">刷新系统信息</span>
      </button>
      <div id="systemInfo" class="system-info-grid">
        <div class="info-loading">加载中...</div>
      </div>
    </div>
  </div>

  <div class="settings-section">
    <h2>说明</h2>
    <div class="card">
      <ul class="info-list">
        <li>开启维护模式后，前端所有页面将显示维护页面</li>
        <li>管理员仍然可以正常访问后台管理面板</li>
        <li>健康检查接口 (<code>/health</code>) 不受影响</li>
        <li>静态资源和 API 请求不受影响</li>
        <li>关闭维护模式后，前端立即恢复正常访问</li>
      </ul>
    </div>
  </div>
</div>

<style>
.maintenance-status {
  display: flex;
  align-items: center;
  gap: 16px;
  padding: 16px;
  border-radius: var(--radius-md);
  transition: var(--transition-base);
}
.maintenance-status.active {
  background: var(--warning-bg);
  border: 1px solid var(--warning-border);
}
.maintenance-status.inactive {
  background: var(--success-bg);
  border: 1px solid var(--success-border);
}
.status-icon { font-size: 40px; }
.status-info { flex: 1; }
.status-info h3 { margin: 0 0 4px; font-size: 16px; color: var(--text-primary); }
.status-info p { margin: 0; font-size: 13px; color: var(--text-muted); }
.status-badge {
  padding: 4px 12px;
  border-radius: var(--radius-full);
  font-size: 12px;
  font-weight: 600;
}
.maintenance-status.active .status-badge {
  background: var(--warning);
  color: #fff;
}
.maintenance-status.inactive .status-badge {
  background: var(--success);
  color: #fff;
}

.toggle-row {
  display: flex;
  align-items: center;
  gap: 12px;
  margin-bottom: 8px;
}
.toggle-switch {
  position: relative;
  display: inline-block;
  width: 48px;
  height: 26px;
}
.toggle-switch input { opacity: 0; width: 0; height: 0; }
.toggle-slider {
  position: absolute;
  cursor: pointer;
  inset: 0;
  background: var(--gray-300);
  transition: var(--transition-base);
  border-radius: 26px;
}
.toggle-slider:before {
  position: absolute;
  content: "";
  height: 20px;
  width: 20px;
  left: 3px;
  bottom: 3px;
  background: #fff;
  transition: var(--transition-base);
  border-radius: 50%;
}
input:checked + .toggle-slider { background: var(--danger); }
input:checked + .toggle-slider:before { transform: translateX(22px); }
.toggle-label { font-weight: 500; color: var(--text-primary); font-size: 14px; }

.help-text { font-size: 12px; color: var(--text-muted); margin-top: 4px; }
.text-muted { color: var(--text-muted); }

.tools-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
  gap: 16px;
}
.tool-card {
  background: var(--bg-card);
  border: 1px solid var(--border-color);
  border-radius: var(--radius-md);
  padding: 16px;
  display: flex;
  flex-direction: column;
  gap: 12px;
  transition: var(--transition-base);
}
.tool-card:hover { box-shadow: var(--shadow-md); }
.tool-header { display: flex; align-items: flex-start; gap: 12px; }
.tool-icon { font-size: 28px; flex-shrink: 0; }
.tool-header h3 { margin: 0 0 4px; font-size: 14px; color: var(--text-primary); }
.tool-header p { margin: 0; font-size: 12px; color: var(--text-muted); line-height: 1.5; }
.tool-actions { display: flex; align-items: center; gap: 8px; }
.tool-actions .form-control { flex: 1; }

.backup-row { display: flex; align-items: center; gap: 12px; flex-wrap: wrap; }
.checkbox-label {
  display: flex;
  align-items: center;
  gap: 6px;
  font-size: 13px;
  cursor: pointer;
  color: var(--text-secondary);
}
.checkbox-label input[type="checkbox"] { width: 16px; height: 16px; accent-color: var(--primary); }

.divider {
  height: 1px;
  background: var(--border-color);
  margin: 20px 0;
}

.scheduled-settings {
  margin-top: 16px;
  padding: 16px;
  background: var(--gray-50);
  border-radius: var(--radius-md);
  border: 1px solid var(--border-color);
}

.form-row {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16px;
}

.version-row {
  display: flex;
  gap: 32px;
  margin-bottom: 16px;
}
.version-item { display: flex; flex-direction: column; }
.version-label { font-size: 12px; color: var(--text-muted); margin-bottom: 4px; }
.version-value { font-size: 20px; font-weight: 700; color: var(--text-primary); }

.update-status {
  padding: 10px 14px;
  border-radius: var(--radius-sm);
  margin-bottom: 12px;
  background: var(--gray-50);
  font-size: 13px;
  color: var(--text-secondary);
}
.update-status.has-update {
  background: var(--warning-bg);
  border: 1px solid var(--warning-border);
  color: var(--warning-dark);
}
.update-status.no-update {
  background: var(--success-bg);
  border: 1px solid var(--success-border);
  color: var(--success-dark);
}

.release-info {
  background: var(--gray-50);
  border-radius: var(--radius-sm);
  padding: 14px;
  margin-bottom: 12px;
  border: 1px solid var(--border-color);
}
.release-info h4 { margin: 0 0 8px; font-size: 14px; color: var(--text-primary); }
.release-meta { font-size: 12px; color: var(--text-muted); margin-bottom: 10px; }
.release-body { font-size: 13px; line-height: 1.6; color: var(--text-secondary); white-space: pre-wrap; }

.system-info-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
  gap: 12px;
}
.info-section {
  background: var(--gray-50);
  border: 1px solid var(--border-color);
  border-radius: var(--radius-sm);
  padding: 14px;
}
.info-section h4 {
  margin: 0 0 10px;
  font-size: 13px;
  color: var(--text-primary);
  border-bottom: 1px solid var(--border-color);
  padding-bottom: 8px;
}
.info-row {
  display: flex;
  justify-content: space-between;
  margin-bottom: 6px;
  font-size: 12px;
}
.info-row .label { color: var(--text-muted); }
.info-row .value { color: var(--text-primary); font-weight: 500; }
.info-loading {
  grid-column: 1 / -1;
  text-align: center;
  padding: 20px;
  color: var(--text-muted);
  font-size: 13px;
}

.info-list {
  margin: 0;
  padding-left: 20px;
  color: var(--text-secondary);
  line-height: 1.8;
  font-size: 13px;
}
.info-list code {
  background: var(--gray-100);
  padding: 2px 6px;
  border-radius: 4px;
  font-size: 12px;
  color: var(--primary);
}

.status-msg { margin-top: 12px; }

@media (max-width: 768px) {
  .tools-grid { grid-template-columns: 1fr; }
  .form-row { grid-template-columns: 1fr; }
  .backup-row { flex-direction: column; align-items: stretch; }
  .version-row { flex-direction: column; gap: 12px; }
}
</style>

<script>
function getCsrfToken() {
  const meta = document.querySelector('meta[name="csrf-token"]');
  return meta ? meta.getAttribute('content') : '';
}

function updateStatusDisplay(enabled) {
  const display = document.getElementById('statusDisplay');
  const icon = document.getElementById('statusIcon');
  const title = document.getElementById('statusTitle');
  const desc = document.getElementById('statusDesc');
  const badge = document.getElementById('statusBadge');
  const toggleLabel = document.getElementById('toggleLabel');
  const toggleBtnText = document.getElementById('toggleBtnText');

  if (enabled) {
    display.className = 'maintenance-status active';
    icon.textContent = '🔴';
    title.textContent = '当前状态：维护中';
    desc.textContent = '前端页面显示维护页面，仅管理员可访问后台';
    badge.textContent = '维护中';
    toggleLabel.textContent = '已开启';
    toggleBtnText.textContent = '关闭维护模式';
  } else {
    display.className = 'maintenance-status inactive';
    icon.textContent = '🟢';
    title.textContent = '当前状态：正常运行';
    desc.textContent = '网站可正常访问';
    badge.textContent = '运行中';
    toggleLabel.textContent = '已关闭';
    toggleBtnText.textContent = '开启维护模式';
  }
}

updateStatusDisplay(document.getElementById('maintenanceEnabled').checked);
document.getElementById('maintenanceEnabled').addEventListener('change', function() {
  updateStatusDisplay(this.checked);
});

function setBtnLoading(btn, loading) {
  const text = btn.querySelector('.btn-text');
  const spinner = btn.querySelector('.btn-loading');
  btn.disabled = loading;
  if (text) text.style.display = loading ? 'none' : '';
  if (spinner) spinner.style.display = loading ? 'inline' : 'none';
}

function showStatus(el, type, msg) {
  el.style.display = 'block';
  const cls = type === 'success' ? 'alert-success' : type === 'error' ? 'alert-error' : 'alert-info';
  el.innerHTML = '<div class="alert ' + cls + '">' + msg + '</div>';
  if (type !== 'info') {
    setTimeout(() => { el.style.display = 'none'; }, 5000);
  }
}

async function saveMaintenance() {
  const btn = document.getElementById('saveBtn');
  const status = document.getElementById('saveStatus');
  const enabled = document.getElementById('maintenanceEnabled').checked;
  const title = document.getElementById('maintenanceTitle').value;
  const message = document.getElementById('maintenanceMessage').value;

  setBtnLoading(btn, true);
  showStatus(status, 'info', '保存中...');

  try {
    const res = await fetch('/admin/maintenance/update', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', 'CSRF-Token': getCsrfToken(), 'X-Requested-With': 'XMLHttpRequest' },
      body: JSON.stringify({ enabled, title, message })
    });
    const result = await res.json();
    if (result.success) {
      showStatus(status, 'success', result.message);
      updateStatusDisplay(enabled);
    } else {
      showStatus(status, 'error', result.error);
    }
  } catch (err) {
    showStatus(status, 'error', '请求失败: ' + err.message);
  } finally {
    setBtnLoading(btn, false);
  }
}

async function toggleMaintenance() {
  const btn = document.getElementById('toggleBtn');
  const status = document.getElementById('saveStatus');
  const checkbox = document.getElementById('maintenanceEnabled');
  const newEnabled = !checkbox.checked;
  const title = document.getElementById('maintenanceTitle').value;
  const message = document.getElementById('maintenanceMessage').value;

  setBtnLoading(btn, true);
  showStatus(status, 'info', '处理中...');

  try {
    const res = await fetch('/admin/maintenance/update', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', 'CSRF-Token': getCsrfToken(), 'X-Requested-With': 'XMLHttpRequest' },
      body: JSON.stringify({ enabled: newEnabled, title, message })
    });
    const result = await res.json();
    if (result.success) {
      checkbox.checked = newEnabled;
      updateStatusDisplay(newEnabled);
      showStatus(status, 'success', result.message);
    } else {
      showStatus(status, 'error', result.error);
    }
  } catch (err) {
    showStatus(status, 'error', '请求失败: ' + err.message);
  } finally {
    setBtnLoading(btn, false);
  }
}

async function runTool(action, btn) {
  if (!confirm('确定要执行此操作吗？')) return;
  const status = document.getElementById('toolStatus');
  setBtnLoading(btn, true);
  showStatus(status, 'info', '处理中...');

  try {
    const res = await fetch('/admin/maintenance/' + action, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', 'CSRF-Token': getCsrfToken(), 'X-Requested-With': 'XMLHttpRequest' }
    });
    const result = await res.json();
    if (result.success) {
      const msg = result.saved ? result.message + ' (释放 ' + result.saved + ')' : result.message;
      showStatus(status, 'success', msg);
    } else {
      showStatus(status, 'error', result.error);
    }
  } catch (err) {
    showStatus(status, 'error', '请求失败: ' + err.message);
  } finally {
    setBtnLoading(btn, false);
  }
}

async function cleanLogs(btn) {
  if (!confirm('确定要清理活动日志吗？')) return;
  const status = document.getElementById('toolStatus');
  const days = document.getElementById('logDays').value;

  setBtnLoading(btn, true);
  showStatus(status, 'info', '清理日志中...');

  try {
    const res = await fetch('/admin/maintenance/clean-logs', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', 'CSRF-Token': getCsrfToken(), 'X-Requested-With': 'XMLHttpRequest' },
      body: JSON.stringify({ days: parseInt(days) })
    });
    const result = await res.json();
    if (result.success) {
      showStatus(status, 'success', result.message + '，删除 ' + result.deleted + ' 条记录');
    } else {
      showStatus(status, 'error', result.error);
    }
  } catch (err) {
    showStatus(status, 'error', '请求失败: ' + err.message);
  } finally {
    setBtnLoading(btn, false);
  }
}

async function backupNow(btn) {
  const status = document.getElementById('backupStatus');
  const type = document.getElementById('backupType').value;
  const sendEmail = document.getElementById('backupSendEmail').checked;

  setBtnLoading(btn, true);
  showStatus(status, 'info', '备份中...');

  try {
    const res = await fetch('/admin/maintenance/backup-now', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', 'CSRF-Token': getCsrfToken(), 'X-Requested-With': 'XMLHttpRequest' },
      body: JSON.stringify({ type, sendNotification: sendEmail })
    });
    const result = await res.json();
    if (result.success) {
      showStatus(status, 'success', result.message + ' (大小: ' + result.size + ')');
    } else {
      showStatus(status, 'error', result.error);
    }
  } catch (err) {
    showStatus(status, 'error', '请求失败: ' + err.message);
  } finally {
    setBtnLoading(btn, false);
  }
}

async function loadScheduledBackup() {
  try {
    const res = await fetch('/admin/maintenance/scheduled-backup', {
      headers: { 'CSRF-Token': getCsrfToken(), 'X-Requested-With': 'XMLHttpRequest' }
    });
    const result = await res.json();
    if (result.success) {
      document.getElementById('scheduledBackupEnabled').checked = result.data.enabled;
      document.getElementById('scheduledToggleLabel').textContent = result.data.enabled ? '已开启' : '已关闭';
      document.getElementById('scheduledCron').value = result.data.cron;
      document.getElementById('scheduledType').value = result.data.type;
      document.getElementById('scheduledNotifyEmail').value = result.data.notifyEmail;
    }
  } catch (err) {
    console.error('Load scheduled backup error:', err);
  }
}

document.getElementById('scheduledBackupEnabled').addEventListener('change', function() {
  document.getElementById('scheduledToggleLabel').textContent = this.checked ? '已开启' : '已关闭';
});

async function saveScheduledBackup(btn) {
  const status = document.getElementById('scheduledStatus');
  const enabled = document.getElementById('scheduledBackupEnabled').checked;
  const cronExpr = document.getElementById('scheduledCron').value;
  const type = document.getElementById('scheduledType').value;
  const notifyEmail = document.getElementById('scheduledNotifyEmail').value;

  setBtnLoading(btn, true);
  showStatus(status, 'info', '保存中...');

  try {
    const res = await fetch('/admin/maintenance/scheduled-backup', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', 'CSRF-Token': getCsrfToken(), 'X-Requested-With': 'XMLHttpRequest' },
      body: JSON.stringify({ enabled, cron: cronExpr, type, notifyEmail })
    });
    const result = await res.json();
    if (result.success) {
      showStatus(status, 'success', result.message);
    } else {
      showStatus(status, 'error', result.error);
    }
  } catch (err) {
    showStatus(status, 'error', '请求失败: ' + err.message);
  } finally {
    setBtnLoading(btn, false);
  }
}

async function loadSystemInfo() {
  const container = document.getElementById('systemInfo');
  container.innerHTML = '<div class="info-loading">加载中...</div>';

  try {
    const res = await fetch('/admin/maintenance/system-info', {
      headers: { 'CSRF-Token': getCsrfToken(), 'X-Requested-With': 'XMLHttpRequest' }
    });
    const result = await res.json();

    if (result.success) {
      const d = result.data;
      let html = '';

      html += '<div class="info-section"><h4>服务器信息</h4>';
      html += infoRow('平台', d.server.platform + ' ' + d.server.arch);
      html += infoRow('Node.js', d.server.nodeVersion);
      html += infoRow('运行时间', formatUptime(d.server.uptime));
      html += infoRow('CPU核心', d.server.cpus + ' 核');
      html += infoRow('系统内存', formatSize(d.server.totalMemory));
      html += infoRow('可用内存', formatSize(d.server.freeMemory));
      html += infoRow('内存占用', formatSize(d.server.memoryUsage.rss));
      html += '</div>';

      html += '<div class="info-section"><h4>数据库信息</h4>';
      html += infoRow('数据库大小', d.database.sizeFormatted);
      html += infoRow('数据表数量', Object.keys(d.database.tableStats).length + ' 个');
      html += '</div>';

      html += '<div class="info-section"><h4>存储空间</h4>';
      html += infoRow('上传文件', d.storage.uploads.formatted);
      html += infoRow('备份文件', d.storage.backups.formatted);
      html += infoRow('临时文件', d.storage.temp.formatted);
      html += '</div>';

      html += '<div class="info-section"><h4>缓存状态</h4>';
      html += infoRow('设置缓存', d.cache.settings.size + '/' + d.cache.settings.maxSize + ' (' + d.cache.settings.hitRate + ')');
      html += infoRow('查询缓存', d.cache.query.size + '/' + d.cache.query.maxSize + ' (' + d.cache.query.hitRate + ')');
      html += infoRow('页面缓存', d.cache.page.size + '/' + d.cache.page.maxSize + ' (' + d.cache.page.hitRate + ')');
      html += '</div>';

      container.innerHTML = html;
    } else {
      container.innerHTML = '<div class="info-loading">加载失败: ' + result.error + '</div>';
    }
  } catch (err) {
    container.innerHTML = '<div class="info-loading">请求失败: ' + err.message + '</div>';
  }
}

function infoRow(label, value) {
  return '<div class="info-row"><span class="label">' + label + '</span><span class="value">' + value + '</span></div>';
}

function formatSize(bytes) {
  if (bytes === 0) return '0 B';
  const k = 1024;
  const sizes = ['B', 'KB', 'MB', 'GB'];
  const i = Math.floor(Math.log(bytes) / Math.log(k));
  return parseFloat((bytes / Math.pow(k, i)).toFixed(2)) + ' ' + sizes[i];
}

function formatUptime(seconds) {
  const d = Math.floor(seconds / 86400);
  const h = Math.floor((seconds % 86400) / 3600);
  const m = Math.floor((seconds % 3600) / 60);
  const s = Math.floor(seconds % 60);
  let r = '';
  if (d > 0) r += d + '天 ';
  if (h > 0) r += h + '时 ';
  if (m > 0) r += m + '分 ';
  r += s + '秒';
  return r;
}

// 初始化
loadScheduledBackup();
loadSystemInfo();
</script>
