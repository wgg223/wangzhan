}
.backup-type-selector {
  display: flex;
  align-items: center;
  gap: 16px;
  flex-wrap: wrap;
}
.backup-type-selector .form-control {
  width: auto;
  min-width: 180px;
}
.checkbox-label {
  display: flex;
  align-items: center;
  gap: 8px;
  font-size: 14px;
  cursor: pointer;
}
.checkbox-label input[type="checkbox"] {
  width: 16px;
  height: 16px;
}
.version-display {
  display: flex;
  gap: 40px;
  margin-bottom: 16px;
}
.current-version, .latest-version {
  display: flex;
  flex-direction: column;
}
.version-display .label {
  font-size: 12px;
