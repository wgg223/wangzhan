<% var active = 'maintenance' %>
<div class="admin-page">
  <div class="page-header">
    <h1>🔧 服务器维护</h1>
    <p class="page-desc">管理服务器维护模式和系统工具</p>
  </div>

  <div class="settings-section">
    <h2>维护状态</h2>
    <div class="update-info-card">
      <div class="maintenance-status-display" id="statusDisplay">
        <div class="status-icon" id="statusIcon">🟢</div>
        <div class="status-info">
          <h3 id="statusTitle">当前状态：正常运行</h3>
          <p id="statusDesc" class="text-muted">网站可正常访问</p>
        </div>
      </div>
    </div>
  </div>

  <div class="settings-section">
    <h2>维护设置</h2>
    <div class="update-info-card">
      <div class="form-group">
        <label>维护模式</label>
        <div class="toggle-switch-container">
          <label class="toggle-switch">
            <input type="checkbox" id="maintenanceEnabled" <%= settings.maintenance_mode === 'true' ? 'checked' : '' %>>
            <span class="toggle-slider"></span>
          </label>
          <span class="toggle-label" id="toggleLabel"><%= settings.maintenance_mode === 'true' ? '已开启' : '已关闭' %></span>
        </div>
        <p class="help-text">开启后，前端页面将显示维护页面，只有管理员可以访问后台</p>
      </div>

      <div class="form-group">
        <label for="maintenanceTitle">维护标题</label>
        <input type="text" id="maintenanceTitle" class="form-control" value="<%= settings.maintenance_title || '系统维护中' %>" placeholder="系统维护中">
      </div>

      <div class="form-group">
        <label for="maintenanceMessage">维护消息</label>
        <textarea id="maintenanceMessage" class="form-control" rows="4" placeholder="系统正在进行维护升级，请稍后再试。"><%= settings.maintenance_message || '系统正在进行维护升级，请稍后再试。' %></textarea>
      </div>

      <div class="update-actions">
        <button type="button" class="btn btn-primary" id="saveBtn" onclick="saveMaintenance()">
          <span class="btn-text">保存设置</span>
          <span class="btn-loading" style="display: none;">保存中...</span>
        </button>
        <button type="button" class="btn btn-success" id="toggleBtn" onclick="toggleMaintenance()">
          <span class="btn-text" id="toggleBtnText"><%= settings.maintenance_mode === 'true' ? '关闭维护模式' : '开启维护模式' %></span>
          <span class="btn-loading" style="display: none;">处理中...</span>
        </button>
      </div>

      <div id="saveStatus" style="display: none; margin-top: 12px;"></div>
    </div>
  </div>

  <div class="settings-section">
    <h2>系统工具</h2>
    <div class="tools-grid">
      <div class="tool-card">
        <div class="tool-icon">🗑️</div>
        <div class="tool-info">
          <h3>清除缓存</h3>
          <p>清除所有内存缓存，包括设置缓存、查询缓存和页面缓存</p>
        </div>
        <button type="button" class="btn btn-warning" onclick="clearCache()">
          <span class="btn-text">清除缓存</span>
          <span class="btn-loading" style="display: none;">处理中...</span>
        </button>
      </div>

      <div class="tool-card">
        <div class="tool-icon">📁</div>
        <div class="tool-info">
          <h3>清理临时文件</h3>
          <p>清理临时目录和过期日志文件，释放磁盘空间</p>
        </div>
        <button type="button" class="btn btn-warning" onclick="cleanTemp()">
          <span class="btn-text">清理临时文件</span>
          <span class="btn-loading" style="display: none;">处理中...</span>
        </button>
      </div>

      <div class="tool-card">
        <div class="tool-icon">📊</div>
        <div class="tool-info">
          <h3>优化数据库</h3>
          <p>运行 VACUUM 命令优化数据库，减少数据库文件大小</p>
        </div>
        <button type="button" class="btn btn-warning" onclick="optimizeDb()">
          <span class="btn-text">优化数据库</span>
          <span class="btn-loading" style="display: none;">处理中...</span>
        </button>
      </div>

      <div class="tool-card">
        <div class="tool-icon">📋</div>
        <div class="tool-info">
          <h3>清理活动日志</h3>
          <p>清理指定天数前的活动日志记录</p>
        </div>
        <div class="tool-actions">
          <select id="logDays" class="form-control" style="width: auto; margin-right: 8px;">
            <option value="7">7天前</option>
            <option value="30" selected>30天前</option>
            <option value="90">90天前</option>
            <option value="180">180天前</option>
          </select>
          <button type="button" class="btn btn-warning" onclick="cleanLogs()">
            <span class="btn-text">清理日志</span>
            <span class="btn-loading" style="display: none;">处理中...</span>
          </button>
        </div>
      </div>
    </div>
    <div id="toolStatus" style="display: none; margin-top: 16px;"></div>
  </div>

  <div class="settings-section">
    <h2>备份管理</h2>
    <div class="update-info-card">
      <div class="form-group">
        <label>手动备份</label>
        <div class="backup-options">
          <div class="backup-type-selector">
            <select id="backupType" class="form-control">
              <option value="database">数据库备份</option>
              <option value="uploads">上传文件备份</option>
              <option value="config">配置文件备份</option>
              <option value="full">完整备份</option>
            </select>
            <label class="checkbox-label">
              <input type="checkbox" id="backupSendEmail"> 备份后发送邮件通知
            </label>
          </div>
          <button type="button" class="btn btn-primary" onclick="backupNow()">
            <span class="btn-text">立即备份</span>
            <span class="btn-loading" style="display: none;">备份中...</span>
          </button>
        </div>
        <div id="backupStatus" style="display: none; margin-top: 12px;"></div>
      </div>

      <div class="form-group" style="margin-top: 24px; padding-top: 24px; border-top: 1px solid #e5e7eb;">
        <label>定时备份</label>
        <div class="toggle-switch-container">
          <label class="toggle-switch">
            <input type="checkbox" id="scheduledBackupEnabled">
            <span class="toggle-slider"></span>
          </label>
          <span class="toggle-label" id="scheduledToggleLabel">已关闭</span>
        </div>
        <div class="scheduled-backup-settings" style="margin-top: 16px;">
          <div class="form-group">
            <label for="scheduledCron">Cron 表达式</label>
            <input type="text" id="scheduledCron" class="form-control" value="0 3 * * *" placeholder="0 3 * * *">
            <p class="help-text">默认每天凌晨3点执行。格式：分 时 日 月 周</p>
          </div>
          <div class="form-group">
            <label for="scheduledType">备份类型</label>
            <select id="scheduledType" class="form-control">
              <option value="database">数据库备份</option>
              <option value="uploads">上传文件备份</option>
              <option value="config">配置文件备份</option>
              <option value="full">完整备份</option>
            </select>
          </div>
          <div class="form-group">
            <label for="scheduledNotifyEmail">通知邮箱</label>
            <input type="email" id="scheduledNotifyEmail" class="form-control" placeholder="admin@example.com">
            <p class="help-text">备份完成后发送通知邮件到此邮箱（需配置SMTP）</p>
          </div>
          <button type="button" class="btn btn-primary" onclick="saveScheduledBackup()">
            <span class="btn-text">保存定时备份设置</span>
            <span class="btn-loading" style="display: none;">保存中...</span>
          </button>
        </div>
        <div id="scheduledStatus" style="display: none; margin-top: 12px;"></div>
      </div>
    </div>
  </div>

  <div class="settings-section">
    <h2>系统更新</h2>
    <div class="update-info-card">
      <h3 style="margin-bottom: 16px;">📦 主项目更新</h3>
      <div class="version-display">
        <div class="current-version">
          <span class="label">当前版本</span>
          <span class="version" id="currentVersion">加载中...</span>
        </div>
        <div class="latest-version" id="latestVersionContainer" style="display: none;">
          <span class="label">最新版本</span>
          <span class="version" id="latestVersion">-</span>
        </div>
      </div>
      <div class="update-status" id="updateStatus">
        <div class="status-message">点击下方按钮检查更新</div>
      </div>
      <div class="release-info" id="releaseInfo" style="display: none;">
        <h4 id="releaseName"></h4>
        <div class="release-meta"><span id="publishedAt"></span></div>
        <div class="release-body" id="releaseBody"></div>
      </div>
      <div class="update-actions" style="margin-top: 16px;">
        <button type="button" class="btn btn-primary" id="checkUpdateBtn" onclick="checkUpdate()">
          <span class="btn-text">检查更新</span>
          <span class="btn-loading" style="display: none;">检查中...</span>
        </button>
        <button type="button" class="btn btn-success" id="downloadBtn" onclick="downloadUpdate()" style="display: none;">
          <span class="btn-text">下载并安装更新</span>
          <span class="btn-loading" style="display: none;">下载中...</span>
        </button>
        <button type="button" class="btn btn-warning" id="restartBtn" onclick="restartServer()">
          <span class="btn-text">重启服务器</span>
          <span class="btn-loading" style="display: none;">重启中...</span>
        </button>
      </div>
      <div id="updateActionResult" style="display: none; margin-top: 12px;"></div>
    </div>
    
    <div class="update-info-card" style="margin-top: 16px;">
      <h3 style="margin-bottom: 16px;">🎮 RP-Hub 更新</h3>
      <div class="version-display">
        <div class="latest-version">
          <span class="label">最新版本</span>
          <span class="version" id="rphubLatestVersion">-</span>
        </div>
      </div>
      <div class="update-status" id="rphubUpdateStatus">
        <div class="status-message">点击下方按钮检查 RP-Hub 更新</div>
      </div>
      <div class="release-info" id="rphubReleaseInfo" style="display: none;">
        <h4 id="rphubReleaseName"></h4>
        <div class="release-meta"><span id="rphubPublishedAt"></span></div>
        <div class="release-body" id="rphubReleaseBody"></div>
      </div>
      <div class="update-actions" style="margin-top: 16px;">
        <button type="button" class="btn btn-primary" id="checkRphubUpdateBtn" onclick="checkRphubUpdate()">
          <span class="btn-text">检查 RP-Hub 更新</span>
          <span class="btn-loading" style="display: none;">检查中...</span>
        </button>
        <a href="https://github.com/STA1N156/RP-Hub/releases" target="_blank" class="btn btn-info">
          📥 前往下载
        </a>
      </div>
    </div>
  </div>

  <div class="settings-section">
    <h2>系统信息</h2>
    <div class="update-info-card">
      <button type="button" class="btn btn-info" onclick="loadSystemInfo()" style="margin-bottom: 16px;">
        <span class="btn-text">刷新系统信息</span>
      </button>
      <div id="systemInfo" class="system-info-grid">
        <div class="info-loading">点击按钮加载系统信息</div>
      </div>
    </div>
  </div>

  <div class="settings-section">
    <h2>说明</h2>
    <div class="info-card">
      <ul class="info-list">
        <li>开启维护模式后，前端所有页面将显示维护页面</li>
        <li>管理员仍然可以正常访问后台管理面板</li>
        <li>健康检查接口 (<code>/health</code>) 不受影响</li>
        <li>静态资源和 API 请求不受影响</li>
        <li>关闭维护模式后，前端立即恢复正常访问</li>
      </ul>
    </div>
  </div>
</div>

<style>
