  display: flex;
  align-items: center;
  gap: 20px;
  padding: 20px;
  border-radius: 8px;
  transition: all 0.3s;
}
.maintenance-status-display.active {
  background: #fef3c7;
  border: 1px solid #fcd34d;
}
.maintenance-status-display.inactive {
  background: #d1fae5;
  border: 1px solid #a7f3d0;
}
.status-icon {
  font-size: 48px;
}
.status-info h3 {
  margin: 0 0 4px 0;
  font-size: 18px;
}
.status-info p {
  margin: 0;
  color: #6b7280;
}
.toggle-switch-container {
  display: flex;
  align-items: center;
  gap: 12px;
  margin-bottom: 8px;
}
.toggle-switch {
  position: relative;
  display: inline-block;
  width: 60px;
  height: 34px;
}
.toggle-switch input {
  opacity: 0;
  width: 0;
  height: 0;
}
.toggle-slider {
  position: absolute;
  cursor: pointer;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: #ccc;
  transition: .4s;
  border-radius: 34px;
}
.toggle-slider:before {
  position: absolute;
  content: "";
  height: 26px;
  width: 26px;
  left: 4px;
  bottom: 4px;
  background-color: white;
  transition: .4s;
  border-radius: 50%;
}
input:checked + .toggle-slider {
  background-color: #ef4444;
}
input:checked + .toggle-slider:before {
  transform: translateX(26px);
}
.toggle-label {
  font-weight: 500;
  color: #374151;
}
.help-text {
  font-size: 13px;
  color: #6b7280;
  margin-top: 4px;
}
.form-control {
  width: 100%;
  padding: 10px 14px;
  border: 1px solid #d1d5db;
  border-radius: 8px;
  font-size: 14px;
  transition: border-color 0.2s;
  font-family: inherit;
}
.form-control:focus {
  outline: none;
  border-color: #6366f1;
  box-shadow: 0 0 0 3px rgba(99, 102, 241, 0.1);
}
.form-group {
  margin-bottom: 20px;
}
.form-group label {
  display: block;
  font-weight: 500;
  margin-bottom: 6px;
  color: #374151;
}
.info-card {
