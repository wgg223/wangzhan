<% var active = 'maintenance' %>
<div class="admin-page">
  <div class="page-header">
    <h1>🔧 服务器维护</h1>
    <p class="page-desc">管理服务器维护模式和系统工具</p>
  </div>

  <div class="settings-section">
    <h2>维护状态</h2>
    <div class="update-info-card">
      <div class="maintenance-status-display" id="statusDisplay">
        <div class="status-icon" id="statusIcon">🟢</div>
        <div class="status-info">
          <h3 id="statusTitle">当前状态：正常运行</h3>
          <p id="statusDesc" class="text-muted">网站可正常访问</p>
        </div>
      </div>
    </div>
  </div>

  <div class="settings-section">
    <h2>维护设置</h2>
    <div class="update-info-card">
      <div class="form-group">
        <label>维护模式</label>
        <div class="toggle-switch-container">
          <label class="toggle-switch">
            <input type="checkbox" id="maintenanceEnabled" <%= settings.maintenance_mode === 'true' ? 'checked' : '' %>>
            <span class="toggle-slider"></span>
          </label>
          <span class="toggle-label" id="toggleLabel"><%= settings.maintenance_mode === 'true' ? '已开启' : '已关闭' %></span>
        </div>
        <p class="help-text">开启后，前端页面将显示维护页面，只有管理员可以访问后台</p>
      </div>

      <div class="form-group">
        <label for="maintenanceTitle">维护标题</label>
        <input type="text" id="maintenanceTitle" class="form-control" value="<%= settings.maintenance_title || '系统维护中' %>" placeholder="系统维护中">
      </div>

      <div class="form-group">
        <label for="maintenanceMessage">维护消息</label>
        <textarea id="maintenanceMessage" class="form-control" rows="4" placeholder="系统正在进行维护升级，请稍后再试。"><%= settings.maintenance_message || '系统正在进行维护升级，请稍后再试。' %></textarea>
      </div>

      <div class="update-actions">
        <button type="button" class="btn btn-primary" id="saveBtn" onclick="saveMaintenance()">
          <span class="btn-text">保存设置</span>
          <span class="btn-loading" style="display: none;">保存中...</span>
        </button>
        <button type="button" class="btn btn-success" id="toggleBtn" onclick="toggleMaintenance()">
          <span class="btn-text" id="toggleBtnText"><%= settings.maintenance_mode === 'true' ? '关闭维护模式' : '开启维护模式' %></span>
          <span class="btn-loading" style="display: none;">处理中...</span>
        </button>
      </div>

      <div id="saveStatus" style="display: none; margin-top: 12px;"></div>
    </div>
  </div>

  <div class="settings-section">
    <h2>系统工具</h2>
    <div class="tools-grid">
      <div class="tool-card">
        <div class="tool-icon">🗑️</div>
        <div class="tool-info">
          <h3>清除缓存</h3>
          <p>清除所有内存缓存，包括设置缓存、查询缓存和页面缓存</p>
        </div>
        <button type="button" class="btn btn-warning" onclick="clearCache()">
          <span class="btn-text">清除缓存</span>
          <span class="btn-loading" style="display: none;">处理中...</span>
        </button>
      </div>

      <div class="tool-card">
        <div class="tool-icon">📁</div>
        <div class="tool-info">
          <h3>清理临时文件</h3>
          <p>清理临时目录和过期日志文件，释放磁盘空间</p>
        </div>
        <button type="button" class="btn btn-warning" onclick="cleanTemp()">
          <span class="btn-text">清理临时文件</span>
          <span class="btn-loading" style="display: none;">处理中...</span>
        </button>
      </div>

      <div class="tool-card">
        <div class="tool-icon">📊</div>
        <div class="tool-info">
          <h3>优化数据库</h3>
          <p>运行 VACUUM 命令优化数据库，减少数据库文件大小</p>
        </div>
        <button type="button" class="btn btn-warning" onclick="optimizeDb()">
          <span class="btn-text">优化数据库</span>
          <span class="btn-loading" style="display: none;">处理中...</span>
        </button>
      </div>

      <div class="tool-card">
        <div class="tool-icon">📋</div>
        <div class="tool-info">
          <h3>清理活动日志</h3>
          <p>清理指定天数前的活动日志记录</p>
        </div>
        <div class="tool-actions">
          <select id="logDays" class="form-control" style="width: auto; margin-right: 8px;">
            <option value="7">7天前</option>
            <option value="30" selected>30天前</option>
            <option value="90">90天前</option>
            <option value="180">180天前</option>
          </select>
          <button type="button" class="btn btn-warning" onclick="cleanLogs()">
            <span class="btn-text">清理日志</span>
            <span class="btn-loading" style="display: none;">处理中...</span>
          </button>
        </div>
      </div>
    </div>
    <div id="toolStatus" style="display: none; margin-top: 16px;"></div>
  </div>

  <div class="settings-section">
    <h2>系统信息</h2>
    <div class="update-info-card">
      <button type="button" class="btn btn-info" onclick="loadSystemInfo()" style="margin-bottom: 16px;">
        <span class="btn-text">刷新系统信息</span>
      </button>
      <div id="systemInfo" class="system-info-grid">
        <div class="info-loading">点击按钮加载系统信息</div>
      </div>
    </div>
  </div>

  <div class="settings-section">
    <h2>说明</h2>
    <div class="info-card">
      <ul class="info-list">
        <li>开启维护模式后，前端所有页面将显示维护页面</li>
        <li>管理员仍然可以正常访问后台管理面板</li>
        <li>健康检查接口 (<code>/health</code>) 不受影响</li>
        <li>静态资源和 API 请求不受影响</li>
        <li>关闭维护模式后，前端立即恢复正常访问</li>
      </ul>
    </div>
  </div>
</div>

<style>
.maintenance-status-display {
  display: flex;
  align-items: center;
  gap: 20px;
  padding: 20px;
  border-radius: 8px;
  transition: all 0.3s;
}
.maintenance-status-display.active {
  background: #fef3c7;
  border: 1px solid #fcd34d;
}
.maintenance-status-display.inactive {
  background: #d1fae5;
  border: 1px solid #a7f3d0;
}
.status-icon {
  font-size: 48px;
}
.status-info h3 {
  margin: 0 0 4px 0;
  font-size: 18px;
}
.status-info p {
  margin: 0;
  color: #6b7280;
}
.toggle-switch-container {
  display: flex;
  align-items: center;
  gap: 12px;
  margin-bottom: 8px;
}
.toggle-switch {
  position: relative;
  display: inline-block;
  width: 60px;
  height: 34px;
}
.toggle-switch input {
  opacity: 0;
  width: 0;
  height: 0;
}
.toggle-slider {
  position: absolute;
  cursor: pointer;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: #ccc;
  transition: .4s;
  border-radius: 34px;
}
.toggle-slider:before {
  position: absolute;
  content: "";
  height: 26px;
  width: 26px;
  left: 4px;
  bottom: 4px;
  background-color: white;
  transition: .4s;
  border-radius: 50%;
}
input:checked + .toggle-slider {
  background-color: #ef4444;
}
input:checked + .toggle-slider:before {
  transform: translateX(26px);
}
.toggle-label {
  font-weight: 500;
  color: #374151;
}
.help-text {
  font-size: 13px;
  color: #6b7280;
  margin-top: 4px;
}
.form-control {
  width: 100%;
  padding: 10px 14px;
  border: 1px solid #d1d5db;
  border-radius: 8px;
  font-size: 14px;
  transition: border-color 0.2s;
  font-family: inherit;
}
.form-control:focus {
  outline: none;
  border-color: #6366f1;
  box-shadow: 0 0 0 3px rgba(99, 102, 241, 0.1);
}
.form-group {
  margin-bottom: 20px;
}
.form-group label {
  display: block;
  font-weight: 500;
  margin-bottom: 6px;
  color: #374151;
}
.info-card {
  background: #f8fafc;
  border: 1px solid #e2e8f0;
  border-radius: 8px;
  padding: 20px;
}
.info-list {
  margin: 0;
  padding-left: 20px;
  color: #475569;
  line-height: 1.8;
}
.info-list code {
  background: #e2e8f0;
  padding: 2px 6px;
  border-radius: 4px;
  font-size: 13px;
}
.text-muted {
  color: #6b7280;
}
.tools-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
  gap: 16px;
}
.tool-card {
  background: #f8fafc;
  border: 1px solid #e2e8f0;
  border-radius: 8px;
  padding: 20px;
  display: flex;
  flex-direction: column;
  gap: 12px;
}
.tool-icon {
  font-size: 32px;
}
.tool-info h3 {
  margin: 0 0 4px 0;
  font-size: 16px;
  color: #1f2937;
}
.tool-info p {
  margin: 0;
  font-size: 13px;
  color: #6b7280;
}
.tool-actions {
  display: flex;
  align-items: center;
  gap: 8px;
}
.tool-actions .form-control {
  flex: 1;
}
.system-info-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(250px, 1fr));
  gap: 16px;
}
.info-section {
  background: #f8fafc;
  border: 1px solid #e2e8f0;
  border-radius: 8px;
  padding: 16px;
}
.info-section h4 {
  margin: 0 0 12px 0;
  font-size: 14px;
  color: #374151;
  border-bottom: 1px solid #e2e8f0;
  padding-bottom: 8px;
}
.info-row {
  display: flex;
  justify-content: space-between;
  margin-bottom: 8px;
  font-size: 13px;
}
.info-row .label {
  color: #6b7280;
}
.info-row .value {
  color: #1f2937;
  font-weight: 500;
}
.info-loading {
  grid-column: 1 / -1;
  text-align: center;
  padding: 20px;
  color: #6b7280;
}
</style>

<script>
function getCsrfToken() {
  const meta = document.querySelector('meta[name="csrf-token"]');
  return meta ? meta.getAttribute('content') : '';
}

// Update status display
function updateStatusDisplay(enabled) {
  const display = document.getElementById('statusDisplay');
  const icon = document.getElementById('statusIcon');
  const title = document.getElementById('statusTitle');
  const desc = document.getElementById('statusDesc');
  const toggleLabel = document.getElementById('toggleLabel');
  const toggleBtnText = document.getElementById('toggleBtnText');

  if (enabled) {
    display.className = 'maintenance-status-display active';
    icon.textContent = '🔴';
    title.textContent = '当前状态：维护中';
    desc.textContent = '前端页面显示维护页面，仅管理员可访问后台';
    toggleLabel.textContent = '已开启';
    toggleBtnText.textContent = '关闭维护模式';
  } else {
    display.className = 'maintenance-status-display inactive';
    icon.textContent = '🟢';
    title.textContent = '当前状态：正常运行';
    desc.textContent = '网站可正常访问';
    toggleLabel.textContent = '已关闭';
    toggleBtnText.textContent = '开启维护模式';
  }
}

// Initialize
updateStatusDisplay(document.getElementById('maintenanceEnabled').checked);

// Toggle change event
document.getElementById('maintenanceEnabled').addEventListener('change', function() {
  updateStatusDisplay(this.checked);
});

async function saveMaintenance() {
  const btn = document.getElementById('saveBtn');
  const btnText = btn.querySelector('.btn-text');
  const btnLoading = btn.querySelector('.btn-loading');
  const status = document.getElementById('saveStatus');

  const enabled = document.getElementById('maintenanceEnabled').checked;
  const title = document.getElementById('maintenanceTitle').value;
  const message = document.getElementById('maintenanceMessage').value;

  btn.disabled = true;
  btnText.style.display = 'none';
  btnLoading.style.display = 'inline';
  status.style.display = 'block';
  status.innerHTML = '<div class="alert alert-info">保存中...</div>';

  try {
    const response = await fetch('/admin/maintenance/update', {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
        'CSRF-Token': getCsrfToken(),
        'X-Requested-With': 'XMLHttpRequest'
      },
      body: JSON.stringify({ enabled, title, message })
    });

    const result = await response.json();

    if (result.success) {
      status.innerHTML = '<div class="alert alert-success">' + result.message + '</div>';
      updateStatusDisplay(enabled);
    } else {
      status.innerHTML = '<div class="alert alert-error">' + result.error + '</div>';
    }
  } catch (err) {
    status.innerHTML = '<div class="alert alert-error">请求失败: ' + err.message + '</div>';
  } finally {
    btn.disabled = false;
    btnText.style.display = 'inline';
    btnLoading.style.display = 'none';
  }
}

async function toggleMaintenance() {
  const btn = document.getElementById('toggleBtn');
  const btnText = btn.querySelector('.btn-text');
  const btnLoading = btn.querySelector('.btn-loading');
  const status = document.getElementById('saveStatus');

  const checkbox = document.getElementById('maintenanceEnabled');
  const newEnabled = !checkbox.checked;
  const title = document.getElementById('maintenanceTitle').value;
  const message = document.getElementById('maintenanceMessage').value;

  btn.disabled = true;
  btnText.style.display = 'none';
  btnLoading.style.display = 'inline';
  status.style.display = 'block';
  status.innerHTML = '<div class="alert alert-info">处理中...</div>';

  try {
    const response = await fetch('/admin/maintenance/update', {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
        'CSRF-Token': getCsrfToken(),
        'X-Requested-With': 'XMLHttpRequest'
      },
      body: JSON.stringify({ enabled: newEnabled, title, message })
    });

    const result = await response.json();

    if (result.success) {
      checkbox.checked = newEnabled;
      updateStatusDisplay(newEnabled);
      status.innerHTML = '<div class="alert alert-success">' + result.message + '</div>';
    } else {
      status.innerHTML = '<div class="alert alert-error">' + result.error + '</div>';
    }
  } catch (err) {
    status.innerHTML = '<div class="alert alert-error">请求失败: ' + err.message + '</div>';
  } finally {
    btn.disabled = false;
    btnText.style.display = 'inline';
    btnLoading.style.display = 'none';
  }
}

// Tool functions
async function clearCache() {
  const btn = event.target.closest('button');
  const btnText = btn.querySelector('.btn-text');
  const btnLoading = btn.querySelector('.btn-loading');
  const status = document.getElementById('toolStatus');

  btn.disabled = true;
  btnText.style.display = 'none';
  btnLoading.style.display = 'inline';
  status.style.display = 'block';
  status.innerHTML = '<div class="alert alert-info">清除缓存中...</div>';

  try {
    const response = await fetch('/admin/maintenance/clear-cache', {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
        'CSRF-Token': getCsrfToken(),
        'X-Requested-With': 'XMLHttpRequest'
      }
    });

    const result = await response.json();

    if (result.success) {
      status.innerHTML = '<div class="alert alert-success">' + result.message + '</div>';
    } else {
      status.innerHTML = '<div class="alert alert-error">' + result.error + '</div>';
    }
  } catch (err) {
    status.innerHTML = '<div class="alert alert-error">请求失败: ' + err.message + '</div>';
  } finally {
    btn.disabled = false;
    btnText.style.display = 'inline';
    btnLoading.style.display = 'none';
  }
}

async function cleanTemp() {
  const btn = event.target.closest('button');
  const btnText = btn.querySelector('.btn-text');
  const btnLoading = btn.querySelector('.btn-loading');
  const status = document.getElementById('toolStatus');

  btn.disabled = true;
  btnText.style.display = 'none';
  btnLoading.style.display = 'inline';
  status.style.display = 'block';
  status.innerHTML = '<div class="alert alert-info">清理临时文件中...</div>';

  try {
    const response = await fetch('/admin/maintenance/clean-temp', {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
        'CSRF-Token': getCsrfToken(),
        'X-Requested-With': 'XMLHttpRequest'
      }
    });

    const result = await response.json();

    if (result.success) {
      status.innerHTML = '<div class="alert alert-success">' + result.message + '</div>';
    } else {
      status.innerHTML = '<div class="alert alert-error">' + result.error + '</div>';
    }
  } catch (err) {
    status.innerHTML = '<div class="alert alert-error">请求失败: ' + err.message + '</div>';
  } finally {
    btn.disabled = false;
    btnText.style.display = 'inline';
    btnLoading.style.display = 'none';
  }
}

async function optimizeDb() {
  const btn = event.target.closest('button');
  const btnText = btn.querySelector('.btn-text');
  const btnLoading = btn.querySelector('.btn-loading');
  const status = document.getElementById('toolStatus');

  btn.disabled = true;
  btnText.style.display = 'none';
  btnLoading.style.display = 'inline';
  status.style.display = 'block';
  status.innerHTML = '<div class="alert alert-info">优化数据库中...</div>';

  try {
    const response = await fetch('/admin/maintenance/optimize-db', {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
        'CSRF-Token': getCsrfToken(),
        'X-Requested-With': 'XMLHttpRequest'
      }
    });

    const result = await response.json();

    if (result.success) {
      status.innerHTML = '<div class="alert alert-success">' + result.message + ' (释放 ' + result.saved + ')</div>';
    } else {
      status.innerHTML = '<div class="alert alert-error">' + result.error + '</div>';
    }
  } catch (err) {
    status.innerHTML = '<div class="alert alert-error">请求失败: ' + err.message + '</div>';
  } finally {
    btn.disabled = false;
    btnText.style.display = 'inline';
    btnLoading.style.display = 'none';
  }
}

async function cleanLogs() {
  const btn = event.target.closest('button');
  const btnText = btn.querySelector('.btn-text');
  const btnLoading = btn.querySelector('.btn-loading');
  const status = document.getElementById('toolStatus');
  const days = document.getElementById('logDays').value;

  btn.disabled = true;
  btnText.style.display = 'none';
  btnLoading.style.display = 'inline';
  status.style.display = 'block';
  status.innerHTML = '<div class="alert alert-info">清理日志中...</div>';

  try {
    const response = await fetch('/admin/maintenance/clean-logs', {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
        'CSRF-Token': getCsrfToken(),
        'X-Requested-With': 'XMLHttpRequest'
      },
      body: JSON.stringify({ days: parseInt(days) })
    });

    const result = await response.json();

    if (result.success) {
      status.innerHTML = '<div class="alert alert-success">' + result.message + '，删除 ' + result.deleted + ' 条记录</div>';
    } else {
      status.innerHTML = '<div class="alert alert-error">' + result.error + '</div>';
    }
  } catch (err) {
    status.innerHTML = '<div class="alert alert-error">请求失败: ' + err.message + '</div>';
  } finally {
    btn.disabled = false;
    btnText.style.display = 'inline';
    btnLoading.style.display = 'none';
  }
}

async function loadSystemInfo() {
  const container = document.getElementById('systemInfo');
  container.innerHTML = '<div class="info-loading">加载中...</div>';

  try {
    const response = await fetch('/admin/maintenance/system-info', {
      headers: {
        'CSRF-Token': getCsrfToken(),
        'X-Requested-With': 'XMLHttpRequest'
      }
    });

    const result = await response.json();

    if (result.success) {
      const data = result.data;
      let html = '';

      // Server info
      html += '<div class="info-section">';
      html += '<h4>服务器信息</h4>';
      html += '<div class="info-row"><span class="label">平台</span><span class="value">' + data.server.platform + ' ' + data.server.arch + '</span></div>';
      html += '<div class="info-row"><span class="label">Node.js</span><span class="value">' + data.server.nodeVersion + '</span></div>';
      html += '<div class="info-row"><span class="label">运行时间</span><span class="value">' + formatUptime(data.server.uptime) + '</span></div>';
      html += '<div class="info-row"><span class="label">CPU核心</span><span class="value">' + data.server.cpus + ' 核</span></div>';
      html += '<div class="info-row"><span class="label">系统内存</span><span class="value">' + formatSize(data.server.totalMemory) + '</span></div>';
      html += '<div class="info-row"><span class="label">可用内存</span><span class="value">' + formatSize(data.server.freeMemory) + '</span></div>';
      html += '<div class="info-row"><span class="label">内存使用</span><span class="value">' + formatSize(data.server.memoryUsage.rss) + '</span></div>';
      html += '</div>';

      // Database info
      html += '<div class="info-section">';
      html += '<h4>数据库信息</h4>';
      html += '<div class="info-row"><span class="label">数据库大小</span><span class="value">' + data.database.sizeFormatted + '</span></div>';
      const tableCount = Object.keys(data.database.tableStats).length;
      html += '<div class="info-row"><span class="label">数据表数量</span><span class="value">' + tableCount + ' 个</span></div>';
      html += '</div>';

      // Storage info
      html += '<div class="info-section">';
      html += '<h4>存储空间</h4>';
      html += '<div class="info-row"><span class="label">上传文件</span><span class="value">' + data.storage.uploads.formatted + '</span></div>';
      html += '<div class="info-row"><span class="label">备份文件</span><span class="value">' + data.storage.backups.formatted + '</span></div>';
      html += '<div class="info-row"><span class="label">临时文件</span><span class="value">' + data.storage.temp.formatted + '</span></div>';
      html += '</div>';

      // Cache info
      html += '<div class="info-section">';
      html += '<h4>缓存状态</h4>';
      html += '<div class="info-row"><span class="label">设置缓存</span><span class="value">' + data.cache.settings.size + '/' + data.cache.settings.maxSize + ' (命中率 ' + data.cache.settings.hitRate + ')</span></div>';
      html += '<div class="info-row"><span class="label">查询缓存</span><span class="value">' + data.cache.query.size + '/' + data.cache.query.maxSize + ' (命中率 ' + data.cache.query.hitRate + ')</span></div>';
      html += '<div class="info-row"><span class="label">页面缓存</span><span class="value">' + data.cache.page.size + '/' + data.cache.page.maxSize + ' (命中率 ' + data.cache.page.hitRate + ')</span></div>';
      html += '</div>';

      container.innerHTML = html;
    } else {
      container.innerHTML = '<div class="info-loading">加载失败: ' + result.error + '</div>';
    }
  } catch (err) {
    container.innerHTML = '<div class="info-loading">请求失败: ' + err.message + '</div>';
  }
}

function formatSize(bytes) {
  if (bytes === 0) return '0 B';
  const k = 1024;
  const sizes = ['B', 'KB', 'MB', 'GB'];
  const i = Math.floor(Math.log(bytes) / Math.log(k));
  return parseFloat((bytes / Math.pow(k, i)).toFixed(2)) + ' ' + sizes[i];
}

function formatUptime(seconds) {
  const days = Math.floor(seconds / 86400);
  const hours = Math.floor((seconds % 86400) / 3600);
  const minutes = Math.floor((seconds % 3600) / 60);
  const secs = Math.floor(seconds % 60);
  
  let result = '';
  if (days > 0) result += days + '天 ';
  if (hours > 0) result += hours + '小时 ';
  if (minutes > 0) result += minutes + '分钟 ';
  result += secs + '秒';
  
  return result;
}
