}
.info-section {
  background: #f8fafc;
  border: 1px solid #e2e8f0;
  border-radius: 8px;
  padding: 16px;
}
.info-section h4 {
  margin: 0 0 12px 0;
  font-size: 14px;
  color: #374151;
  border-bottom: 1px solid #e2e8f0;
