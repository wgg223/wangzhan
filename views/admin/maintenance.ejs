let updateData = null;

async function checkUpdate() {
  const btn = document.getElementById('checkUpdateBtn');
  const btnText = btn.querySelector('.btn-text');
  const btnLoading = btn.querySelector('.btn-loading');
  const status = document.getElementById('updateStatus');
  const releaseInfo = document.getElementById('releaseInfo');
  const downloadBtn = document.getElementById('downloadBtn');

  btn.disabled = true;
  btnText.style.display = 'none';
  btnLoading.style.display = 'inline';
  status.innerHTML = '<div class="status-message">检查更新中...</div>';

  try {
    const response = await fetch('/admin/maintenance/check-update', {
      headers: {
        'CSRF-Token': getCsrfToken(),
        'X-Requested-With': 'XMLHttpRequest'
      }
    });

    const result = await response.json();

    if (result.success) {
      updateData = result.data;
      document.getElementById('currentVersion').textContent = 'v' + result.data.currentVersion;

      if (result.data.hasUpdate) {
        document.getElementById('latestVersionContainer').style.display = 'flex';
        document.getElementById('latestVersion').textContent = 'v' + result.data.latestVersion;
        status.className = 'update-status has-update';
        status.innerHTML = '<div class="status-message">发现新版本 v' + result.data.latestVersion + '</div>';
        downloadBtn.style.display = 'inline-flex';

        if (result.data.releaseName) {
          releaseInfo.style.display = 'block';
          document.getElementById('releaseName').textContent = result.data.releaseName;
          document.getElementById('publishedAt').textContent = '发布时间: ' + new Date(result.data.publishedAt).toLocaleString('zh-CN');
          document.getElementById('releaseBody').textContent = result.data.releaseBody;
        }
      } else {
        document.getElementById('latestVersionContainer').style.display = 'none';
        status.className = 'update-status no-update';
        status.innerHTML = '<div class="status-message">当前已是最新版本</div>';
        downloadBtn.style.display = 'none';
        releaseInfo.style.display = 'none';
      }
    } else {
      status.innerHTML = '<div class="status-message">检查失败: ' + result.error + '</div>';
    }
  } catch (err) {
    status.innerHTML = '<div class="status-message">请求失败: ' + err.message + '</div>';
  } finally {
    btn.disabled = false;
    btnText.style.display = 'inline';
    btnLoading.style.display = 'none';
  }
}

async function downloadUpdate() {
  if (!updateData || !updateData.downloadUrl) {
    alert('请先检查更新');
    return;
  }

  if (!confirm('确定要下载并安装更新吗？建议先备份数据。')) return;

  const btn = document.getElementById('downloadBtn');
  const btnText = btn.querySelector('.btn-text');
  const btnLoading = btn.querySelector('.btn-loading');
  const resultDiv = document.getElementById('updateActionResult');

  btn.disabled = true;
  btnText.style.display = 'none';
  btnLoading.style.display = 'inline';
  resultDiv.style.display = 'block';
  resultDiv.innerHTML = '<div class="alert alert-info">下载并安装更新中...</div>';

  try {
    const response = await fetch('/admin/maintenance/download-update', {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
        'CSRF-Token': getCsrfToken(),
        'X-Requested-With': 'XMLHttpRequest'
      },
      body: JSON.stringify({
        downloadUrl: updateData.downloadUrl,
        version: updateData.latestVersion
      })
    });

    const result = await response.json();

    if (result.success) {
      resultDiv.innerHTML = '<div class="alert alert-success">' + result.message + '</div>';
      document.getElementById('currentVersion').textContent = 'v' + updateData.latestVersion;
      btn.style.display = 'none';
    } else {
      resultDiv.innerHTML = '<div class="alert alert-error">' + result.error + '</div>';
    }
  } catch (err) {
    resultDiv.innerHTML = '<div class="alert alert-error">请求失败: ' + err.message + '</div>';
  } finally {
    btn.disabled = false;
    btnText.style.display = 'inline';
    btnLoading.style.display = 'none';
  }
}

