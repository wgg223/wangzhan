  border: 1px solid #e2e8f0;
  border-radius: 8px;
  padding: 20px;
}
.info-list {
  margin: 0;
  padding-left: 20px;
  color: #475569;
  line-height: 1.8;
}
.info-list code {
  background: #e2e8f0;
  padding: 2px 6px;
  border-radius: 4px;
  font-size: 13px;
}
.text-muted {
  color: #6b7280;
}
.tools-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
  gap: 16px;
}
.tool-card {
  background: #f8fafc;
  border: 1px solid #e2e8f0;
  border-radius: 8px;
  padding: 20px;
  display: flex;
  flex-direction: column;
  gap: 12px;
}
.tool-icon {
  font-size: 32px;
}
.tool-info h3 {
  margin: 0 0 4px 0;
  font-size: 16px;
  color: #1f2937;
}
.tool-info p {
  margin: 0;
  font-size: 13px;
  color: #6b7280;
}
.tool-actions {
  display: flex;
  align-items: center;
  gap: 8px;
}
.tool-actions .form-control {
