<% var active = 'messages' %>
<div class="admin-page">
  <div class="page-header">
    <h1>发送站内信</h1>
    <a href="/admin/messages" class="btn">返回列表</a>
  </div>

  <% if (typeof error !== 'undefined' && error) { %>
    <div class="alert alert-error"><%= error %></div>
  <% } %>

  <form action="/admin/messages/send" method="POST" class="admin-form" style="max-width: 700px;">
    <input type="hidden" name="_csrf" value="<%= csrfToken %>">

    <div class="form-group">
      <label>
        <input type="checkbox" id="broadcast" name="broadcast" value="1" <%= prefill.broadcast === '1' ? 'checked' : '' %> onchange="toggleBroadcast()">
        群发给所有用户
      </label>
    </div>

    <div class="form-group" id="user-select-group">
      <label for="to_user_id">接收用户 <span style="color: var(--danger);">*</span></label>
      <select id="to_user_id" name="to_user_id" style="width: 100%;">
        <option value="">请选择用户</option>
        <% users.forEach(function(u) { %>
          <option value="<%= u.id %>" <%= prefill.to_user_id == u.id ? 'selected' : '' %>>
            <%= u.nickname || u.username %> (<%= u.username %>)
          </option>
        <% }); %>
      </select>
    </div>

    <div class="form-group">
      <label for="title">标题 <span style="color: var(--danger);">*</span></label>
      <input type="text" id="title" name="title" value="<%= prefill.title || '' %>" required>
    </div>

    <div class="form-group">
      <label for="content">内容 <span style="color: var(--danger);">*</span></label>
      <textarea id="content" name="content" rows="8" required style="width: 100%;"><%= prefill.content || '' %></textarea>
    </div>

    <div class="form-group">
      <label>
        <input type="checkbox" id="is_popup" name="is_popup" value="1" <%= prefill.is_popup === '1' ? 'checked' : '' %>>
        弹窗通知（用户访问时弹出提示框）
      </label>
    </div>

    <div class="form-actions">
      <button type="submit" class="btn btn-primary">发送</button>
      <a href="/admin/messages" class="btn">取消</a>
    </div>
  </form>
</div>

<script>
function toggleBroadcast() {
  var broadcast = document.getElementById('broadcast');
  var userSelect = document.getElementById('user-select-group');
  var toUser = document.getElementById('to_user_id');
  if (broadcast.checked) {
    userSelect.style.display = 'none';
    toUser.removeAttribute('required');
  } else {
    userSelect.style.display = '';
    toUser.setAttribute('required', 'required');
  }
}
toggleBroadcast();
</script>
