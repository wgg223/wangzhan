<% var active = 'articles' %>
<div class="admin-page">
  <div class="page-header">
    <h1>文章管理</h1>
    <a href="/admin/articles/new" class="btn btn-primary">新建文章</a>
  </div>
  
  <table class="admin-table">
    <thead>
      <tr>
        <th>ID</th>
        <th>标题</th>
        <th>分类</th>
        <th>作者</th>
        <th>状态</th>
        <th>发布时间</th>
        <th>操作</th>
      </tr>
    </thead>
    <tbody>
      <% if (articles.length > 0) { %>
        <% articles.forEach(function(article) { %>
          <tr>
            <td><%= article.id %></td>
            <td><%= article.title %></td>
            <td><%= article.category || '未分类' %></td>
            <td><%= article.author_name || '未知' %></td>
            <td><span class="status-badge status-<%= article.status %>"><%= article.status === 'published' ? '已发布' : '草稿' %></span></td>
            <td><%= new Date(article.created_at).toLocaleDateString('zh-CN') %></td>
            <td class="actions">
              <a href="/admin/articles/edit/<%= article.id %>" class="btn btn-small">编辑</a>
              <a href="/articles/<%= article.id %>" target="_blank" class="btn btn-small">查看</a>
              <form action="/admin/articles/delete/<%= article.id %>" method="POST" class="inline-form" onsubmit="return confirm('确定要删除这篇文章吗？')">
                <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                <button type="submit" class="btn btn-small btn-danger">删除</button>
              </form>
            </td>
          </tr>
        <% }); %>
      <% } else { %>
        <tr>
          <td colspan="7" class="empty-row">暂无文章</td>
        </tr>
      <% } %>
    </tbody>
  </table>
</div>