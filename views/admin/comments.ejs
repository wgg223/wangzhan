<% var active = 'comments' %>
<div class="admin-page">
  <div class="page-header">
    <h1>评论管理</h1>
  </div>
  
  <div class="comment-tabs">
    <button class="tab-btn active" onclick="switchTab('article')">文章评论</button>
    <button class="tab-btn" onclick="switchTab('media')">图片评论</button>
  </div>
  
  <!-- 文章评论 -->
  <div id="article-comments" class="tab-content active">
    <table class="admin-table">
      <thead>
        <tr>
          <th>ID</th>
          <th>文章</th>
          <th>评论者</th>
          <th>评论内容</th>
          <th>状态</th>
          <th>时间</th>
          <th>操作</th>
        </tr>
      </thead>
      <tbody>
        <% if (comments.length > 0) { %>
          <% comments.forEach(c => { %>
            <tr class="<%= c.status === 'pending' ? 'row-pending' : '' %>">
              <td><%= c.id %></td>
              <td>
                <a href="/articles/<%= c.article_id %>" target="_blank">
                  <%= c.article_title || '文章已删除' %>
                </a>
              </td>
              <td>
                <% if (c.commenter_name) { %>
                  <strong><%= c.commenter_name %></strong>
                  <span class="commenter-type">(注册用户)</span>
                <% } else if (c.visitor_name) { %>
                  <%= c.visitor_name %>
                  <span class="commenter-type">(<%= c.visitor_email %>)</span>
                <% } else { %>
                  <span class="anonymous-label">匿名</span>
                <% } %>
              </td>
              <td>
                <div class="comment-content">
                  <%= c.content.substring(0, 100) %><%= c.content.length > 100 ? '...' : '' %>
                </div>
                <% if (c.parent_id > 0) { %>
                  <span class="reply-badge">回复</span>
                <% } %>
              </td>
              <td>
                <span class="status-badge status-<%= c.status %>">
                  <% if (c.status === 'approved') { %>已通过<% } %>
                  <% if (c.status === 'pending') { %>待审核<% } %>
                  <% if (c.status === 'rejected') { %>已拒绝<% } %>
                </span>
              </td>
              <td><%= new Date(c.created_at).toLocaleString('zh-CN') %></td>
              <td class="actions">
                <% if (c.status === 'pending') { %>
                  <form action="/admin/comments/approve/<%= c.id %>" method="POST" class="inline-form">
                    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                    <button type="submit" class="btn btn-small btn-success">通过</button>
                  </form>
                  <form action="/admin/comments/reject/<%= c.id %>" method="POST" class="inline-form">
                    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                    <button type="submit" class="btn btn-small btn-warning">拒绝</button>
                  </form>
                <% } %>
                <% if (c.status === 'rejected') { %>
                  <form action="/admin/comments/approve/<%= c.id %>" method="POST" class="inline-form">
                    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                    <button type="submit" class="btn btn-small btn-success">恢复</button>
                  </form>
                <% } %>
                <form action="/admin/comments/delete/<%= c.id %>" method="POST" class="inline-form" onsubmit="return confirm('确定要删除这条评论吗？')">
                  <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                  <button type="submit" class="btn btn-small btn-danger">删除</button>
                </form>
              </td>
            </tr>
          <% }) %>
        <% } else { %>
          <tr>
            <td colspan="7" class="empty-row">暂无文章评论</td>
          </tr>
        <% } %>
      </tbody>
    </table>
  </div>
  
  <!-- 图片评论 -->
  <div id="media-comments" class="tab-content">
    <table class="admin-table">
      <thead>
        <tr>
          <th>ID</th>
          <th>图片</th>
          <th>评论者</th>
          <th>评论内容</th>
          <th>状态</th>
          <th>时间</th>
          <th>操作</th>
        </tr>
      </thead>
      <tbody>
        <% if (mediaComments.length > 0) { %>
          <% mediaComments.forEach(c => { %>
            <tr class="<%= c.status === 'pending' ? 'row-pending' : '' %>">
              <td><%= c.id %></td>
              <td>
                <a href="/image-share" target="_blank">
                  <%= c.media_title || '图片已删除' %>
                </a>
              </td>
              <td>
                <% if (c.commenter_name) { %>
                  <strong><%= c.commenter_name %></strong>
                  <span class="commenter-type">(注册用户)</span>
                <% } else if (c.visitor_name) { %>
                  <%= c.visitor_name %>
                  <span class="commenter-type">(<%= c.visitor_email %>)</span>
                <% } else { %>
                  <span class="anonymous-label">匿名</span>
                <% } %>
              </td>
              <td>
                <div class="comment-content">
                  <%= c.content.substring(0, 100) %><%= c.content.length > 100 ? '...' : '' %>
                </div>
              </td>
              <td>
                <span class="status-badge status-<%= c.status %>">
                  <% if (c.status === 'approved') { %>已通过<% } %>
                  <% if (c.status === 'pending') { %>待审核<% } %>
                  <% if (c.status === 'rejected') { %>已拒绝<% } %>
                </span>
              </td>
              <td><%= new Date(c.created_at).toLocaleString('zh-CN') %></td>
              <td class="actions">
                <% if (c.status === 'pending') { %>
                  <form action="/admin/media-comments/approve/<%= c.id %>" method="POST" class="inline-form">
                    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                    <button type="submit" class="btn btn-small btn-success">通过</button>
                  </form>
                  <form action="/admin/media-comments/reject/<%= c.id %>" method="POST" class="inline-form">
                    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                    <button type="submit" class="btn btn-small btn-warning">拒绝</button>
                  </form>
                <% } %>
                <% if (c.status === 'rejected') { %>
                  <form action="/admin/media-comments/approve/<%= c.id %>" method="POST" class="inline-form">
                    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                    <button type="submit" class="btn btn-small btn-success">恢复</button>
                  </form>
                <% } %>
                <form action="/admin/media-comments/delete/<%= c.id %>" method="POST" class="inline-form" onsubmit="return confirm('确定要删除这条图片评论吗？')">
                  <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                  <button type="submit" class="btn btn-small btn-danger">删除</button>
                </form>
              </td>
            </tr>
          <% }) %>
        <% } else { %>
          <tr>
            <td colspan="7" class="empty-row">暂无图片评论</td>
          </tr>
        <% } %>
      </tbody>
    </table>
  </div>
</div>

<style>
.row-pending {
  background: var(--warning-bg);
}

.comment-content {
  max-width: 300px;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  font-size: 13px;
  color: var(--gray-600);
}

.reply-badge {
  display: inline-block;
  padding: 1px 5px;
  background: var(--info-bg);
  color: var(--primary);
  border-radius: 3px;
  font-size: 11px;
  margin-left: 5px;
}

.comment-tabs {
  margin-bottom: 20px;
  display: flex;
  gap: 0;
  border-bottom: 2px solid var(--gray-200);
}

.tab-btn {
  padding: 10px 24px;
  background: transparent;
  border: none;
  border-bottom: 2px solid transparent;
  margin-bottom: -2px;
  cursor: pointer;
  font-size: 14px;
  font-weight: 500;
  color: var(--text-muted);
  transition: all 0.2s;
}

.tab-btn:hover {
  color: var(--primary);
}

.tab-btn.active {
  color: var(--primary);
  border-bottom-color: var(--primary);
}

.tab-content {
  display: none;
}

.tab-content.active {
  display: block;
}

.commenter-type {
  font-size: 12px;
  color: var(--gray-400);
}

.anonymous-label {
  color: var(--text-muted);
}
</style>

<script>
function switchTab(tab) {
  document.querySelectorAll('.tab-btn').forEach(btn => btn.classList.remove('active'));
  document.querySelectorAll('.tab-content').forEach(content => content.classList.remove('active'));
  
  if (tab === 'article') {
    document.querySelectorAll('.tab-btn')[0].classList.add('active');
    document.getElementById('article-comments').classList.add('active');
  } else {
    document.querySelectorAll('.tab-btn')[1].classList.add('active');
    document.getElementById('media-comments').classList.add('active');
  }
}
</script>