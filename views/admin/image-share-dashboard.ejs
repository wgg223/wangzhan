<h2 style="margin-bottom: 20px;">🖼️ 图片分享管理</h2>

<div class="stats" style="display: grid; grid-template-columns: repeat(auto-fit, minmax(150px, 1fr)); gap: 15px; margin-bottom: 20px;">
  <div class="stat-card" style="background: white; border-radius: 10px; padding: 20px; text-align: center; box-shadow: 0 2px 8px rgba(0,0,0,0.06);">
    <div style="font-size: 28px; font-weight: bold; color: #667eea;"><%= stats.total %></div>
    <div style="font-size: 13px; color: #999; margin-top: 5px;">总图片</div>
  </div>
  <div class="stat-card" style="background: white; border-radius: 10px; padding: 20px; text-align: center; box-shadow: 0 2px 8px rgba(0,0,0,0.06);">
    <div style="font-size: 28px; font-weight: bold; color: #ffc107;"><%= stats.pending %></div>
    <div style="font-size: 13px; color: #999; margin-top: 5px;">待审核</div>
  </div>
  <div class="stat-card" style="background: white; border-radius: 10px; padding: 20px; text-align: center; box-shadow: 0 2px 8px rgba(0,0,0,0.06);">
    <div style="font-size: 28px; font-weight: bold; color: #28a745;"><%= stats.approved %></div>
    <div style="font-size: 13px; color: #999; margin-top: 5px;">已通过</div>
  </div>
  <div class="stat-card" style="background: white; border-radius: 10px; padding: 20px; text-align: center; box-shadow: 0 2px 8px rgba(0,0,0,0.06);">
    <div style="font-size: 28px; font-weight: bold; color: #dc3545;"><%= stats.rejected %></div>
    <div style="font-size: 13px; color: #999; margin-top: 5px;">已驳回</div>
  </div>
  <div class="stat-card" style="background: white; border-radius: 10px; padding: 20px; text-align: center; box-shadow: 0 2px 8px rgba(0,0,0,0.06);">
    <div style="font-size: 28px; font-weight: bold; color: #667eea;"><%= stats.users %></div>
    <div style="font-size: 13px; color: #999; margin-top: 5px;">用户数</div>
  </div>
  <div class="stat-card" style="background: white; border-radius: 10px; padding: 20px; text-align: center; box-shadow: 0 2px 8px rgba(0,0,0,0.06);">
    <div style="font-size: 28px; font-weight: bold; color: #667eea;"><%= stats.categories %></div>
    <div style="font-size: 13px; color: #999; margin-top: 5px;">分类数</div>
  </div>
</div>

<div style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-bottom: 20px;">
  <a href="/admin/image-share/images?status=0" style="display: block; text-align: center; cursor: pointer; border-left: 4px solid #ffc107; background: white; border-radius: 8px; padding: 20px; text-decoration: none; color: inherit; box-shadow: 0 2px 8px rgba(0,0,0,0.06); transition: all 0.3s;" onmouseover="this.style.transform='translateY(-2px)';this.style.boxShadow='0 4px 12px rgba(0,0,0,0.12)'" onmouseout="this.style.transform='';this.style.boxShadow='0 2px 8px rgba(0,0,0,0.06)'">
    <div style="font-size: 24px; color: #ffc107;">🕐</div>
    <h3 style="margin-top: 10px; font-size: 16px;">审核图片</h3>
  </a>
  <a href="/admin/image-share/images" style="display: block; text-align: center; cursor: pointer; border-left: 4px solid #667eea; background: white; border-radius: 8px; padding: 20px; text-decoration: none; color: inherit; box-shadow: 0 2px 8px rgba(0,0,0,0.06); transition: all 0.3s;" onmouseover="this.style.transform='translateY(-2px)';this.style.boxShadow='0 4px 12px rgba(0,0,0,0.12)'" onmouseout="this.style.transform='';this.style.boxShadow='0 2px 8px rgba(0,0,0,0.06)'">
    <div style="font-size: 24px; color: #667eea;">🖼️</div>
    <h3 style="margin-top: 10px; font-size: 16px;">图片管理</h3>
  </a>
  <a href="/admin/image-share/categories" style="display: block; text-align: center; cursor: pointer; border-left: 4px solid #28a745; background: white; border-radius: 8px; padding: 20px; text-decoration: none; color: inherit; box-shadow: 0 2px 8px rgba(0,0,0,0.06); transition: all 0.3s;" onmouseover="this.style.transform='translateY(-2px)';this.style.boxShadow='0 4px 12px rgba(0,0,0,0.12)'" onmouseout="this.style.transform='';this.style.boxShadow='0 2px 8px rgba(0,0,0,0.06)'">
    <div style="font-size: 24px; color: #28a745;">📁</div>
    <h3 style="margin-top: 10px; font-size: 16px;">分类管理</h3>
  </a>
  <a href="/admin/image-share/settings" style="display: block; text-align: center; cursor: pointer; border-left: 4px solid #17a2b8; background: white; border-radius: 8px; padding: 20px; text-decoration: none; color: inherit; box-shadow: 0 2px 8px rgba(0,0,0,0.06); transition: all 0.3s;" onmouseover="this.style.transform='translateY(-2px)';this.style.boxShadow='0 4px 12px rgba(0,0,0,0.12)'" onmouseout="this.style.transform='';this.style.boxShadow='0 2px 8px rgba(0,0,0,0.06)'">
    <div style="font-size: 24px; color: #17a2b8;">⚙️</div>
    <h3 style="margin-top: 10px; font-size: 16px;">网站设置</h3>
  </a>
</div>

<div style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-bottom: 20px;">
  <a href="/admin/image-share/trusted-users" style="display: block; text-align: center; cursor: pointer; border-left: 4px solid #e83e8c; background: white; border-radius: 8px; padding: 20px; text-decoration: none; color: inherit; box-shadow: 0 2px 8px rgba(0,0,0,0.06); transition: all 0.3s;" onmouseover="this.style.transform='translateY(-2px)';this.style.boxShadow='0 4px 12px rgba(0,0,0,0.12)'" onmouseout="this.style.transform='';this.style.boxShadow='0 2px 8px rgba(0,0,0,0.06)'">
    <div style="font-size: 24px; color: #e83e8c;">👤</div>
    <h3 style="margin-top: 10px; font-size: 16px;">免审核用户</h3>
  </a>
  <a href="/admin/image-share/comments" style="display: block; text-align: center; cursor: pointer; border-left: 4px solid #fd7e14; background: white; border-radius: 8px; padding: 20px; text-decoration: none; color: inherit; box-shadow: 0 2px 8px rgba(0,0,0,0.06); transition: all 0.3s;" onmouseover="this.style.transform='translateY(-2px)';this.style.boxShadow='0 4px 12px rgba(0,0,0,0.12)'" onmouseout="this.style.transform='';this.style.boxShadow='0 2px 8px rgba(0,0,0,0.06)'">
    <div style="font-size: 24px; color: #fd7e14;">💬</div>
    <h3 style="margin-top: 10px; font-size: 16px;">图片评论</h3>
  </a>
</div>

<div class="card" style="background: white; border-radius: 12px; padding: 20px; margin-bottom: 20px; box-shadow: 0 2px 8px rgba(0,0,0,0.06);">
  <h3 style="margin-bottom: 15px;">📋 最近操作日志</h3>
  <% if (recentLogs.length > 0) { %>
    <table>
      <thead>
        <tr>
          <th>管理员</th>
          <th>操作内容</th>
          <th>时间</th>
        </tr>
      </thead>
      <tbody>
        <% recentLogs.forEach(function(log) { %>
          <tr>
            <td><%= log.admin_name || '未知' %></td>
            <td><%= log.content %></td>
            <td style="color: #999; font-size: 12px;"><%= log.created_at %></td>
          </tr>
        <% }); %>
      </tbody>
    </table>
  <% } else { %>
    <p style="color: #999; text-align: center;">暂无操作日志</p>
  <% } %>
</div>