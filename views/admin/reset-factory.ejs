<% var active = 'reset' %>
<div class="admin-page">
  <div class="page-header">
    <h1>🔥 恢复出厂设置</h1>
  </div>

  <div class="alert alert-danger">
    <strong>☠️ 极度危险操作：</strong>此操作将<strong>删除整个数据库文件</strong>，<strong>彻底清空所有数据</strong>（包括超级管理员账户、网站设置、所有用户、文章、页面、评论、媒体、小说等全部数据），系统将恢复至<strong>全新安装状态</strong>。此操作不可撤销！
  </div>

  <div class="card" style="border-color: var(--danger-bg); background: var(--danger-bg); margin-bottom: 20px;">
    <h2 style="color: var(--danger-dark);">⚠️ 完全恢复出厂设置说明</h2>
    <p style="margin-bottom: 16px; color: var(--danger-dark);">
      与"重置服务器"不同，"恢复出厂设置"将执行以下操作：
    </p>
    <ul style="margin-bottom: 16px; padding-left: 20px; color: var(--danger-dark); line-height: 1.8;">
      <li><strong>删除数据库文件 (database.sqlite)</strong> — 所有数据永久消失</li>
      <li>删除所有已上传的媒体文件（图片、小说章节等）</li>
      <li>删除所有用户账户（包括超级管理员 admin）</li>
      <li>删除所有网站设置、页面、文章、评论等全部内容</li>
      <li>会话将被销毁，您将立刻退出登录</li>
      <li><strong>服务器需要手动重启</strong> — 重启后系统将自动重建全新的数据库</li>
    </ul>
    <p style="color: var(--danger-dark); font-weight: 600;">
      重启服务器后首次访问将自动创建新的默认管理员账户：<strong>admin / admin123</strong>
    </p>
  </div>

  <div class="card">
    <h2>📊 当前数据统计（即将全部丢失）</h2>
    <p style="margin-bottom: 16px; color: var(--gray-500);">以下所有数据都将在恢复出厂设置后被彻底删除，总计 <strong style="color: var(--danger-dark);"><%= totalRecords %></strong> 条记录：</p>
    
    <% projectStats.forEach(function(project) { %>
    <div class="project-stat-block">
      <h3 style="margin-bottom: 8px; font-size: 16px;"><%= project.icon %> <%= project.name %></h3>
      <p style="margin-bottom: 8px; color: var(--gray-500); font-size: 13px;"><%= project.description %></p>
      <div class="reset-stats">
        <% var tableKeys = Object.keys(project.stats); %>
        <% tableKeys.forEach(function(table) { %>
        <div class="reset-stat-item">
          <span class="reset-stat-label"><%= table %></span>
          <span class="reset-stat-value"><%= project.stats[table] %></span>
        </div>
        <% }); %>
      </div>
      <div class="project-total">
        小计：<span><%= project.totalRecords %></span> 条记录
      </div>
    </div>
    <% }); %>

    <!-- 全局数据统计 -->
    <div class="project-stat-block">
      <h3 style="margin-bottom: 8px; font-size: 16px;">🌐 全局数据</h3>
      <p style="margin-bottom: 8px; color: var(--gray-500); font-size: 13px;">用户、媒体、活动日志等跨模块数据</p>
      <div class="reset-stats">
        <div class="reset-stat-item">
          <span class="reset-stat-label">👤 所有用户</span>
          <span class="reset-stat-value"><%= totalUsers %></span>
        </div>
        <div class="reset-stat-item">
          <span class="reset-stat-label">🖼️ 媒体文件</span>
          <span class="reset-stat-value"><%= globalStats.media %></span>
        </div>
        <div class="reset-stat-item">
          <span class="reset-stat-label">📋 活动日志</span>
          <span class="reset-stat-value"><%= globalStats.activity_logs %></span>
        </div>
        <div class="reset-stat-item">
          <span class="reset-stat-label">📬 站内信</span>
          <span class="reset-stat-value"><%= globalStats.internal_messages %></span>
        </div>
        <div class="reset-stat-item">
          <span class="reset-stat-label">🔔 通知</span>
          <span class="reset-stat-value"><%= globalStats.notifications %></span>
        </div>
        <div class="reset-stat-item">
          <span class="reset-stat-label">❤️ 点赞</span>
          <span class="reset-stat-value"><%= globalStats.content_likes %></span>
        </div>
        <div class="reset-stat-item">
          <span class="reset-stat-label">👥 用户关注</span>
          <span class="reset-stat-value"><%= globalStats.user_follows %></span>
        </div>
        <div class="reset-stat-item">
          <span class="reset-stat-label">🏷️ 标签</span>
          <span class="reset-stat-value"><%= globalStats.tags %></span>
        </div>
        <div class="reset-stat-item">
          <span class="reset-stat-label">🔗 标签关联</span>
          <span class="reset-stat-value"><%= globalStats.content_tags %></span>
        </div>
        <div class="reset-stat-item">
          <span class="reset-stat-label">📝 内容版本</span>
          <span class="reset-stat-value"><%= globalStats.content_versions %></span>
        </div>
        <div class="reset-stat-item">
          <span class="reset-stat-label">📄 文章草稿</span>
          <span class="reset-stat-value"><%= globalStats.article_drafts %></span>
        </div>
      </div>
    </div>
  </div>

  <div class="card" style="border-color: var(--danger-dark); background: var(--danger-bg); border-width: 2px;">
    <h2 style="color: var(--danger-dark);">🔐 最后确认</h2>
    <p style="margin-bottom: 16px; color: var(--danger-dark); font-weight: 600;">
      请输入以下信息以确认执行恢复出厂设置：
    </p>
    <div class="form-group">
      <label for="confirm-text" style="color: var(--danger-dark); font-weight: 600;">
        请输入 <strong style="color: var(--danger-dark); font-size: 18px;">恢复出厂设置</strong> 以继续：
      </label>
      <input type="text" id="confirm-text" placeholder="请输入" style="border-color: var(--danger-bg); max-width: 400px;">
    </div>
    <div class="form-group">
      <label for="admin-password" style="color: var(--danger-dark); font-weight: 600;">
        🔑 请输入当前管理员密码以确认身份：
      </label>
      <input type="password" id="admin-password" placeholder="请输入管理员密码" style="border-color: var(--danger-bg); max-width: 400px;">
    </div>
    <div class="form-actions">
      <button type="button" class="btn btn-danger btn-large" id="reset-btn" onclick="executeFactoryReset()" disabled>🔥 执行恢复出厂设置</button>
      <a href="/admin/reset" class="btn">返回普通重置</a>
      <a href="/admin" class="btn">取消</a>
    </div>
  </div>
</div>

<div id="reset-progress-overlay" style="display:none; position:fixed; top:0; left:0; right:0; bottom:0; background:rgba(0,0,0,0.25); z-index:9999; align-items:center; justify-content:center;">
  <div style="background:var(--bg-card); padding:40px; border-radius:16px; text-align:center; max-width:450px; box-shadow:0 25px 50px rgba(0,0,0,0.3);">
    <div class="spinner" style="width:48px; height:48px; border:4px solid var(--gray-200); border-top-color:var(--danger); border-radius:50%; animation:spin 0.8s linear infinite; margin:0 auto 20px;"></div>
    <h3 style="margin-bottom:8px; color:var(--gray-900);">🔥 正在恢复出厂设置...</h3>
    <p style="color:var(--text-muted); font-size:14px;">正在删除数据库文件和媒体文件，请勿关闭页面...</p>
  </div>
</div>

<div id="reboot-overlay" style="display:none; position:fixed; top:0; left:0; right:0; bottom:0; background:rgba(0,0,0,0.35); z-index:10000; align-items:center; justify-content:center;">
  <div style="background:var(--bg-card); padding:40px; border-radius:16px; text-align:center; max-width:500px; box-shadow:0 25px 50px rgba(0,0,0,0.3);">
    <div style="font-size:48px; margin-bottom:16px;">✅</div>
    <h3 style="margin-bottom:12px; color:var(--gray-900);">恢复出厂设置成功！</h3>
    <p style="color:var(--text-muted); font-size:14px; line-height:1.8; margin-bottom:20px;" id="reboot-message"></p>
    <p style="color:var(--danger-dark); font-size:14px; font-weight:600; margin-bottom:20px; padding:12px; background:var(--danger-bg); border-radius:8px;">
      ⚠️ 服务器已没有数据库文件，需要手动重启服务器才能重新使用！
    </p>
    <p style="color:var(--text-muted); font-size:13px; margin-bottom:20px;">
      重启服务器后，系统将自动创建全新的默认管理员账户：<strong>admin / admin123</strong>
    </p>
    <div style="background:var(--gray-50); padding:16px; border-radius:8px; text-align:left; margin-bottom:20px; font-size:13px; color:var(--gray-700); line-height:1.8;">
      <strong>重启命令：</strong><br>
      <code style="background:var(--gray-900); color:var(--primary-light); padding:2px 8px; border-radius:4px;">node server/app.js</code>
    </div>
    <button type="button" class="btn" onclick="window.location.href='/auth/login'" style="padding:12px 32px; font-size:15px;">
      稍后手动重启 →
    </button>
  </div>
</div>

<style>
@keyframes spin {
  to { transform: rotate(360deg); }
}

.reset-stats {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
  gap: 12px;
}

.reset-stat-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 12px 16px;
  background: var(--gray-50);
  border-radius: var(--radius-sm);
  border: 1px solid var(--gray-100);
}

.reset-stat-label {
  font-size: 14px;
  color: var(--gray-600);
}

.reset-stat-value {
  font-size: 18px;
  font-weight: 700;
  color: var(--danger);
}

.project-total {
  margin-top: 12px;
  padding: 10px 12px;
  background: var(--primary-bg);
  border-radius: 6px;
  text-align: center;
  font-size: 14px;
  color: var(--gray-600);
}

.project-total span {
  font-weight: 700;
  color: var(--primary);
  font-size: 18px;
}

.project-stat-block {
  margin-bottom: 24px;
  padding-bottom: 20px;
  border-bottom: 1px solid var(--gray-100);
}

.project-stat-block:last-child {
  border-bottom: none;
  margin-bottom: 0;
  padding-bottom: 0;
}

code {
  font-family: 'SFMono-Regular', Consolas, 'Liberation Mono', Menlo, monospace;
}
</style>

<script>
// 输入确认文本和密码后启用按钮
document.addEventListener('DOMContentLoaded', function() {
  var confirmInput = document.getElementById('confirm-text');
  var passwordInput = document.getElementById('admin-password');
  var resetBtn = document.getElementById('reset-btn');

  function checkForm() {
    resetBtn.disabled = !(confirmInput.value.trim() === '恢复出厂设置' && passwordInput.value.trim().length >= 6);
  }

  if (confirmInput && passwordInput && resetBtn) {
    confirmInput.addEventListener('input', checkForm);
    passwordInput.addEventListener('input', checkForm);

    // 回车提交
    passwordInput.addEventListener('keydown', function(e) {
      if (e.key === 'Enter' && !resetBtn.disabled) {
        executeFactoryReset();
      }
    });
  }
});

// 从页面 meta 标签获取 CSRF token
function getCsrfToken() {
  var meta = document.querySelector('meta[name="csrf-token"]');
  return meta ? meta.getAttribute('content') : '';
}

function executeFactoryReset() {
  var passwordInput = document.getElementById('admin-password');
  var password = passwordInput ? passwordInput.value.trim() : '';

  if (!password) {
    alert('⚠️ 请输入管理员密码');
    return;
  }

  if (!confirm('☠️ 这是最后确认！\n\n此操作将完全删除数据库文件！\n所有数据（包括管理员账户、网站设置）将永久丢失！\n\n服务器需要手动重启才能重新使用！\n\n确定要继续吗？')) {
    return;
  }

  // 二次确认
  if (!confirm('🔥 再次确认：您确定要恢复出厂设置吗？\n\n此操作不可撤销！')) {
    return;
  }

  // 显示进度遮罩
  var overlay = document.getElementById('reset-progress-overlay');
  if (overlay) {
    overlay.style.display = 'flex';
  }

  // 禁用按钮
  var resetBtn = document.getElementById('reset-btn');
  if (resetBtn) {
    resetBtn.disabled = true;
    resetBtn.textContent = '恢复出厂设置中...';
  }

  fetch('/admin/reset/factory-execute', {
    method: 'POST',
    headers: {
      'Content-Type': 'application/json',
      'x-csrf-token': getCsrfToken()
    },
    body: JSON.stringify({ password: password })
  })
  .then(function(response) {
    if (!response.ok) {
      return response.json().then(function(data) {
        throw new Error(data.error || '请求失败');
      });
    }
    return response.json();
  })
  .then(function(data) {
    if (data.success) {
      // 隐藏进度遮罩
      if (overlay) overlay.style.display = 'none';
      
      // 显示重启提示
      var rebootOverlay = document.getElementById('reboot-overlay');
      var rebootMessage = document.getElementById('reboot-message');
      if (rebootOverlay) {
        rebootOverlay.style.display = 'flex';
      }
      if (rebootMessage) {
        rebootMessage.textContent = data.detail || '数据库文件已被删除，所有数据已清空。';
      }
    } else {
      alert('❌ 恢复出厂设置失败: ' + (data.error || '未知错误'));
      if (overlay) overlay.style.display = 'none';
      if (resetBtn) {
        resetBtn.disabled = false;
        resetBtn.textContent = '🔥 执行恢复出厂设置';
      }
    }
  })
  .catch(function(err) {
    alert('❌ 错误: ' + err.message);
    if (overlay) overlay.style.display = 'none';
    if (resetBtn) {
      resetBtn.disabled = false;
      resetBtn.textContent = '🔥 执行恢复出厂设置';
    }
  });
}
</script>