<% var active = 'users' %>
<div class="admin-page">
  <div class="page-header">
    <h1>👥 用户管理</h1>
    <div class="actions">
      <button type="button" class="btn btn-primary" onclick="openCreateUserModal()">+ 添加用户</button>
    </div>
  </div>
  
  <div class="section-card accent-primary">
    <div class="section-header bg-gradient-primary">
      <h2>用户列表 <span class="badge badge-primary"><%= users.length %></span></h2>
    </div>
    <div class="section-body" style="padding:0;">
      <table class="admin-table">
        <thead>
          <tr>
            <th>ID</th>
            <th>用户名</th>
            <th>邮箱</th>
            <th>角色</th>
            <th>状态</th>
            <th>注册时间</th>
            <th>操作</th>
          </tr>
        </thead>
        <tbody>
          <% if (users.length > 0) { %>
            <% users.forEach(u => { %>
              <tr>
                <td><span style="color:var(--gray-400);font-family:var(--font-mono);font-size:var(--text-sm);"><%= u.uid || '#' + u.id %></span></td>
                <td><strong><%= u.username %></strong></td>
                <td><%= u.email || '未填写' %></td>
                <td>
                  <span class="role-badge role-<%= u.role %>">
                    <% if (u.role === 'super_admin') { %>👑 超级管理员<% } %>
                    <% if (u.role === 'admin') { %>🛡️ 管理员<% } %>
                    <% if (u.role === 'user') { %>👤 用户<% } %>
                    <% if (u.role === 'visitor') { %>👁️ 访客<% } %>
                  </span>
                  <% if (u.role !== 'super_admin') { %>
                    <form action="/admin/users/role/<%= u.id %>" method="POST" class="inline-form" style="margin-left:6px;">
                      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                      <select name="role" onchange="this.form.submit()" style="font-size:11px;padding:2px 6px;border-radius:4px;border:1px solid var(--gray-200);" <%= (u.id === user.id) ? 'disabled' : '' %>>
                        <option value="admin" <%= u.role === 'admin' ? 'selected' : '' %>>管理员</option>
                        <option value="user" <%= u.role === 'user' ? 'selected' : '' %>>用户</option>
                        <option value="visitor" <%= u.role === 'visitor' ? 'selected' : '' %>>访客</option>
                      </select>
                    </form>
                  <% } %>
                </td>
                <td>
                  <span class="status-badge status-<%= u.status %>">
                    <% if (u.status === 'active') { %>✅ 已激活<% } %>
                    <% if (u.status === 'pending') { %>⏳ 待审核<% } %>
                    <% if (u.status === 'disabled') { %>🚫 已禁用<% } %>
                  </span>
                </td>
                <td><%= new Date(u.created_at).toLocaleDateString('zh-CN') %></td>
                <td class="actions">
                  <% if (u.id !== user.id) { %>
                    <% if (u.status === 'pending') { %>
                      <form action="/admin/users/approve/<%= u.id %>" method="POST" class="inline-form">
                        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                        <button type="submit" class="btn btn-small btn-success">✓ 通过</button>
                      </form>
                    <% } %>
                    <% if (u.status === 'active') { %>
                      <form action="/admin/users/disable/<%= u.id %>" method="POST" class="inline-form">
                        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                        <button type="submit" class="btn btn-small btn-warning">禁用</button>
                      </form>
                    <% } %>
                    <% if (u.status === 'disabled') { %>
                      <form action="/admin/users/approve/<%= u.id %>" method="POST" class="inline-form">
                        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                        <button type="submit" class="btn btn-small btn-success">启用</button>
                      </form>
                    <% } %>
                    <button type="button" class="btn btn-small btn-info" onclick="resetPassword(<%= u.id %>, '<%= u.username %>')">🔑 重置</button>
                    <form action="/admin/users/delete/<%= u.id %>" method="POST" class="inline-form" onsubmit="return confirm('确定要删除这个用户吗？')">
                      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                      <button type="submit" class="btn btn-small btn-danger">删除</button>
                    </form>
                  <% } else { %>
                    <span class="current-user-label">当前登录</span>
                  <% } %>
                </td>
              </tr>
            <% }) %>
          <% } else { %>
            <tr>
              <td colspan="7" class="empty-row">暂无用户</td>
            </tr>
          <% } %>
        </tbody>
      </table>
    </div>
  </div>
</div>

<style>
.current-user-label {
  color: var(--gray-400);
  font-size: var(--text-xs);
  font-style: italic;
  background: var(--gray-50);
  padding: 2px 8px;
  border-radius: var(--radius-xs);
}
</style>

<!-- 创建用户模态框 -->
<div id="create-user-modal" class="modal" style="display:none;">
  <div class="modal-content">
    <div class="modal-header">
      <h2>添加新用户</h2>
      <button type="button" class="modal-close" onclick="closeCreateUserModal()">&times;</button>
    </div>
    <div class="modal-body">
      <div id="create-user-error" class="alert alert-error" style="display:none;"></div>
      <div class="form-group">
        <label for="new-username">用户名 <span class="required">*</span></label>
        <input type="text" id="new-username" placeholder="请输入用户名（至少3个字符）" required>
      </div>
      <div class="form-group">
        <label for="new-email">邮箱</label>
        <input type="email" id="new-email" placeholder="请输入邮箱（选填）">
      </div>
      <div class="form-group">
        <label for="new-password">密码 <span class="required">*</span></label>
        <input type="password" id="new-password" placeholder="请输入密码（至少6位）" required>
      </div>
      <div class="form-group">
        <label for="new-role">角色 <span class="required">*</span></label>
        <select id="new-role">
          <option value="user">👤 用户</option>
          <option value="admin">🛡️ 管理员</option>
          <option value="visitor">👁️ 访客</option>
        </select>
      </div>
    </div>
    <div class="modal-footer">
      <button type="button" class="btn" onclick="closeCreateUserModal()">取消</button>
      <button type="button" class="btn btn-primary" id="submit-create-user" onclick="submitCreateUser()">创建账户</button>
    </div>
  </div>
</div>

<style>
.modal {
  position: fixed;
  z-index: 1000;
  left: 0;
  top: 0;
  width: 100%;
  height: 100%;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  backdrop-filter: blur(4px);
  animation: modalFadeIn 0.2s ease;
}

.modal-content {
  background: var(--bg-card);
  border-radius: var(--radius-md);
  box-shadow: var(--shadow-xl);
  width: 480px;
  max-width: 90vw;
  max-height: 90vh;
  overflow-y: auto;
  animation: modalSlideIn 0.2s ease;
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20px 24px;
  border-bottom: 1px solid var(--gray-100);
}

.modal-header h2 {
  margin: 0;
  font-size: 18px;
  color: var(--gray-800);
  border: none;
  padding: 0;
}

.modal-close {
  background: none;
  border: none;
  font-size: 24px;
  color: var(--gray-400);
  cursor: pointer;
  padding: 0;
  line-height: 1;
  transition: var(--transition);
}

.modal-close:hover {
  color: var(--gray-600);
}

.modal-body {
  padding: 24px;
}

.modal-footer {
  display: flex;
  justify-content: flex-end;
  gap: 10px;
  padding: 16px 24px;
  border-top: 1px solid var(--gray-100);
}

.required {
  color: var(--danger);
}

@keyframes modalFadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}

@keyframes modalSlideIn {
  from { transform: translateY(-20px); opacity: 0; }
  to { transform: translateY(0); opacity: 1; }
}
</style>
